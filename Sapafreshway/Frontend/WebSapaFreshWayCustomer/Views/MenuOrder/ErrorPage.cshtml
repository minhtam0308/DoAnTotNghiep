@{
    ViewData["Title"] = "Khóa QR";
    Layout = null;

    // BẮT BUỘC: đảm bảo tableId và apiBaseUrl KHÔNG null
    int tableId = ViewBag.TableId == null ? 0 : (int)ViewBag.TableId;
    string apiBaseUrl = ViewBag.ApiBaseUrl ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f8f9fa;
        }

        .call-staff-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            color: white;
            font-size: 14px;
            background: linear-gradient(135deg, #ff6b6b, #f06595);
            border-radius: 25px;
            cursor: pointer;
        }

            .call-staff-btn i {
                font-size: 15px;
            }

            .call-staff-btn:hover {
                opacity: 0.9;
            }

            .call-staff-btn.ringing {
                animation: ring 1s infinite;
            }

        @@keyframes ring {
            0%

        {
            transform: rotate(0deg);
        }

        25% {
            transform: rotate(2deg);
        }

        50% {
            transform: rotate(-2deg);
        }

        75% {
            transform: rotate(2deg);
        }

        100% {
            transform: rotate(0deg);
        }

        }
    </style>
</head>

<body>

    <!-- Hidden values -->
    <input type="hidden" id="tableId" value="@tableId" />
    <input type="hidden" id="apiBaseUrl" value="@apiBaseUrl" />

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="text-center p-5 bg-white rounded shadow-sm">
            <h1 class="text-danger mb-3">⚠️ Không thể gọi món!</h1>
            <p class="lead mb-3">Lý do: @(ViewBag.Error ?? "Đã xảy ra lỗi không xác định.")</p>
            <p class="mb-4">Vui lòng liên hệ nhân viên để được hỗ trợ.</p>

            <!-- Nút gọi nhân viên -->
            <div class="call-staff-btn" id="call-staff-btn" data-has-customer="false">
                <i class="fas fa-bell"></i>
                <span>Gọi Nhân Viên</span>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="mobileToast" style="position: fixed; bottom: 20px; left: 50%;
         transform: translateX(-50%); z-index: 2000; display: none;">
        <div id="mobileToastMessage"
             style="padding: 12px 20px; border-radius: 25px; color: white;
             min-width: 200px; max-width: 80vw; text-align: center;">
            Nội dung thông báo
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="callStaffModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Gọi nhân viên</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <label for="staffNote" class="form-label">Ghi chú (tuỳ chọn):</label>
                    <textarea id="staffNote" class="form-control" rows="3"
                              placeholder="Ví dụ: Cần hỗ trợ gọi món..."></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" id="sendStaffRequest" class="btn btn-primary">
                        <i class="fas fa-paper-plane"></i> Gửi yêu cầu
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Bootstrap + jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Toast function (BẮT BUỘC PHẢI CÓ) -->
    <script>
        function showMobileToast(message, type = "info") {
            const toast = document.getElementById("mobileToast");
            const msg = document.getElementById("mobileToastMessage");

            msg.innerText = message;

            if (type === "success") msg.style.background = "#28a745";
            else if (type === "error") msg.style.background = "#dc3545";
            else msg.style.background = "#6c757d";

            toast.style.display = "block";
            setTimeout(() => toast.style.display = "none", 3000);
        }
    </script>

    <!-- Call staff script -->
    <script src="~/js/call-staff.js"></script>

</body>
</html>
