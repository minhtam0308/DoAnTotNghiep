    function filterByQuantityAndQuality() {
        const quantityStatus = document.getElementById('quantityStatusFilter').value;
        const qualityStatus = document.getElementById('qualityStatusFilter').value;

        // ✅ NẾU ĐANG DÙNG SHORTCUT FILTER, ƯU TIÊN SHORTCUT
        if (currentStatusFilter !== 'all') {
            filterByStatus(currentStatusFilter);
            return;
        }

        // ✅ NẾU KHÔNG CÓ FILTER NÀO, HIỂN THỊ TẤT CẢ
        if (quantityStatus === '' && qualityStatus === '') {
            filterByStatus('all');
            return;
        }

        const rows = document.querySelectorAll('.ingredient-row');
        const noDataRow = document.querySelector('.no-data-row');

        let visibleCount = 0;

        rows.forEach(row => {
            let showRow = true;

            // ✅ FILTER THEO SỐ LƯỢNG
            if (quantityStatus !== '') {
                const qtyCell = row.querySelector('td:nth-child(9)'); // Cột trạng thái số lượng
                const qtyText = qtyCell.textContent.toLowerCase();

                if (quantityStatus === 'normal') {
                    showRow = showRow && qtyText.includes('bình thường');
                } else if (quantityStatus === 'below-reorder') {
                    showRow = showRow && qtyText.includes('dưới tối thiểu');
                } else if (quantityStatus === 'low-stock') {
                    showRow = showRow && qtyText.includes('sắp hết hàng');
                } else if (quantityStatus === 'out-of-stock') {
                    showRow = showRow && qtyText.includes('hết hàng');
                }
            }

            // ✅ FILTER THEO CHẤT LƯỢNG
            if (qualityStatus !== '') {
                const qualityCell = row.querySelector('td:nth-child(10)'); // Cột trạng thái chất lượng
                const qualityText = qualityCell.textContent.toLowerCase();

                if (qualityStatus === 'quality-normal') {
                    showRow = showRow && qualityText.includes('bình thường');
                } else if (qualityStatus === 'expiring-soon') {
                    showRow = showRow && qualityText.includes('sắp hết hạn');
                } else if (qualityStatus === 'expired') {
                    showRow = showRow && qualityText.includes('hết hạn');
                }
            }

            // Hiển thị hoặc ẩn row
            if (showRow) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });

        // Hiển thị thông báo nếu không có kết quả
        if (visibleCount === 0 && !noDataRow) {
            const tbody = document.getElementById('ingredientTableBody');
            const noResultRow = document.createElement('tr');
            noResultRow.className = 'no-result-row';
            noResultRow.innerHTML = `
                <td colspan="11" style="text-align:center; padding:3rem; color:#6b7280;">
                    <i class="fas fa-filter" style="font-size:3rem; color:#d1d5db; margin-bottom:1rem;"></i>
                    <br>
                    <strong style="font-size:1.1rem; color:#374151;">Không có mặt hàng nào phù hợp với bộ lọc</strong>
                    <br>
                    <span style="font-size:0.875rem;">Vui lòng thay đổi điều kiện lọc</span>
                </td>
            `;
            tbody.appendChild(noResultRow);
        } else {
            const noResultRow = document.querySelector('.no-result-row');
            if (noResultRow) {
                noResultRow.remove();
            }
        }

        updatePaginationInfo(visibleCount);
        updateDashboard();
    }

