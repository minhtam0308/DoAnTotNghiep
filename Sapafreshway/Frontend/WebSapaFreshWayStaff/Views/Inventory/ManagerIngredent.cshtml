        modal.setAttribute('data-ingredient-code', ingredientCode);
        modal.setAttribute('data-ingredient-name', ingredientName);
        modal.setAttribute('data-ingredient-unit', ingredientUnit);
        modal.setAttribute('data-ingredient-unit-id', ingredientUnitId);
        modal.setAttribute('data-ingredient-unit-type', ingredientUnitType); // ← THÊM DÒNG NÀY

        // Gọi function load batch
        loadBatchList(ingredientId);
    }

    // ===== LOAD DANH SÁCH BATCH =====
    async function loadBatchList(ingredientId) {
        const modal = document.getElementById("ingredientModal");
        const tbody = document.getElementById("batchTableBody");
        const url = `/api/InventoryIngredient/BatchIngredient/${ingredientId}`;

        try {
            tbody.innerHTML = `
                <tr>
                    <td colspan="10" style="text-align:center;padding:2rem;">
                        <i class="fas fa-spinner fa-spin"></i> Đang tải dữ liệu...
                    </td>
                </tr>
            `;
            modal.style.display = "flex";

            const response = await fetch(url);
            if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

            const data = await response.json();
            console.log("Batch data received:", data);

            if (!Array.isArray(data) || data.length === 0) {
                displayNoData(tbody);
                allBatches = [];
                filteredBatches = [];
                return;
            }

            // ✅ LƯU TOÀN BỘ BATCHES VÀO BIẾN TOÀN CỤC
            allBatches = data;

            // ✅ RESET FILTERS VÀ HIỂN THỊ TRANG ĐẦU TIÊN
            resetBatchFilters();

        } catch (error) {
            console.error("Error:", error);
            displayError(tbody, error.message);
            allBatches = [];
            filteredBatches = [];
        }
    }

    function filterBatches() {
        const searchText = document.getElementById('batchCodeSearch').value.toLowerCase();
        const isActiveFilter = document.getElementById('isActiveFilter').value;
        const showEmpty = document.getElementById('showEmptyBatches').checked;

        filteredBatches = allBatches.filter(batch => {
            const matchSearch = batch.purchaseOrderId.toLowerCase().includes(searchText);

            let matchIsActive = true;
            if (isActiveFilter !== '') {
                matchIsActive = batch.isActive.toString() === isActiveFilter;
            }

            const matchQuantity = showEmpty || batch.quantityRemaining > 0;

            return matchSearch && matchIsActive && matchQuantity;
        });

        // ✅ THÊM: Sắp xếp sau khi filter
        filteredBatches = sortBatches(filteredBatches);

        currentBatchPage = 1;
        renderBatchTable();
    }

    function resetBatchFilters() {
        document.getElementById('batchCodeSearch').value = '';
        document.getElementById('isActiveFilter').value = '';
        document.getElementById('showEmptyBatches').checked = false;

        // Mặc định không hiển thị lô hết hàng
        filteredBatches = allBatches.filter(b => b.quantityRemaining > 0);

        // ✅ THÊM: Sắp xếp
        filteredBatches = sortBatches(filteredBatches);

        currentBatchPage = 1;
        renderBatchTable();
    }

    function sortBatches(batches) {
        return batches.sort((a, b) => {
            // 1. Ưu tiên lô đang sử dụng lên trước
            if (a.isActive !== b.isActive) {
                return b.isActive - a.isActive; // true (1) lên trước false (0)
            }

            // 2. Ưu tiên lô còn hàng lên trước lô hết hàng
            const aHasStock = a.quantityRemaining > 0;
            const bHasStock = b.quantityRemaining > 0;
            if (aHasStock !== bHasStock) {
                return bHasStock - aHasStock;
            }

            // 3. Trong các lô còn hàng: sắp xếp theo hạn sử dụng (FEFO)
            if (aHasStock && bHasStock) {
                const dateA = new Date(a.expiryDate);
                const dateB = new Date(b.expiryDate);

                // Lô hết hạn sớm hơn lên trước
                if (dateA.getTime() !== dateB.getTime()) {
                    return dateA - dateB;
                }

                // Nếu cùng hạn sử dụng, sắp xếp theo ngày nhập (FIFO)
                const createdA = new Date(a.createdAt);
                const createdB = new Date(b.createdAt);
                return createdA - createdB;
            }

            // 4. Các lô hết hàng: sắp xếp theo ngày nhập mới nhất lên trước
            const createdA = new Date(a.createdAt);
            const createdB = new Date(b.createdAt);
            return createdB - createdA;
        });
    }

