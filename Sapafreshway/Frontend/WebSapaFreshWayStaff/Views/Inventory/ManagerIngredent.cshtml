    function renderBatchPagination(totalPages) {
        // Xóa pagination cũ nếu có
        const existingPagination = document.querySelector('.batch-pagination');
        if (existingPagination) existingPagination.remove();

        if (totalPages <= 1) return; // Không cần pagination nếu chỉ có 1 trang

        const batchTableContainer = document.querySelector('.batch-table-container');

        const paginationHTML = `
            <div class="batch-pagination">
                <div class="batch-pagination-controls">
                    <button class="batch-pagination-btn ${currentBatchPage === 1 ? 'disabled' : ''}"
                            onclick="changeBatchPage(${currentBatchPage - 1})"
                            ${currentBatchPage === 1 ? 'disabled' : ''}>
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <span class="batch-pagination-btn active">${currentBatchPage}</span>
                    <span style="color: #6b7280; font-size: 0.875rem;">/ ${totalPages}</span>
                    <button class="batch-pagination-btn ${currentBatchPage === totalPages ? 'disabled' : ''}"
                            onclick="changeBatchPage(${currentBatchPage + 1})"
                            ${currentBatchPage === totalPages ? 'disabled' : ''}>
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
                <div class="batch-pagination-info">
                    Hiển thị ${((currentBatchPage - 1) * batchesPerPage) + 1} - ${Math.min(currentBatchPage * batchesPerPage, filteredBatches.length)}
                    trên ${filteredBatches.length} lô
                </div>
            </div>
        `;

        batchTableContainer.insertAdjacentHTML('beforeend', paginationHTML);
    }

