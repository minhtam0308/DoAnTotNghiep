    // ===== BIẾN TOÀN CỤC LƯU TRẠNG THÁI FILTER =====
    let currentStatusFilter = 'all';

    // ===== HÀM ĐẾM SỐ LƯỢNG mặt hàng THEO TRẠNG THÁI =====
    function countIngredientsByStatus() {
        const rows = document.querySelectorAll('.ingredient-row');

        let counts = {
            total: 0,
            outOfStock: 0,
            lowStock: 0,
            belowReorder: 0,
            expiringSoon: 0,
            expired: 0
        };

        rows.forEach(row => {
            // Chỉ đếm các row đang hiển thị
            if (row.style.display === 'none') return;

            counts.total++;

            // Lấy số lượng từ cột thứ 5 (index 4)
            const qtyText = row.cells[4].textContent.trim();
            const qty = parseVietnameseNumber(qtyText);

            // Lấy trạng thái số lượng từ cột thứ 6 (index 5)
            const qtyStatusCell = row.cells[5];
            const qtyStatusText = qtyStatusCell ? qtyStatusCell.textContent.toLowerCase() : '';

            // Lấy trạng thái chất lượng từ cột thứ 7 (index 6)
            const qualityStatusCell = row.cells[6];
            const qualityStatusText = qualityStatusCell ? qualityStatusCell.textContent.toLowerCase() : '';

            // 1. Đếm hết hàng
            if (qty === 0) {
                counts.outOfStock++;
            }

            // 2. Đếm sắp hết hàng
            if (qtyStatusText.includes('sắp hết hàng')) {
                counts.lowStock++;
            }

            // 3. Đếm dưới tối thiểu
            if (qtyStatusText.includes('dưới tối thiểu')) {
                counts.belowReorder++;
            }

            // 4. Đếm sắp hết hạn
            if (qualityStatusText.includes('sắp hết hạn:')) {
                counts.expiringSoon++;
            }

            // 5. Đếm hết hạn
            if (qualityStatusText.includes('hết hạn:')) {
                counts.expired++;
            }
        });

        return counts;
    }

    // ===== CẬP NHẬT DASHBOARD VÀ BUTTONS =====
    function updateDashboard() {
        const counts = countIngredientsByStatus();

        // CHỈ cập nhật Filter Buttons (bỏ phần cập nhật Dashboard Cards)
        document.getElementById('totalCount').textContent = counts.total;
        document.getElementById('outOfStockBtn').textContent = counts.outOfStock;
        document.getElementById('lowStockBtn').textContent = counts.lowStock;
        document.getElementById('belowReorderBtn').textContent = counts.belowReorder;
        document.getElementById('expiringSoonBtn').textContent = counts.expiringSoon;
        document.getElementById('expiredBtn').textContent = counts.expired;
    }

    // ===== LỌC mặt hàng THEO TRẠNG THÁI =====
    function filterByStatus(status) {
        currentStatusFilter = status;

        const rows = document.querySelectorAll('.ingredient-row');
        const noDataRow = document.querySelector('.no-data-row');
        let visibleCount = 0;

        // Xóa "no result" row cũ nếu có
        const oldNoResult = document.querySelector('.no-result-row');
        if (oldNoResult) oldNoResult.remove();

        // Cập nhật active state cho buttons
        document.querySelectorAll('.filter-shortcut-btn').forEach(btn => {
            if (btn.getAttribute('data-filter') === status) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // Nếu filter = "all", hiển thị tất cả
        if (status === 'all') {
            rows.forEach(row => {
                row.style.display = '';
                visibleCount++;
            });
            updatePaginationInfo(visibleCount);

            // ✅ SẮP XẾP LẠI SAU KHI FILTER
            sortTable();
            return;
        }

        // Lọc theo từng loại trạng thái
        rows.forEach(row => {
            let shouldShow = false;

            // Lấy số lượng từ cột 5 (cells[4])
            const qtyText = row.cells[4].textContent.trim();
            const qty = parseVietnameseNumber(qtyText);

            // Lấy trạng thái số lượng từ cột 6 (cells[5])
            const qtyStatusCell = row.cells[5];
            const qtyStatusText = qtyStatusCell ? qtyStatusCell.textContent.toLowerCase() : '';

            // Lấy trạng thái chất lượng từ cột 7 (cells[6])
            const qualityStatusCell = row.cells[6];
            const qualityStatusText = qualityStatusCell ? qualityStatusCell.textContent.toLowerCase() : '';

            switch (status) {
                case 'out-of-stock':
                    shouldShow = qty === 0;
                    break;

                case 'low-stock':
                    shouldShow = qtyStatusText.includes('sắp hết hàng');
                    break;

                case 'below-reorder':
                    shouldShow = qtyStatusText.includes('dưới tối thiểu');
                    break;

                case 'expiring-soon':
                    shouldShow = qualityStatusText.includes('sắp hết hạn:');
                    break;

                case 'expired':
                    shouldShow = qualityStatusText.includes('hết hạn:');
                    break;
            }

            if (shouldShow) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });

        // Hiển thị thông báo nếu không có kết quả
        if (visibleCount === 0 && !noDataRow) {
            const tbody = document.getElementById('ingredientTableBody');
            const statusNames = {
                'out-of-stock': 'Hết hàng',
                'low-stock': 'Sắp hết hàng',
                'below-reorder': 'Dưới tối thiểu',
                'expiring-soon': 'Sắp hết hạn',
                'expired': 'Hết hạn'
            };

            const noResultRow = document.createElement('tr');
            noResultRow.className = 'no-result-row';
            noResultRow.innerHTML = `
                <td colspan="11" style="text-align:center; padding:3rem; color:#6b7280;">
                    <i class="fas fa-filter" style="font-size:3rem; color:#d1d5db; margin-bottom:1rem;"></i>
                    <br>
                    <strong style="font-size:1.1rem; color:#374151;">Không có mặt hàng nào ở trạng thái "${statusNames[status]}"</strong>
                    <br>
                    <span style="font-size:0.875rem;">Nhấn "Tất cả" để xem toàn bộ danh sách</span>
                </td>
            `;
            tbody.appendChild(noResultRow);
        }

        updatePaginationInfo(visibleCount);

        // ✅ SẮP XẾP LẠI SAU KHI FILTER
        sortTable();
    }

    // ===== CẬP NHẬT THÔNG TIN PAGINATION =====
    function updatePaginationInfo(visibleCount) {
        const paginationInfo = document.querySelector('.pagination-info');
        if (paginationInfo && visibleCount > 0) {
            const totalItems = document.querySelectorAll('.ingredient-row').length;
            paginationInfo.innerHTML = `Hiển thị ${visibleCount} trên ${totalItems} kết quả`;
        }
    }

    let currentSortBy = 'code';
    let currentSortOrder = 'asc';

    // ===== HÀM SẮP XẾP BẢNG =====
    function sortTable() {
        const sortBy = document.getElementById('sortBySelect').value;
        const sortOrder = document.getElementById('sortOrderSelect').value;

        currentSortBy = sortBy;
        currentSortOrder = sortOrder;

        const tbody = document.getElementById('ingredientTableBody');
        const rows = Array.from(tbody.querySelectorAll('.ingredient-row'));

        // Nếu không có dòng nào, return
        if (rows.length === 0) return;

        // Xóa dòng "no-data" hoặc "no-result" nếu có
        const noDataRow = tbody.querySelector('.no-data-row');
        const noResultRow = tbody.querySelector('.no-result-row');
        if (noDataRow) noDataRow.remove();
        if (noResultRow) noResultRow.remove();

        // Sắp xếp rows
        rows.sort((rowA, rowB) => {
            let valueA, valueB;

            switch (sortBy) {
                case 'code':
                    // Cột 2: Mã mặt hàng
                    valueA = rowA.cells[1].textContent.trim();
                    valueB = rowB.cells[1].textContent.trim();
                    break;

                case 'name':
                    // Cột 3: Tên mặt hàng
                    valueA = rowA.cells[2].textContent.trim().toLowerCase();
                    valueB = rowB.cells[2].textContent.trim().toLowerCase();
                    break;

                case 'quantity':
                    // Cột 5: Số lượng tồn (SL tồn)
                    valueA = parseVietnameseNumber(rowA.cells[4].textContent.trim());
                    valueB = parseVietnameseNumber(rowB.cells[4].textContent.trim());
                    break;

                default:
                    valueA = rowA.cells[1].textContent.trim();
                    valueB = rowB.cells[1].textContent.trim();
            }

            // So sánh
            let comparison = 0;

            if (sortBy === 'quantity') {
                // So sánh số
                comparison = valueA - valueB;
            } else {
                // So sánh chuỗi
                comparison = valueA.localeCompare(valueB, 'vi');
            }

            // Đảo ngược nếu giảm dần
            return sortOrder === 'asc' ? comparison : -comparison;
        });

        // Cập nhật lại STT sau khi sắp xếp
        rows.forEach((row, index) => {
            row.cells[0].textContent = index + 1;
        });

        // Clear tbody và append lại các rows đã sắp xếp
        tbody.innerHTML = '';
        rows.forEach(row => tbody.appendChild(row));

        // Cập nhật lại bảng cảnh báo
        renderAlertPanel();
    }

    // ===== RENDER BẢNG CẢNH BÁO =====
    function renderAlertPanel() {
        const rows = document.querySelectorAll('.ingredient-row');
        const alertBody = document.getElementById('alertPanelBody');
        const alertCount = document.getElementById('alertCount');

        let alertItems = [];

        rows.forEach((row, index) => {
            if (row.style.display === 'none') return;

            const code = row.cells[1].textContent.trim();
            const name = row.cells[2].textContent.trim();
            const unit = row.cells[3].textContent.trim();
            const qtyText = row.cells[4].textContent.trim();
            const qty = parseVietnameseNumber(qtyText);

            const qtyStatusCell = row.cells[5];
            const statusText = qtyStatusCell ? qtyStatusCell.textContent.toLowerCase() : '';

            // ✅ ĐỌC CHÍNH XÁC TỪ DATA ATTRIBUTES
            const qtyExcludingExpired = parseFloat(row.dataset.qtyExcludingExpired);
            const reorderLevel = parseFloat(row.dataset.reorderLevel);
            const needUrgentRestock = row.dataset.needUrgentRestock === 'true';

            console.log(`Row ${index + 1} (${code}):`, {
                qty,
                qtyExcludingExpired,
                reorderLevel,
                needUrgentRestock,
                statusText
            });

            let alertType = null;
            let statusLabel = '';
            let priority = 0;
            let extraInfo = null;

            // ✅ LOGIC PHÂN LOẠI (ƯU TIÊN THEO THỨ TỰ)
            if (qty === 0) {
                // Ưu tiên 0: Hết hàng hoàn toàn
                alertType = 'out-of-stock';
                statusLabel = 'Hết hàng';
                priority = 0;
            }
            else if (statusText.includes('sắp hết hàng')) {
                // Ưu tiên 1: Sắp hết hàng
                alertType = 'low-stock';
                statusLabel = 'Sắp hết hàng';
                priority = 1;
            }
            else if (needUrgentRestock) {
                // ✅ Ưu tiên 2: CẦN NHẬP GẤP (có lô hết hạn làm giảm số lượng)
                alertType = 'urgent-restock';
                statusLabel = 'Cần nhập gấp';
                priority = 2;

                // ✅ Đảm bảo hiển thị đúng số liệu
                if (!isNaN(qtyExcludingExpired) && !isNaN(reorderLevel)) {
                    extraInfo = {
                        qtyExcludingExpired: formatNumber(qtyExcludingExpired),
                        reorderLevel: formatNumber(reorderLevel)
                    };
                    console.log(` Found urgent restock: ${code}`, extraInfo);
                }
            }
            else if (statusText.includes('dưới tối thiểu')) {
                // Ưu tiên 3: Dưới tối thiểu
                alertType = 'below-reorder';
                statusLabel = 'Dưới tối thiểu';
                priority = 3;
            }

            if (alertType) {
                alertItems.push({
                    code,
                    name,
                    unit,
                    qty: formatNumber(qty),
                    status: statusLabel,
                    alertType,
                    priority,
                    rowIndex: index,
                    extraInfo // ✅ Thêm thông tin chi tiết
                });
            }
        });

        // Sắp xếp theo priority
        alertItems.sort((a, b) => a.priority - b.priority);

        // Cập nhật số lượng
        alertCount.textContent = alertItems.length;

        // Render
        if (alertItems.length === 0) {
            alertBody.innerHTML = `
                <div class="alert-empty">
                    <i class="fas fa-check-circle"></i>
                    <p><strong>Tuyệt vời!</strong></p>
                    <p>Không có mặt hàng nào cần chú ý</p>
                </div>
            `;
            return;
        }

        alertBody.innerHTML = alertItems.map((item, index) => `
            <div class="alert-item ${item.alertType}" onclick="scrollToIngredient(${item.rowIndex})">
                <div class="alert-item-header">
                    <span class="alert-item-code">#${index + 1} - ${item.code}</span>
                    <span class="status-badge status-${item.alertType}" style="font-size: 0.7rem; padding: 0.25rem 0.5rem;">
                        ${item.status}
                    </span>
                </div>
                <div class="alert-item-name">${item.name}</div>
                <div class="alert-item-footer">
                    <div style="display: flex; flex-direction: column; gap: 0.25rem; flex: 1;">
                        <span class="alert-quantity">
                            <i class="fas fa-box"></i> <strong>${item.qty}</strong> ${item.unit}
                        </span>
                        ${item.extraInfo ? `
                            <span style="font-size: 0.75rem; color: #dc2626; font-weight: 600; line-height: 1.4;">
                                <i class="fas fa-exclamation-triangle"></i>
                                Còn ${item.extraInfo.qtyExcludingExpired} ${item.unit} (sau trừ hết hạn)
                            </span>
                            <span style="font-size: 0.75rem; color: #6b7280; line-height: 1.4;">
                                <i class="fas fa-chart-line"></i>
                                Tối thiểu: ${item.extraInfo.reorderLevel} ${item.unit}
                            </span>
                        ` : ''}
                    </div>
                    <span style="color: #6b7280; flex-shrink: 0;">
                        <i class="fas fa-arrow-right"></i>
                    </span>
                </div>
            </div>
        `).join('');
    }

    // ===== SCROLL ĐẾN mặt hàng =====
    function scrollToIngredient(rowIndex) {
        const rows = document.querySelectorAll('.ingredient-row');
        const targetRow = rows[rowIndex];

        if (targetRow && targetRow.style.display !== 'none') {
            // Xóa highlight cũ
            rows.forEach(r => r.style.backgroundColor = '');

            // Highlight row
            targetRow.style.backgroundColor = '#fef3c7';
            targetRow.scrollIntoView({ behavior: 'smooth', block: 'center' });

            // Xóa highlight sau 2s
            setTimeout(() => {
                targetRow.style.backgroundColor = '';
            }, 2000);
        }
    }

    // ===== XUẤT BÁO CÁO PDF MẶT HÀNG =====
    document.getElementById('exportIngredientReportBtn')?.addEventListener('click', async function () {
        const period = document.getElementById('ingredientReportPeriod').value;
        const btn = this;

        try {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang tạo báo cáo...';

            const response = await fetch('/api/Ingredient/ExportReport', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ period: period })
            });

            if (!response.ok) {
                const errorText = await response.text();
                throw new Error(errorText || 'Không thể tạo báo cáo');
            }

            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;

            // Tạo tên file với timestamp
            const timestamp = new Date().getTime();
            const periodText = period === 'today' ? 'HomNay' :
                period === '7days' ? '7Ngay' : '30Ngay';
            a.download = `BaoCaoMatHang_${periodText}_${timestamp}.pdf`;

            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);

            // Hiển thị thông báo thành công
            btn.innerHTML = 'Tải thành công!';
            showToast('Tải báo cáo thành công!', 'success');

            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-file-pdf"></i> Xuất báo cáo PDF';
                btn.disabled = false;
            }, 2000);

        } catch (error) {
            console.error('Lỗi xuất báo cáo:', error);
            showToast('Không thể tạo báo cáo: ' + error.message, 'error');

            btn.innerHTML = '<i class="fas fa-file-pdf"></i> Xuất báo cáo PDF';
            btn.disabled = false;
        }
    });

</script>