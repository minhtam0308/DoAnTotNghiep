@using WebSapaFreshWayStaff.DTOs;
@using WebSapaFreshWayStaff.DTOs.Inventory;
@using System.Security.Claims

@{
    Layout = "_LayoutInventory";
    ViewData["Title"] = "Quản lý mặt hàng";

    // ✅ LẤY THÔNG TIN TỪ CLAIMS
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
    var userName = User.FindFirst(ClaimTypes.Name)?.Value ?? "Không xác định";
    var userEmail = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var userPhone = User.FindFirst(ClaimTypes.MobilePhone)?.Value ?? ""; // ✅ THÊM DÒNG NÀY

    // ✅ LẤY POSITIONS (nếu có)
    var positionsJson = User.FindFirst("Positions")?.Value;
    var userPosition = "Nhân viên kho";
    if (!string.IsNullOrEmpty(positionsJson))
    {
        try
        {
            var positions = System.Text.Json.JsonSerializer.Deserialize<List<string>>(positionsJson);
            userPosition = positions != null && positions.Any() ? string.Join(", ", positions) : "Nhân viên";
        }
        catch
        {
            userPosition = "Nhân viên kho";
        }
    }
}
@model WebSapaFreshWayStaff.DTOs.InventoryPagedViewModel

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background-color: #f9fafb;
        color: #111827;
    }

    .container {
        min-height: 100vh;
        padding: 0.2rem;
    }

    .max-width {
        max-width: 100rem;
        margin: 0 auto;
    }

    .card {
        background: white;
        border-radius: 0.5rem;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
        padding: 0.5rem;
        margin-bottom: 0.5rem;
