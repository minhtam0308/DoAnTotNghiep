    // Thay thế function openAuditModal cũ bằng code mới này:

    async function openAuditModal(batchId) {
        try {
            // ✅ KIỂM TRA ĐƠN KIỂM KÊ ĐANG XỬ LÝ
            const checkResponse = await fetch(`/ManagerIngredent/CheckAuditStatus?batchId=${batchId}`);
            if (!checkResponse.ok) {
                throw new Error('Không thể kiểm tra trạng thái đơn kiểm kê');
            }
            const checkResult = await checkResponse.json();
            if (checkResult.hasUnprocessedAudit && checkResult.auditId) {
                showAuditWarningPopup(checkResult.auditId);
                return;
            }

            const modal = document.getElementById('auditModal');
            const ingredientModal = document.getElementById('ingredientModal');
            const row = document.querySelector(`tr[data-batch-id="${batchId}"]`);

            if (!row) {
                showToast('Không tìm thấy thông tin lô hàng', 'error');
                return;
            }

            // Lấy dữ liệu từ row
            const batchCode = row.cells[0].textContent;
            const supplierName = row.cells[1].textContent;
            const createdDate = row.cells[2].textContent;
            const expiryDate = row.cells[3].textContent;
            const quantity = parseVietnameseNumber(row.cells[4].textContent);
            const statusBadge = row.cells[5].innerHTML;

            // ✅ LẤY THÔNG TIN KHO TỪ SELECT
            const warehouseSelect = row.querySelector('.warehouse-select');
            const warehouseName = warehouseSelect.options[warehouseSelect.selectedIndex].text;
            const warehouseId = warehouseSelect.value;

            // Lấy thông tin từ modal ingredient
            const ingredientCode = ingredientModal.getAttribute('data-ingredient-code');
            const ingredientName = ingredientModal.getAttribute('data-ingredient-name');
            const ingredientUnit = ingredientModal.getAttribute('data-ingredient-unit');
            const ingredientUnitType = parseInt(ingredientModal.getAttribute('data-ingredient-unit-type'));

            const currentDateTime = new Date();
            const formattedDateTime = formatDateTime(currentDateTime);

            // ✅ PARSE NGÀY TẠO TỪ STRING "DD/MM/YYYY" SANG DATE OBJECT
            const createdDateParts = createdDate.split('/');
            const createdDateObj = new Date(
                parseInt(createdDateParts[2]), // year
                parseInt(createdDateParts[1]) - 1, // month (0-indexed)
                parseInt(createdDateParts[0]) // day
            );

            // Lưu thông tin batch hiện tại
            currentAuditBatch = {
                batchId: batchId,
                batchCode: batchCode,
                ingredientCode: ingredientCode,
                ingredientName: ingredientName,
                unit: ingredientUnit,
                unitType: ingredientUnitType,
                quantity: quantity,
                expiryDate: expiryDate,
                createdDate: createdDate,
                createdDateObj: createdDateObj, 
                warehouseName: warehouseName, 
                warehouseId: warehouseId, 
                status: statusBadge,
                auditDateTime: currentDateTime
            };

            // Điền thông tin vào form audit modal
            document.getElementById('auditBatchCode').textContent = batchCode;
            document.getElementById('auditIngredientCode').textContent = ingredientCode;
            document.getElementById('auditIngredientName').textContent = ingredientName;
            document.getElementById('auditUnit').textContent = ingredientUnit;
            document.getElementById('auditExpiryDate').textContent = expiryDate;
            document.getElementById('auditDateTime').textContent = formattedDateTime;
            document.getElementById('auditCurrentQty').textContent = formatNumber(quantity);
            document.getElementById('auditStatus').innerHTML = statusBadge;

            // ✅ HIỂN THỊ THÔNG TIN KHO
            document.getElementById('auditWarehouse').textContent = warehouseName;

            // ✅ SET MIN DATE CHO INPUT NGÀY HẾT HẠN
            const minDateStr = createdDateObj.toISOString().split('T')[0]; // "YYYY-MM-DD"
            document.getElementById('auditNewExpiryDate').setAttribute('min', minDateStr);
            document.getElementById('auditNewExpiryDate').value = ''; // Reset value

            // Cập nhật preview ban đầu
            document.getElementById('auditPreviewQty').textContent = formatNumber(quantity);
