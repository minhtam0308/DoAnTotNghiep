    // ✅ Function kiểm tra trạng thái của batch
    // ✅ Function kiểm tra trạng thái của batch
    function getBatchStatus(batch) {
        const today = new Date();
        today.setHours(0, 0, 0, 0);

        if (!batch.expiryDate || !batch.createdAt) {
            return {
                isExpired: false,
                isExpiringSoon: false,
                badge: '<span class="batch-status-badge batch-status-normal"><i class="fas fa-check-circle"></i> Bình thường</span>'
            };
        }

        // Parse dates
        const createdDate = new Date(batch.createdAt);
        createdDate.setHours(0, 0, 0, 0);

        const expiryDate = new Date(batch.expiryDate);
        expiryDate.setHours(0, 0, 0, 0);

        // Kiểm tra hết hạn
        if (today >= expiryDate) {
            return {
                isExpired: true,
                isExpiringSoon: false,
                badge: '<span class="batch-status-badge batch-status-expired"><i class="fas fa-times-circle"></i> Hết hạn</span>'
            };
        }

        // Kiểm tra sắp hết hạn (2/3 thời gian)
        const totalDays = (expiryDate - createdDate) / (1000 * 60 * 60 * 24);
        const twoThirdsPoint = new Date(createdDate.getTime() + (totalDays * 2 / 3 * 24 * 60 * 60 * 1000));

        if (today >= twoThirdsPoint) {
            const daysLeft = Math.ceil((expiryDate - today) / (1000 * 60 * 60 * 24));
            return {
                isExpired: false,
                isExpiringSoon: true,
                badge: `<span class="batch-status-badge batch-status-expiring"><i class="fas fa-exclamation-triangle"></i> Còn ${daysLeft} ngày</span>`
            };
        }

        return {
            isExpired: false,
            isExpiringSoon: false,
            badge: '<span class="batch-status-badge batch-status-normal"><i class="fas fa-check-circle"></i> Bình thường</span>'
        };
    }

