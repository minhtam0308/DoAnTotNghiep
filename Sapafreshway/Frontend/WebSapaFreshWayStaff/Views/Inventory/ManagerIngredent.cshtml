    function updateAuditPreview() {
        if (!currentAuditBatch) return;

        const auditType = document.querySelector('input[name="auditType"]:checked').value;
        const quantity = parseFloat(document.getElementById('auditQuantity').value) || 0;

        let newQuantity = currentAuditBatch.quantity;

        // Tính toán số lượng mới
        if (auditType === 'add') {
            newQuantity = currentAuditBatch.quantity + quantity;
        } else if (auditType === 'remove') {
            newQuantity = Math.max(0, currentAuditBatch.quantity - quantity);
        } else if (auditType === 'removeAll') {
            newQuantity = 0;
        } else if (auditType === 'noChange') {
            // ✅ KHÔNG THAY ĐỔI - GIỮ NGUYÊN
            newQuantity = currentAuditBatch.quantity;
        }

        const diff = newQuantity - currentAuditBatch.quantity;
        const qtyCell = document.getElementById('auditPreviewQty');
        const diffIndicator = document.getElementById('auditDiffIndicator');

        qtyCell.textContent = formatNumber(newQuantity);

        if (diff > 0) {
            qtyCell.style.color = '#10b981';
            diffIndicator.innerHTML = `<span style="color: #10b981;">
                <i class="fas fa-arrow-up"></i> +${formatNumber(Math.abs(diff))}
            </span>`;
        } else if (diff < 0) {
            qtyCell.style.color = '#ef4444';
            diffIndicator.innerHTML = `<span style="color: #ef4444;">
                <i class="fas fa-arrow-down"></i> -${formatNumber(Math.abs(diff))}
            </span>`;
        } else {
            qtyCell.style.color = '#1f2937';
            diffIndicator.innerHTML = `<span style="color: #6b7280;">
                <i class="fas fa-minus"></i> Không thay đổi
            </span>`;
        }
    }

