    function handleImageUpload(event) {
        const file = event.target.files[0];
        if (!file) return;

        // Validate file size (5MB)
        if (file.size > 5 * 1024 * 1024) {
            showToast('Kích thước file không được vượt quá 5MB', 'warning');
            event.target.value = '';
            return;
        }

        // Validate file type
        if (!file.type.startsWith('image/')) {
            showToast('Vui lòng chọn file hình ảnh (PNG, JPG, JPEG)', 'warning');
            event.target.value = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = function (e) {
            const container = document.getElementById('imagePreviewContainer');
            container.innerHTML = `
                <img src="${e.target.result}" class="audit-image-preview" alt="Preview">
                <p style="font-size: 0.875rem; color: #065f46; font-weight: 600;">
                    Nhấn để thay đổi hình ảnh
                </p>
            `;
        };
        reader.readAsDataURL(file);
    }

    async function submitAudit() {
        if (!currentAuditBatch) {
            showToast('Không có thông tin lô hàng để kiểm kê', 'error');
            return;
        }

        // ✅ 1. VALIDATE INPUT
        const auditType = document.querySelector('input[name="auditType"]:checked').value;
        const quantity = parseFloat(document.getElementById('auditQuantity').value) || 0;
        const reason = document.getElementById('auditReason').value.trim();
        const newExpiryDate = document.getElementById('auditNewExpiryDate').value; // ✅ LẤY NGÀY MỚI


        if (auditType === 'remove' && quantity > currentAuditBatch.quantity) {
            showToast(`Số lượng hủy (${formatNumber(quantity)}) không được lớn hơn số lượng hiện tại (${formatNumber(currentAuditBatch.quantity)})!`, 'error');
            document.getElementById('auditQuantity').focus();
            return;
        }

        if (auditType !== 'removeAll' && auditType !== 'noChange') {
            if (quantity < 0) {
                showToast('Số lượng không được nhỏ hơn 0!', 'warning');
                document.getElementById('auditQuantity').focus();
                return;
            }

            if (quantity <= 0) {
                showToast('Vui lòng nhập số lượng hợp lệ', 'warning');
                document.getElementById('auditQuantity').focus();
                return;
            }
        }

        // Validate số lượng (trừ trường hợp removeAll)
        if (auditType !== 'removeAll' && auditType !== 'noChange' && quantity <= 0) {
            showToast('Vui lòng nhập số lượng hợp lệ', 'warning');
            document.getElementById('auditQuantity').focus();
            return;
        }

        // Validate lý do
        if (!reason) {
            showToast('Vui lòng nhập lý do kiểm kê', 'warning');
            document.getElementById('auditReason').focus();
            return;
        }

        // ✅ VALIDATE NGÀY HẾT HẠN MỚI (nếu có nhập)
        if (newExpiryDate) {
            const selectedDate = new Date(newExpiryDate);
            const minDate = currentAuditBatch.createdDateObj;

            if (selectedDate < minDate) {
                showToast('Ngày hết hạn mới không được nhỏ hơn ngày tạo lô!', 'warning');
                document.getElementById('auditNewExpiryDate').focus();
                return;
            }
        }

        // Validate thông tin người kiểm kê
        const useMyInfo = document.getElementById('useMyInfo').checked;
        if (!useMyInfo) {
            showToast('Vui lòng xác nhận thông tin người kiểm kê', 'warning');
            return;
        }

        // Validate ảnh minh chứng
        const imageFile = document.getElementById('auditImageUpload').files[0];
        if (!imageFile) {
            showToast('Vui lòng tải lên hình ảnh minh chứng', 'warning');
            return;
        }

        const formData = new FormData();

        // BatchId
        formData.append('BatchId', currentAuditBatch.batchId);

        // Mã lô (PurchaseOrderId)
        formData.append('PurchaseOrderId', currentAuditBatch.batchCode);

        // Mã mặt hàng
        formData.append('IngredientCode', currentAuditBatch.ingredientCode);
        formData.append('IngredientName', currentAuditBatch.ingredientName);
        formData.append('Unit', currentAuditBatch.unit);

        // Số lượng gốc
        formData.append('OriginalQuantity', currentAuditBatch.quantity);

        // ✅ HẠN SỬ DỤNG
        if (newExpiryDate) {
            formData.append('ExpiryDate', newExpiryDate);
        } else if (currentAuditBatch.expiryDate && currentAuditBatch.expiryDate !== 'N/A') {
            const parts = currentAuditBatch.expiryDate.split('/');
            if (parts.length === 3) {
                const formattedDate = `${parts[2]}-${parts[1]}-${parts[0]}`;
                formData.append('ExpiryDate', formattedDate);
            }
        }

        // ✅ THÔNG TIN NGƯỜI TẠO (từ Claims)
        formData.append('CreatorId', currentUserData.userId);
        formData.append('CreatorName', currentUserData.name);
        formData.append('CreatorEmail', currentUserData.email); // ✅ THÊM
        formData.append('CreatorPosition', currentUserData.position);
        formData.append('CreatorRole', currentUserData.role); // ✅ THÊM
        formData.append('CreatorPhone', document.getElementById('confirmerPhone').value || 'N/A');

        // Thời gian tạo đơn
        formData.append('CreatedAt',
            new Date().toLocaleString('sv-SE', {
                timeZone: 'Asia/Ho_Chi_Minh'
            }).replace(' ', 'T')
        );

        // Lý do kiểm kê
        formData.append('Reason', reason);

        // Số lượng điều chỉnh
        let adjustmentQty = quantity;
        let isAddition = false;

        if (auditType === 'add') {
            adjustmentQty = quantity;
            isAddition = true;
        } else if (auditType === 'remove') {
            adjustmentQty = quantity;
            isAddition = false;
        } else if (auditType === 'removeAll') {
            adjustmentQty = currentAuditBatch.quantity;
            isAddition = false;
        } else if (auditType === 'noChange') {
            adjustmentQty = 0;
            isAddition = false;
        }

        formData.append('AdjustmentQuantity', adjustmentQty.toString());
        formData.append('IsAddition', isAddition.toString());

        // ✅ XÁC ĐỊNH IngredientStatus
        const statusBadgeHTML = currentAuditBatch.status;
        let ingredientStatus = 'normal';

        if (statusBadgeHTML.includes('Hết hạn') || statusBadgeHTML.includes('expired')) {
            ingredientStatus = 'expired';
        } else if (statusBadgeHTML.includes('Sắp hết hạn') || statusBadgeHTML.includes('expiring')) {
            ingredientStatus = 'expiring';
        } else {
            ingredientStatus = 'normal';
        }

        formData.append('IngredientStatus', ingredientStatus);

        // ✅ FILE ẢNH MINH CHỨNG
        formData.append('ImageFile', imageFile);

        // ✅ LOG DỮ LIỆU
        console.log('=== AUDIT SUBMISSION DATA ===');
        console.log('UserId:', currentUserData.userId);
        console.log('UserName:', currentUserData.name);
        console.log('UserEmail:', currentUserData.email);
        console.log('UserPosition:', currentUserData.position);
        console.log('BatchId:', currentAuditBatch.batchId);
        console.log('AdjustmentQuantity:', adjustmentQty);
        console.log('IsAddition:', isAddition);

        // ✅ 8. GỬI REQUEST
        try {
            const submitBtn = document.getElementById('submitAuditBtn');
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';

            const response = await fetch('/api/Audit/SubmitAudit', {
                method: 'POST',
                body: formData
            });

            if (!response.ok) {
                const errorText = await response.text();
                throw new Error(`Server error: ${response.status} - ${errorText}`);
            }

            const result = await response.json();

            if (result.success) {
                showSuccessMessage(result.message || 'Tạo đơn kiểm kê thành công!');
                closeAuditModal();
                setTimeout(() => {
                    window.location.reload();
                }, 1500);
            } else {
                throw new Error(result.message || 'Có lỗi xảy ra');
            }

        } catch (error) {
            console.error('Error submitting audit:', error);
            showToast('Có lỗi xảy ra khi tạo đơn kiểm kê: ' + error.message, 'error');

            const submitBtn = document.getElementById('submitAuditBtn');
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="fas fa-check-circle"></i> Xác nhận kiểm kê';
        }
    }

