<div class="container">
    <div class="max-width">
        <!-- Notification messages -->
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error" id="alertMessage">
                <i class="fas fa-exclamation-circle"></i>
                <span>@TempData["ErrorMessage"]</span>
                <button class="alert-close" onclick="closeAlert()">&times;</button>
            </div>
        }

        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert alert-info" id="alertMessage">
                <i class="fas fa-info-circle"></i>
                <span>@TempData["InfoMessage"]</span>
                <button class="alert-close" onclick="closeAlert()">&times;</button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" id="alertMessage">
                <i class="fas fa-check-circle"></i>
                <span>@TempData["SuccessMessage"]</span>
                <button class="alert-close" onclick="closeAlert()">&times;</button>
            </div>
        }
        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h1 class="header-title">Quản lý mặt hàng</h1>
                    <p class="header-subtitle">Quản lý thông tin mặt hàng</p>
                </div>

                <div style="display: flex; gap: 0.75rem; align-items: center;">
                    <select class="form-select" id="ingredientReportPeriod" style="width: 150px;">
                        <option value="today">Hôm nay</option>
                    </select>
                    <button id="exportIngredientReportBtn" class="btn btn-success" style="white-space: nowrap;">
                         Xuất báo cáo
                    </button>
                </div>
            </div>
        </div>
        
        <!-- ===== FILTER SHORTCUTS ===== -->
        <div id="filterShortcuts" style="display: flex; gap: 0.75rem; flex-wrap: wrap; padding: 1.25rem; background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%); border-radius: 0.75rem; border: 1px solid #e5e7eb;">
            <button class="filter-shortcut-btn active" data-filter="all" onclick="filterByStatus('all')">
                <i class="fas fa-th-large"></i>
                <span>Tất cả</span>
                <span class="count-badge" id="totalCount">0</span>
            </button>

            <button class="filter-shortcut-btn" data-filter="out-of-stock" onclick="filterByStatus('out-of-stock')">
                <i class="fas fa-box-open"></i>
                <span>Hết hàng</span>
                <span class="count-badge" id="outOfStockBtn">0</span>
            </button>

            <button class="filter-shortcut-btn" data-filter="low-stock" onclick="filterByStatus('low-stock')">
                <i class="fas fa-exclamation-triangle"></i>
                <span>Sắp hết</span>
                <span class="count-badge" id="lowStockBtn">0</span>
            </button>

            <button class="filter-shortcut-btn" data-filter="below-reorder" onclick="filterByStatus('below-reorder')">
                <i class="fas fa-box"></i>
                <span>Dưới tối thiểu</span>
                <span class="count-badge" id="belowReorderBtn">0</span>
            </button>

            <button class="filter-shortcut-btn" data-filter="expiring-soon" onclick="filterByStatus('expiring-soon')">
                <i class="fas fa-clock"></i>
                <span>Sắp hết hạn</span>
                <span class="count-badge" id="expiringSoonBtn">0</span>
            </button>

            <button class="filter-shortcut-btn" data-filter="expired" onclick="filterByStatus('expired')">
                <i class="fas fa-times-circle"></i>
                <span>Hết hạn</span>
                <span class="count-badge" id="expiredBtn">0</span>
            </button>
        </div>

        <form method="post" asp-controller="ManagerIngredent" asp-action="FilterIngredent" class="card" id="filterForm">


            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 0; align-items: end;">

                <!-- Box 1: Tìm kiếm -->
                <div style="background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); padding: 1.5rem; border-radius: 0.5rem; border-left: 4px solid #3b82f6;">
                    <h3 style="font-size: 1rem; font-weight: 600; color: #1e40af; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                        <i class="fas fa-search"></i>
                        Tìm kiếm
                    </h3>
                    <div style="display: flex; gap: 0.75rem; align-items: flex-end;">
                        <div class="form-group" style="margin-bottom: 0; flex: 1;">
                            <label class="form-label">
                                <i class="fas fa-box"></i> Tìm kiếm mặt hàng
                            </label>
                            <input type="text"
                                   placeholder="Nhập tên mặt hàng hoặc mã mặt hàng"
                                   name="searchIngredent"
                                   class="form-input"
                                   value="@Model.SearchIngredent" />
                        </div>
                        <button type="submit" class="btn btn-primary" style="height: 42px; flex-shrink: 0;">
                            <i class="fas fa-search"></i> Tìm kiếm
                        </button>
                    </div>
                </div>

                <!-- Box 2: Sắp xếp -->
                <div style="background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); padding: 1.5rem; border-radius: 0.5rem; border-left: 4px solid #10b981;">
                    <h3 style="font-size: 1rem; font-weight: 600; color: #065f46; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                        <i class="fas fa-sort"></i>
                        Sắp xếp danh sách
                    </h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <!-- Sắp xếp theo -->
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">
                                <i class="fas fa-sort-amount-down"></i> Sắp xếp theo
                            </label>
                            <select id="sortBySelect" class="form-select" onchange="sortTable()">
                                <option value="code">Mã mặt hàng</option>
                                <option value="name">Tên mặt hàng</option>
                                <option value="quantity">Số lượng tồn</option>
                            </select>
                        </div>
                        <!-- Thứ tự -->
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">
                                <i class="fas fa-arrows-alt-v"></i> Thứ tự
                            </label>
                            <select id="sortOrderSelect" class="form-select" onchange="sortTable()">
                                <option value="asc">Tăng dần</option>
                                <option value="desc">Giảm dần</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </form>
        <div class="main-content-wrapper">
         <div>
          <div class="table-container">
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Mã mặt hàng</th>
                            <th>Tên mặt hàng</th>
                            <th>Đơn vị tính</th>
                            <th class="text-right">SL tồn</th>
@*                             <th class="text-right">Tồn đầu kỳ</th>
                            <th class="text-right">SL nhập</th>
                            <th class="text-right">SL xuất</th> *@
                            <th class="text-center">Trạng thái số lượng</th>
                            <th class="text-center">Trạng thái chất lượng</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="ingredientTableBody">
                        @if (Model.Ingredients == null || !Model.Ingredients.Any())
                        {
                            <tr class="no-data-row">
                                <td colspan="10" style="text-align:center; padding:3rem; color:#6b7280;">
                                    <i class="fas fa-inbox" style="font-size:3rem; color:#d1d5db; margin-bottom:1rem;"></i>
                                    <br>
                                    <strong style="font-size:1.1rem; color:#374151;">Không tìm thấy mặt hàng nào</strong>
                                    <br>
                                    <span style="font-size:0.875rem;">Vui lòng thử lại với điều kiện tìm kiếm khác</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            int stt = (Model.CurrentPage - 1) * Model.ItemsPerPage + 1;

                            @foreach (var item in Model.Ingredients)
                            {
                                var rowClass = "";
                                var dataStatus = "normal";

                                if (item.IsExpired)
                                {
                                    rowClass = "expired";
                                    dataStatus = "expired";
                                }
                                else if (item.IsLowStock)
                                {
                                    rowClass = "low-stock";
                                    dataStatus = "low-stock";
                                }
                                else if (item.IsBelowReorderLevel)
                                {
                                    rowClass = "below-reorder";
                                    dataStatus = "below-reorder";
                                }
                                else if (item.HasExpiringSoon)
                                {
                                    rowClass = "expiring-soon";
                                    dataStatus = "expiring-soon";
                                }

                                        <tr class="@rowClass ingredient-row"
                                            data-status="@dataStatus"
                                            data-qty-excluding-expired="@item.QuantityExcludingExpired"
                                            data-reorder-level="@(item.ReorderLevel ?? 0)"
                                            data-need-urgent-restock="@item.NeedUrgentRestock.ToString().ToLower()">
                                    <td>@stt</td>
                                    <td>@item.IngredientCode</td>
                                    <td>@item.Name</td>
                                    <td>@(item.Unit?.UnitName ?? "---")</td>
                                    <td class="text-right">@item.TotalQuantity</td>
@*                                     <td class="text-right">@item.OriginalQuantity</td>
                                    <td class="text-right">@item.TotalImport</td>
                                    <td class="text-right">@item.TotalExport</td> *@
                                    <td class="text-center">
                                        @* Trạng thái số lượng *@

                                        @if (item.TotalQuantity == 0)
                                                {
                                            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white rounded-md text-sm font-bold border-2 border-gray-700 shadow-sm pulse-dark">
                                                <i class="fas fa-box-open"></i>
                                                <span>Hết hàng</span>
                                            </div>
                                                }
                                        else if (item.IsLowStock)
                                        {
                                            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-100 text-red-700 rounded-md text-sm font-bold border-2 border-red-400 shadow-sm pulse-red-alert">
                                                <i class="fas fa-exclamation-triangle"></i>
                                                <span>Sắp hết hàng</span>
                                            </div>
                                        }
                                        else if (item.IsBelowReorderLevel)
                                        {
                                            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-orange-100 text-orange-700 rounded-md text-sm font-bold border-2 border-orange-400 shadow-sm">
                                                <i class="fas fa-box"></i>
                                                <span>Dưới tối thiểu</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-100 text-green-700 rounded-md text-sm font-semibold border border-green-300">
                                                <i class="fas fa-check-circle"></i>
                                                Bình thường
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
    @* Trạng thái chất lượng *@
    <div style="display: flex; flex-direction: column; gap: 0.375rem; align-items: center;">
        @if (item.ExpiredBatchCount > 0)
        {
            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-100 text-red-700 rounded-md text-sm font-bold border-2 border-red-400 shadow-sm pulse-red-alert">
                <i class="fas fa-times-circle"></i>
                <span>Hết hạn: @item.ExpiredBatchCount</span>
            </div>
        }
        @if (item.ExpiringSoonBatchCount > 0)
        {
            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-yellow-100 text-yellow-700 rounded-md text-sm font-bold border-2 border-yellow-400 shadow-sm">
                <i class="fas fa-clock"></i>
                <span>Sắp hết hạn: @item.ExpiringSoonBatchCount</span>
            </div>
        }
        @if (item.ExpiredBatchCount == 0 && item.ExpiringSoonBatchCount == 0)
        {
            <span class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-100 text-green-700 rounded-md text-sm font-semibold border border-green-300">
                <i class="fas fa-check-circle"></i>
                Bình thường
            </span>
        }
    </div>
</td>
                                    <td class="text-center">
                                        <div class="action-buttons">
                                            <a href="#"
                                               data-ingredient-id="@item.IngredientId"
                                               data-ingredient-code="@item.IngredientCode"
                                               data-ingredient-name="@item.Name"
                                               data-ingredient-unit="@(item.Unit?.UnitName ?? "---")"
                                               data-ingredient-unit-id="@(item.Unit?.UnitId ?? 0)"
                                               data-ingredient-unit-type="@((int)(item.Unit?.UnitType ?? UnitType.Integer))"
                                               data-reorder-level="@(item.ReorderLevel?.ToString() ?? "")"
                                               class="action-btn view"
                                               title="Xem chi tiết"
                                               onclick="showIngredientDetailFromRow(this); return false;">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                stt++;
                            }
                        }
                    </tbody>
                </table>
              </div>
            </div>
          </div>
            <!-- CỘT PHẢI: Bảng cảnh báo -->
            <div class="alert-panel">
                <div class="alert-panel-header">
                    <div class="alert-panel-header-content">
                        <h3>
                            <i class="fas fa-exclamation-triangle"></i>
                            mặt hàng cần nhập ngay
                        </h3>
                        <p>
                            <span id="alertCount">0</span> mặt hàng cần chú ý
                        </p>
                    </div>
                    <!-- ✅ THÊM BUTTON VÀO ĐÂY -->
                    <a href="/ImportInventory" class="btn btn-success" style="padding: 0.75rem 1.25rem; font-size: 0.875rem; white-space: nowrap;">
                        <i class="fas fa-plus"></i> Thêm mặt hàng
                    </a>
                </div>

                <div class="alert-panel-body" id="alertPanelBody">
                    <!-- Render bằng JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Modal chi tiết mặt hàng -->
    <div id="ingredientModal" class="modal-overlay" style="display:none;">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fas fa-info-circle"></i> Chi tiết mặt hàng</h2>
                <button id="closeModal" class="close-btn">&times;</button>
            </div>

            <div class="modal-body">
                <div class="info-header">
                    <div class="info-header-content">
                        <p><strong>Tên mặt hàng:</strong> <span id="mName">---</span></p>
                        <p><strong>Đơn vị tính:</strong> <span id="mUnit">---</span></p>
                        <p style="position: relative;">
                            <strong>Mức tối thiểu:</strong>
                            <span id="mReorderLevel">---</span>
                            <span class="info-tooltip">
                                <i class="fas fa-info-circle"></i>
                                <span class="tooltip-text">
                                    Đây là số lượng trung bình mặt hàng này xuất ra trong 30 ngày gần nhất.
                                </span>
                            </span>
                        </p>
                    </div>
                    <div class="info-header-actions">
                        <button class="btn-edit-info" onclick="openEditModalFromDetail()">
                            <i class="fas fa-edit"></i> Chỉnh sửa
                        </button>
                        <button class="btn-edit-info" style="background-color: #10b981; margin-left: 0.5rem;" onclick="toggleAuditButtons()">
                            <i class="fas fa-clipboard-check"></i> Kiểm kê thực tế
                        </button>
                    </div>
                </div>
                <!-- Thêm vào sau div.info-header trong modal-body -->
                <div class="batch-filter-container" style="background: #f9fafb; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
                    <div style="display: grid; grid-template-columns: 2fr 2fr 1fr 1fr; gap: 1rem; align-items: end;">
                        <!-- Tìm kiếm theo mã lô -->
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">
                                <i class="fas fa-search"></i> Tìm kiếm mã lô
                            </label>
                            <input type="text"
                                   id="batchCodeSearch"
                                   class="form-input"
                                   placeholder="Nhập mã lô..."
                                   onkeyup="filterBatches()">
                        </div>

                        <!-- Filter trạng thái sử dụng -->
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">
                                <i class="fas fa-toggle-on"></i> Trạng thái sử dụng
                            </label>
                            <select id="isActiveFilter" class="form-select" onchange="filterBatches()">
                                <option value="">Tất cả</option>
                                <option value="true">Đang sử dụng</option>
                                <option value="false">Ngừng sử dụng</option>
                            </select>
                        </div>

                        <!-- Checkbox hiển thị lô hết hàng -->
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label" style="opacity: 0;">.</label>
                            <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.875rem; font-weight: 500;">
                                <input type="checkbox"
                                       id="showEmptyBatches"
                                       onchange="filterBatches()"
                                       style="width: 1.125rem; height: 1.125rem; cursor: pointer;">
                                <span>Hiển thị lô hết hàng</span>
                            </label>
                        </div>

                        <!-- Nút reset filter -->
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label" style="opacity: 0;">.</label>
                            <button class="btn btn-primary" onclick="resetBatchFilters()" style="width: 100%;">
                                <i class="fas fa-redo"></i> Reset
                            </button>
                        </div>
                    </div>
                </div>
                <hr>
                <h4 style="margin-top: 1rem; color:#1f2937;">Danh sách các lô nhập</h4>
                <div class="batch-table-container">
                    <table class="batch-table">
                        <thead>
                            <tr>
                                <th>Mã lô</th>
                                <th>Nhà cung cấp</th>
                                <th>Ngày nhập</th>
                                <th>Hạn sử dụng</th>
                                <th>Số lượng còn</th>
                                <th>Tình trạng</th>
                                <th>Thuộc kho</th>
                                <th>Đang sử dụng</th>
                                <th>Thao tác</th>
                                <th id="auditActionHeader" style="display: none;">Kiểm kê</th>
                            </tr>
                        </thead>
                        <tbody id="batchTableBody">
                            <tr><td colspan="8" style="text-align:center;">Chưa có dữ liệu</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="modal-footer" style="justify-content: space-between; align-items: center;">
                <div style="flex: 1; background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
                padding: 0.75rem 1rem; border-radius: 0.5rem; border-left: 4px solid #dc2626;
                margin-right: 1rem;">
                    <p style="margin: 0; font-size: 0.875rem; color: #991b1b; line-height: 1.5;
                  display: flex; align-items: start; gap: 0.5rem;">
                        <i class="fas fa-exclamation-circle" style="margin-top: 0.125rem; flex-shrink: 0; font-size: 1rem;"></i>
                        <span><strong>Lưu ý:</strong> Với các lô mặt hàng hết hạn sử dụng nhưng vẫn có trạng thái đang sử dụng, hệ thống sẽ không trừ mặt hàng để chất lượng mặt hàng luôn được đảm bảo.</span>
                    </p>
                </div>
                <button id="closeModalFooter" class="btn btn-danger" style="flex-shrink: 0;">
                    <i class="fas fa-times"></i> Đóng
                </button>
            </div>
        </div>
    </div>

    <!-- Modal chỉnh sửa mặt hàng -->
    <div id="editIngredientModal" class="edit-modal-overlay">
        <div class="edit-modal-content">
            <div class="edit-modal-header">
                <h2>
                    <i class="fas fa-edit"></i>
                    Chỉnh sửa mặt hàng
                </h2>
                <button id="closeEditModal" class="close-btn">&times;</button>
            </div>

            <div class="edit-modal-body">
                <form id="editIngredientForm">
                    <input type="hidden" id="editIngredientId">

                    <div class="edit-form-group">
                        <label class="edit-form-label">
                            <i class="fas fa-hashtag"></i> Mã mặt hàng
                        </label>
                        <input type="text"
                               id="editIngredientCode"
                               class="edit-form-input"
                               disabled>
                    </div>

                    <div class="edit-form-group">
                        <label class="edit-form-label">
                            <i class="fas fa-box"></i> Tên mặt hàng
                        </label>
                        <input type="text"
                               id="editIngredientName"
                               class="edit-form-input"
                               placeholder="Nhập tên mặt hàng"
                               required>
                    </div>

                    <div class="edit-form-group">
                        <label class="edit-form-label">
                            <i class="fas fa-ruler"></i> Đơn vị tính
                        </label>
                        <select id="editIngredientUnit"
                                class="edit-form-input"
                                required
                                style="cursor: pointer;">
                            <option value="">-- Chọn đơn vị tính --</option>
                            @foreach (var unit in Model.Units)
                            {
                                <option value="@unit.UnitId">@unit.UnitName</option>
                            }
                        </select>
                    </div>
                </form>
            </div>

            <div class="edit-modal-footer">
                <button class="btn btn-danger" onclick="closeEditIngredientModal()">
                    <i class="fas fa-times"></i> Hủy
                </button>
                <button class="btn btn-success" id="saveEditBtn">
                    <i class="fas fa-save"></i> Lưu thay đổi
                </button>
            </div>
        </div>
    </div>

    <!-- Modal kiểm kê thực tế - VERSION CẬP NHẬT -->
    <div id="auditModal" class="audit-modal-overlay">
        <div class="audit-modal-content">
            <div class="audit-modal-header">
                <h2>
                    <i class="fas fa-clipboard-check"></i>
                    Kiểm kê thực tế mặt hàng
                </h2>
                <button class="close-btn" onclick="closeAuditModal()">&times;</button>
            </div>

            <div class="audit-modal-body">
                <!-- 1. Thông tin lô hiện tại -->
                <div class="audit-section">
                    <h3 style="font-size: 1.125rem; font-weight: 700; color: #374151; margin-bottom: 1rem;">
                        <i class="fas fa-box" style="color: #9333ea;"></i>
                        Thông tin lô mặt hàng hiện tại
                    </h3>
                    <div style="background: linear-gradient(135deg, #f3e8ff 0%, #e9d5ff 100%); padding: 1.5rem; border-radius: 8px; border-left: 4px solid #9333ea;">
                        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
                            <!-- Cột trái -->
                            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">
                                        <i class="fas fa-hashtag"></i> Mã lô:
                                    </div>
                                    <div id="auditBatchCode" style="flex: 1; background: white; padding: 0.5rem 1rem; border-radius: 6px; font-weight: 700; color: #9333ea;">---</div>
                                </div>
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">Mã mặt hàng:</div>
                                    <div id="auditIngredientCode" style="flex: 1; background: white; padding: 0.5rem 1rem; border-radius: 6px;">---</div>
                                </div>
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">Tên mặt hàng:</div>
                                    <div id="auditIngredientName" style="flex: 1; background: white; padding: 0.5rem 1rem; border-radius: 6px; font-weight: 500;">---</div>
                                </div>
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">Đơn vị tính:</div>
                                    <div id="auditUnit" style="flex: 1; background: white; padding: 0.5rem 1rem; border-radius: 6px;">---</div>
                                </div>
                            </div>

                            <!-- Cột phải -->
                            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">
                                        Hạn sử dụng:
                                    </div>
                                    <div id="auditExpiryDate" style="flex: 1; background: white; padding: 0.5rem 1rem; border-radius: 6px;">---</div>
                                </div>
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">Số lượng:</div>
                                    <div id="auditCurrentQty" style="flex: 1; background: white; padding: 0.5rem 1rem; border-radius: 6px; font-weight: 700; text-align: left;">0</div>
                                </div>
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">
                                        Thời gian kiểm kê:
                                    </div>
                                    <div id="auditDateTime" style="flex: 1; background: white; padding: 0.5rem 1rem; border-radius: 6px; font-weight: 600; color: #7c3aed;">---</div>
                                </div>
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">
                                        <i class="fas fa-warehouse"></i> Thuộc kho:
                                    </div>
                                    <div id="auditWarehouse" style="flex: 1; background: white; padding: 0.5rem 1rem; border-radius: 6px; font-weight: 500;">---</div>
                                </div>
                                <div style="display: flex; align-items: start; gap: 0.75rem;">
                                    <div style="min-width: 140px; font-weight: 600; color: #6b21a8;">Tình trạng:</div>
                                    <div id="auditStatus" style="flex: 1;">---</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Thao tác kiểm kê + Lý do (Grid 2 cột) -->
                <div style="margin-bottom: 1.5rem;">
                    <div class="audit-section">
                        <div class="audit-actions">
                            <h3 style="font-size: 1.125rem; font-weight: 700; color: #1e40af; margin-bottom: 1rem;">
                                Thao tác kiểm kê
                            </h3>

                            <div style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;">
                                <!-- Cột trái: Radio buttons + Input -->
                                <div>
                                    <!-- Radio buttons -->
                                    <div class="audit-radio-group" style="margin-bottom: 1.5rem;">
                                        <label class="audit-radio-label">
                                            <input type="radio" name="auditType" value="add" checked onchange="handleAuditTypeChange()">
                                            <span>Thêm số lượng</span>
                                        </label>
                                        <label class="audit-radio-label">
                                            <input type="radio" name="auditType" value="remove" onchange="handleAuditTypeChange()">
                                            <span>Hủy số lượng</span>
                                        </label>
                                        <label class="audit-radio-label">
                                            <input type="radio" name="auditType" value="removeAll" onchange="handleAuditTypeChange()">
                                            <span>Hủy tất cả</span>
                                        </label>
                                        <label class="audit-radio-label">
                                            <input type="radio" name="auditType" value="noChange" onchange="handleAuditTypeChange()">
                                            <span>Không thay đổi</span>
                                        </label>
                                    </div>

                                    <!-- Input số lượng -->
                                    <div id="auditQuantityInput">
                                        <label style="display: block; font-size: 0.875rem; font-weight: 600; color: #374151; margin-bottom: 0.5rem;">
                                            Nhập số lượng <span id="auditTypeLabel">thêm</span>
                                        </label>
                                        <input type="number"
                                               id="auditQuantity"
                                               class="audit-quantity-input"
                                               placeholder="Nhập số lượng"
                                               min="0"
                                               step="any"
                                               oninput="updateAuditPreview()">
                                    </div>

                                    <div style="margin-top: 1rem;">
                                        <label style="display: block; font-size: 0.875rem; font-weight: 600; color: #374151; margin-bottom: 0.5rem;">
                                            <i class="fas fa-calendar-alt" style="color: #f59e0b;"></i>
                                            Ngày hết hạn mới (tùy chọn)
                                        </label>
                                        <input type="date"
                                               id="auditNewExpiryDate"
                                               class="audit-quantity-input"
                                               style="width: 100%;">
                                        <p style="font-size: 0.75rem; color: #6b7280; margin-top: 0.5rem;">
                                            <i class="fas fa-info-circle"></i>
                                            Để trống nếu giữ nguyên hạn sử dụng hiện tại
                                        </p>
                                    </div>
                                </div>

                                <!-- Cột phải: Preview số lượng -->
                                <div style="min-width: 280px; padding: 1.5rem; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 12px; border-left: 4px solid #f59e0b; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);">
                                    <div style="text-align: center;">
                                        <div style="font-size: 0.875rem; font-weight: 600; color: #92400e; margin-bottom: 0.75rem;">
                                            <i class="fas fa-calculator" style="margin-right: 0.5rem;"></i>
                                            Số lượng sau kiểm kê
                                        </div>
                                        <div id="auditPreviewQty" style="font-size: 2.5rem; font-weight: 800; color: #1f2937; margin-bottom: 0.5rem;">
                                            0
                                        </div>
                                        <div id="auditDiffIndicator" style="font-size: 0.875rem; font-weight: 600; min-height: 1.25rem;">
                                            <span style="color: #6b7280;">
                                                <i class="fas fa-minus"></i> Không thay đổi
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 3. Lý do kiểm kê (Full Width - Xuống dưới) -->
                    <div class="audit-section">
                        <div class="audit-reason-section" style="width: 100%;">
                            <h3 style="font-size: 1.125rem; font-weight: 700; color: #92400e; margin-bottom: 1rem;">
                                <i class="fas fa-comment-alt" style="margin-right: 0.5rem;"></i>
                                Lý do kiểm kê
                            </h3>
                            <textarea id="auditReason"
                                      class="audit-reason-textarea"
                                      placeholder="Nhập lý do kiểm kê...&#10;Ví dụ: Hàng bị hư hỏng, Sai sót trong nhập liệu, Kiểm tra định kỳ, v.v."
                                      style="width: 100%;"></textarea>
                            <p style="font-size: 0.75rem; color: #92400e; margin-top: 0.5rem;">
                                <i class="fas fa-info-circle"></i> Vui lòng mô tả rõ lý do thêm/hủy mặt hàng
                            </p>
                        </div>
                    </div>
                </div>



                <!-- 4. Thông tin xác nhận & Upload ảnh -->
                <div class="audit-confirmer-section">
                    <!-- Thông tin người xác nhận -->
                    <div class="audit-confirmer-box">
                        <label class="audit-checkbox-label">
                            <input type="checkbox" id="useMyInfo" onchange="handleConfirmerCheckbox(this.checked)">
                            <i class="fas fa-user"></i>
                            <span>Sử dụng thông tin của tôi</span>
                        </label>

                        <div id="confirmerInfoForm" style="display: none;">
                            <div class="audit-input-group">
                                <label class="audit-input-label">
                                    <i class="fas fa-user"></i> Tên người xác nhận
                                </label>
                                <input type="text" id="confirmerName" class="audit-input" readonly>
                            </div>
                            <div class="audit-input-group">
                                <label class="audit-input-label">
                                    <i class="fas fa-briefcase"></i> Chức vụ
                                </label>
                                <input type="text" id="confirmerPosition" class="audit-input" readonly>
                            </div>
                            <div class="audit-input-group">
                                <label class="audit-input-label">
                                    <i class="fas fa-phone"></i> Số điện thoại
                                </label>
                                <input type="tel" id="confirmerPhone" class="audit-input" readonly>
                            </div>
                        </div>

                        <div id="confirmerPlaceholder" class="audit-placeholder">
                            <i class="fas fa-user"></i>
                            <p style="font-size: 0.875rem;">Tick checkbox để sử dụng thông tin của bạn</p>
                        </div>
                    </div>

                    <!-- Upload hình ảnh -->
                    <div class="audit-image-box">
                        <h4 style="font-size: 1.125rem; font-weight: 700; color: #065f46; margin-bottom: 1rem;">
                            <i class="fas fa-camera"></i> Hình ảnh chứng cứ
                        </h4>
                        <label for="auditImageUpload" class="audit-upload-area">
                            <div id="imagePreviewContainer">
