        }

        const isConfirmed = await showConfirmModal({
            type: 'danger',
            icon: '⚠️',
            title: 'Từ chối đơn kiểm kê',
            message: 'Bạn có chắc chắn muốn TỪ CHỐI đơn kiểm kê này?',
            warning: ' Hành động này không thể hoàn tác!',
            buttonText: ' Từ chối',
            buttonClass: 'confirm-modal-btn-reject'
            
        });

        if (!isConfirmed) return;

        rejectBtn.disabled = true;
        rejectBtn.textContent = ' Đang xử lý...';

        try {
            //  LẤY THÔNG TIN TỪ CLAIMS
            const user = await getCurrentUserFromSession();

            const requestData = {
                auditId: auditId,
                auditStatus: 'cancelled',
                confirmerId: user.userId,
                confirmerName: user.fullName,
                confirmerPhone: user.phone,
                confirmerPosition: user.position,
                confirmedAt: new Date().toISOString()
            };

            console.log('Sending reject request:', requestData);

            const response = await fetch(`/AuditInventory/ConfirmAudit/${auditId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(requestData)
            });

            const result = await response.json();

            if (result.success) {
                await showConfirmModal({
                    type: 'success',
                    icon: '✅',
                    title: 'Thành công!',
                    message: 'Từ chối đơn kiểm kê thành công!',
                    warning: null,
                    buttonText: ' Đóng',
                    buttonClass: 'confirm-modal-btn-confirm',
                    showCancelButton: false
                });
                closeAuditModal();
                location.reload();
            } else {
                await showConfirmModal({
                    type: 'danger',
                    icon: '❌',
                    title: 'Lỗi',
                    message: result.message || 'Không thể từ chối đơn kiểm kê',
                    warning: null,
                    buttonText: ' Đóng',
                    buttonClass: 'confirm-modal-btn-reject'
                });
                rejectBtn.disabled = false;
                rejectBtn.innerHTML = ' Từ chối';
            }
        } catch (error) {
            console.error('Error rejecting audit:', error);
            await showConfirmModal({
                type: 'danger',
                icon: '❌',
                title: 'Lỗi',
                message: error.message || 'Có lỗi xảy ra khi từ chối',
                warning: null,
                buttonText: ' Đóng',
                buttonClass: 'confirm-modal-btn-reject'
            });
            rejectBtn.disabled = false;
            rejectBtn.innerHTML = ' Từ chối';
        }
    }

    function printAudit(auditId) {
        window.print();
    }

    function openImageViewer(imagePath) {
        const viewer = document.getElementById('imageViewer');
        const modalOverlay = document.getElementById('auditDetailModal');
        const img = document.getElementById('imageViewerImg');

        // Set image source
        img.src = imagePath;

        // Add classes to shift modal and show viewer
        modalOverlay.classList.add('with-image-viewer');
        viewer.classList.add('active');
    }

    function closeImageViewer() {
        const viewer = document.getElementById('imageViewer');
        const modalOverlay = document.getElementById('auditDetailModal');

        // Remove classes
        modalOverlay.classList.remove('with-image-viewer');
        viewer.classList.remove('active');
    }

    // Confirmation Modal Helper
    function showConfirmModal(config) {
        return new Promise((resolve) => {
            const modal = document.getElementById('confirmModal');
            const icon = document.getElementById('confirmModalIcon');
            const title = document.getElementById('confirmModalTitle');
            const message = document.getElementById('confirmModalMessage');
            const warning = document.getElementById('confirmModalWarning');
            const footer = document.getElementById('confirmModalFooter');

            // Set icon
            icon.className = 'confirm-modal-icon ' + config.type;
            icon.innerHTML = config.icon;

            // Set title
            title.textContent = config.title;

            // Set message
            message.textContent = config.message;

            // Set warning (optional)
            if (config.warning) {
                warning.textContent = config.warning;
                warning.style.display = 'block';
            } else {
                warning.style.display = 'none';
            }

            // Set buttons
            footer.innerHTML = '';

            // ✅ THÊM: Kiểm tra nếu có tham số showCancelButton (mặc định là true)
            const showCancelButton = config.showCancelButton !== false;

            // ✅ CHỈ HIỂN THỊ NÚT HỦY NẾU showCancelButton = true
            if (showCancelButton) {
                const cancelBtn = document.createElement('button');
                cancelBtn.className = 'confirm-modal-btn confirm-modal-btn-cancel';
                cancelBtn.innerHTML = 'Hủy bỏ';
                cancelBtn.onclick = () => {
                    closeConfirmModal();
                    resolve(false);
                };
                footer.appendChild(cancelBtn);
            }

            // Confirm/Reject button
            const actionBtn = document.createElement('button');
            actionBtn.className = 'confirm-modal-btn ' + config.buttonClass;
            actionBtn.innerHTML = config.buttonText;
            actionBtn.onclick = () => {
                closeConfirmModal();
                resolve(true);
            };
            footer.appendChild(actionBtn);

            // Show modal
            modal.classList.add('active');
        });
    }

    function closeConfirmModal() {
        const modal = document.getElementById('confirmModal');
        modal.classList.remove('active');
    }

    async function generateReport(data) {
        try {
            const requestBody = {
                dateFrom: reportPeriod.dateFrom.toISOString(),
                dateTo: reportPeriod.dateTo.toISOString(),
                status: currentTab === 'all' ? null : currentTab,
                reporterName: currentUser.fullName,
                reporterPosition: currentUser.position
            };

            const response = await fetch('/AuditInventory/ExportReportPdf', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(requestBody)
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.message || 'Không thể tạo báo cáo PDF');
            }

            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `BaoCaoKiemKe_${formatDateForInput(reportPeriod.dateFrom)}_${formatDateForInput(reportPeriod.dateTo)}.pdf`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);

        } catch (error) {
            console.error('Error generating report:', error);
            throw error;
        }
    }

    let reportPeriod = {
        dateFrom: new Date(),
        dateTo: new Date(),
        selectedDays: 7 // Mặc định 7 ngày
    };

    // ✅ XỬ LÝ KHI THAY ĐỔI SELECT
    function handleReportPeriodChange(value) {
        if (value === 'custom') {
            openCustomDatePicker();
        } else {
            const days = parseInt(value);
            selectReportPeriod(days);
        }
    }

    // ✅ CHỌN KỲ BÁO CÁO
    function selectReportPeriod(days) {
        const today = new Date();
        today.setHours(23, 59, 59, 999);

        let fromDate = new Date();
        fromDate.setHours(0, 0, 0, 0);

        if (days > 0) {
            fromDate.setDate(today.getDate() - days);
        }

        reportPeriod = {
            dateFrom: fromDate,
            dateTo: today,
            selectedDays: days
        };

        console.log('Selected period:', reportPeriod);
    }

    // ✅ MỞ MODAL CHỌN NGÀY TÙY CHỈNH
    function openCustomDatePicker() {
        // Set default dates
        const today = new Date();
        const sevenDaysAgo = new Date();
        sevenDaysAgo.setDate(today.getDate() - 7);

        document.getElementById('customDateFrom').value = formatDateForInput(sevenDaysAgo);
        document.getElementById('customDateTo').value = formatDateForInput(today);

        // Show modal
        document.getElementById('customDateModal').classList.add('active');
    }

    // ✅ ĐÓNG MODAL CHỌN NGÀY
    function closeCustomDatePicker() {
        document.getElementById('customDateModal').classList.remove('active');

        // Reset select về giá trị trước đó
        const select = document.getElementById('reportPeriodSelect');
        select.value = reportPeriod.selectedDays === 'custom' ? '7' : reportPeriod.selectedDays.toString();
    }

    // ✅ ÁP DỤNG NGÀY TÙY CHỈNH
    function applyCustomDate() {
        const fromInput = document.getElementById('customDateFrom').value;
        const toInput = document.getElementById('customDateTo').value;

        if (!fromInput || !toInput) {
            showToast('warning', 'Thiếu thông tin', 'Vui lòng chọn đầy đủ từ ngày và đến ngày');
            return;
        }

        const fromDate = new Date(fromInput);
        const toDate = new Date(toInput);

        fromDate.setHours(0, 0, 0, 0);
        toDate.setHours(23, 59, 59, 999);

        if (fromDate > toDate) {
            showToast('error', 'Ngày không hợp lệ', 'Từ ngày phải nhỏ hơn hoặc bằng đến ngày');
            return;
        }

        reportPeriod = {
            dateFrom: fromDate,
            dateTo: toDate,
            selectedDays: 'custom'
        };

        document.getElementById('customDateModal').classList.remove('active');

    }

    // ✅ XUẤT BÁO CÁO
    async function exportReport() {
        try {
            // Kiểm tra đã chọn kỳ báo cáo chưa
            if (!reportPeriod || !reportPeriod.dateFrom || !reportPeriod.dateTo) {
                showToast('warning', 'Chưa chọn kỳ báo cáo', 'Vui lòng chọn khoảng thời gian báo cáo');
                return;
            }

            // Show loading
            const exportBtn = document.querySelector('.audit-btn-export-report');
            const originalText = exportBtn.innerHTML;
            exportBtn.disabled = true;
            exportBtn.innerHTML = '⏳ Đang tạo báo cáo...';

            // Prepare request data
            const requestData = {
                dateFrom: reportPeriod.dateFrom.toISOString(),
                dateTo: reportPeriod.dateTo.toISOString(),
                status: currentTab === 'all' ? null : currentTab,
                reporterName: currentUser.fullName,
                reporterPosition: currentUser.position
            };

            console.log('Exporting report with data:', requestData);

            // Call API
            const response = await fetch('/AuditInventory/ExportReportPdf', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(requestData)
            });

            if (!response.ok) {
                const errorText = await response.text();
                let errorMessage = 'Không thể tạo báo cáo';

                try {
                    const error = JSON.parse(errorText);
                    errorMessage = error.message || errorMessage;
                } catch (e) {
                    console.error('Error parsing response:', errorText);
                }

                throw new Error(errorMessage);
            }

            // Download PDF
            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `BaoCaoKiemKe_${formatDateForFilename(reportPeriod.dateFrom)}_${formatDateForFilename(reportPeriod.dateTo)}.pdf`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);

            showToast('success', 'Xuất báo cáo thành công', 'File PDF đã được tải về');

            // Reset button
            exportBtn.disabled = false;
            exportBtn.innerHTML = originalText;

        } catch (error) {
            console.error('Error exporting report:', error);
            showToast('error', 'Lỗi xuất báo cáo', error.message || 'Không thể tạo báo cáo PDF');

            // Reset button
            const exportBtn = document.querySelector('.audit-btn-export-report');
            exportBtn.disabled = false;
            exportBtn.innerHTML = 'Xuất báo cáo';
        }
    }

    // ✅ HELPER: FORMAT DATE CHO INPUT (YYYY-MM-DD)
    function formatDateForInput(date) {
        if (!date) return '';
        const d = new Date(date);
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
    }

    // ✅ HELPER: FORMAT DATE CHO FILENAME (YYYYMMDD)
    function formatDateForFilename(date) {
        if (!date) return '';
        const d = new Date(date);
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${year}${month}${day}`;
    }

    // ✅ HELPER: FORMAT DATE CHO HIỂN THỊ (DD/MM/YYYY)
    function formatDate(date) {
        if (!date) return '';
        const d = new Date(date);
        const day = String(d.getDate()).padStart(2, '0');
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const year = d.getFullYear();
        return `${day}/${month}/${year}`;
    }

    // ✅ KHỞI TẠO MẶC ĐỊNH KHI LOAD TRANG
    document.addEventListener('DOMContentLoaded', function () {
        // Khởi tạo mặc định cho báo cáo (7 ngày qua)
        selectReportPeriod(7);
    });

</script>