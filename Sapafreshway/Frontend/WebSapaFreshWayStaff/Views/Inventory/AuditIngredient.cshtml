<script>
    function showToast(type, title, message, duration = 4000) {
        const container = document.getElementById('toastContainer');

        // Tạo toast element
        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;

        // Icon theo loại
        const icons = {
            success: '✓',
            error: '✕',
            warning: '⚠',
            info: 'ℹ'
        };

        toast.innerHTML = `
                <div class="toast-icon">${icons[type] || 'ℹ'}</div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-message">${message}</div>
                </div>
                <button class="toast-close" onclick="this.closest('.toast').remove()">×</button>
            `;

        container.appendChild(toast);

        // Auto remove sau duration
        setTimeout(() => {
            toast.classList.add('slide-out');
            setTimeout(() => toast.remove(), 300);
        }, duration);
    }


    const currentUser = {
        userId: parseInt('@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value' || '0'),
        fullName: decodeURIComponent('@Html.Raw(System.Uri.EscapeDataString(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? ""))'),
        phone: '@User.FindFirst(System.Security.Claims.ClaimTypes.MobilePhone)?.Value',
        email: '@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value',
        position: decodeURIComponent('@Html.Raw(System.Uri.EscapeDataString(User.FindFirst("Positions")?.Value ?? "Nhân viên kho"))')
    };

        let currentPage = 1;
        const itemsPerPage = 10;
        let allRows = [];
        let filteredRows = [];
        let currentTab = 'all'; // Mặc định tab "Tất cả"

        document.addEventListener('DOMContentLoaded', function () {
            allRows = Array.from(document.querySelectorAll('.audit-row'));

            // Sắp xếp mặc định theo thời gian (mới nhất lên đầu)
            sortRowsByTime(allRows, true);

            filteredRows = [...allRows];

            // Cập nhật số lượng cho các tab
            updateTabCounts();

            // Mặc định hiển thị tab "Tất cả"
            switchTab('all');

            // Event listeners
            document.getElementById('searchInput').addEventListener('input', applyFilters);
            document.getElementById('sortByFilter').addEventListener('change', applyFilters);
            document.getElementById('dateFromFilter').addEventListener('change', applyFilters);
            document.getElementById('dateToFilter').addEventListener('change', applyFilters);
        });

        // Đếm số lượng đơn theo trạng thái
        function updateTabCounts() {
    const processingCount = allRows.filter(row => row.dataset.auditStatus === 'processing').length;
    const completedCount = allRows.filter(row => row.dataset.auditStatus === 'completed').length;
    const cancelledCount = allRows.filter(row => row.dataset.auditStatus === 'cancelled').length;
    const allCount = allRows.length;

    document.getElementById('processingCount').textContent = processingCount;
    document.getElementById('completedCount').textContent = completedCount;
    document.getElementById('cancelledCount').textContent = cancelledCount;
    document.getElementById('allCount').textContent = allCount;
}

        // Chuyển tab
        function switchTab(tab) {
            currentTab = tab;

            // Cập nhật active state cho tabs
            document.querySelectorAll('.audit-tab').forEach(tabEl => {
                if (tabEl.dataset.tab === tab) {
                    tabEl.classList.add('active');
                } else {
                    tabEl.classList.remove('active');
                }
            });

            // Reset về trang 1 và áp dụng filters
            currentPage = 1;
            applyFilters();
        }

        // Áp dụng filters
        function applyFilters() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            const sortBy = document.getElementById('sortByFilter').value;
            const dateFrom = document.getElementById('dateFromFilter').value;
            const dateTo = document.getElementById('dateToFilter').value;

            filteredRows = allRows.filter(row => {
                // Lọc theo tab
                if (currentTab !== 'all') {
                    const status = row.dataset.auditStatus;
                    if (status !== currentTab) return false;
                }

                // Lấy các giá trị từ data attributes
                const auditCode = (row.dataset.auditCode || '').toLowerCase();
                const purchaseOrderId = (row.dataset.purchaseOrderId || '').toLowerCase();
                const ingredientName = (row.dataset.ingredientName || '').toLowerCase();
                const ingredientCode = (row.dataset.ingredientCode || '').toLowerCase();
                const createdAt = row.dataset.createdAt || '';

                // Search filter
                const matchSearch = !searchTerm ||
                    auditCode.includes(searchTerm) ||
                    purchaseOrderId.includes(searchTerm) ||
                    ingredientName.includes(searchTerm) ||
                    ingredientCode.includes(searchTerm);

                // Date filter
                let matchDate = true;
                if (dateFrom || dateTo) {
                    const rowDate = parseDate(createdAt);
                    if (!rowDate) {
                        matchDate = false;
                    } else {
                        if (dateFrom) {
                            const fromDate = new Date(dateFrom);
                            fromDate.setHours(0, 0, 0, 0);
                            matchDate = matchDate && rowDate >= fromDate;
                        }
                        if (dateTo) {
                            const toDate = new Date(dateTo);
                            toDate.setHours(23, 59, 59, 999);
                            matchDate = matchDate && rowDate <= toDate;
                        }
                    }
                }

                return matchSearch && matchDate;
            });

            // Sắp xếp
            sortFilteredRows(sortBy);

            currentPage = 1;
            updatePagination();
        }

        // Sắp xếp rows đã lọc
        function sortFilteredRows(sortBy) {
            switch (sortBy) {
                case 'time':
                    sortRowsByTime(filteredRows, true); // true = mới nhất lên đầu
                    break;
                case 'code':
                    filteredRows.sort((a, b) => {
                        const codeA = a.dataset.auditCode || '';
                        const codeB = b.dataset.auditCode || '';
                        return codeA.localeCompare(codeB);
                    });
                    break;
                case 'ingredient':
                    filteredRows.sort((a, b) => {
                        const nameA = a.dataset.ingredientName || '';
                        const nameB = b.dataset.ingredientName || '';
                        return nameA.localeCompare(nameB, 'vi');
                    });
                    break;
            }
        }

        // Sắp xếp theo thời gian
        function sortRowsByTime(rows, newestFirst = true) {
            rows.sort((a, b) => {
                const dateA = parseDate(a.dataset.createdAt);
                const dateB = parseDate(b.dataset.createdAt);

                if (!dateA && !dateB) return 0;
                if (!dateA) return 1;
                if (!dateB) return -1;

                return newestFirst ? dateB - dateA : dateA - dateB;
            });
        }

        function parseDate(dateStr) {
            if (!dateStr) return null;

            try {
                const parts = dateStr.split(' ');
                if (parts.length < 1) return null;

                const dateParts = parts[0].split('/');
                if (dateParts.length !== 3) return null;

                const day = parseInt(dateParts[0]);
                const month = parseInt(dateParts[1]) - 1;
                const year = parseInt(dateParts[2]);

                // Nếu có giờ phút
                let hours = 0, minutes = 0;
                if (parts.length > 1) {
                    const timeParts = parts[1].split(':');
                    if (timeParts.length === 2) {
                        hours = parseInt(timeParts[0]);
                        minutes = parseInt(timeParts[1]);
                    }
                }

                const date = new Date(year, month, day, hours, minutes);

                if (isNaN(date.getTime())) return null;

                return date;
            } catch (error) {
                console.error('Error parsing date:', dateStr, error);
                return null;
            }
        }

        function updatePagination() {
            // Hide all rows
            allRows.forEach(row => row.classList.add('hidden'));

            // Show filtered rows for current page
            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = Math.min(startIndex + itemsPerPage, filteredRows.length);

            for (let i = startIndex; i < endIndex; i++) {
                filteredRows[i].classList.remove('hidden');
            }

            // Update pagination info
            document.getElementById('showingFrom').textContent = filteredRows.length > 0 ? startIndex + 1 : 0;
            document.getElementById('showingTo').textContent = endIndex;
            document.getElementById('totalVisible').textContent = filteredRows.length;

            // Cập nhật số ở tab hiện tại
            const currentTabElement = document.querySelector(`.audit-tab[data-tab="${currentTab}"]`);
            if (currentTabElement) {
                const badge = currentTabElement.querySelector('.audit-tab-badge');
                if (badge) {
                    document.getElementById('totalAuditsCount').textContent = filteredRows.length;
                }
            }

            // Update page number
            const totalPages = Math.ceil(filteredRows.length / itemsPerPage);
            document.getElementById('currentPageBtn').textContent = filteredRows.length > 0 ? currentPage : 0;

            // Enable/disable pagination buttons
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');

            if (currentPage <= 1) {
                prevBtn.classList.add('disabled');
            } else {
                prevBtn.classList.remove('disabled');
            }

            if (currentPage >= totalPages) {
                nextBtn.classList.add('disabled');
            } else {
                nextBtn.classList.remove('disabled');
            }
        }

        function changePage(direction) {
            const totalPages = Math.ceil(filteredRows.length / itemsPerPage);
            const newPage = currentPage + direction;

            if (newPage >= 1 && newPage <= totalPages) {
                currentPage = newPage;
                updatePagination();
            }
        }

