    async function getCurrentUserFromSession() {
        //  VALIDATE DỮ LIỆU TỪ CLAIMS
        if (!currentUser || !currentUser.userId || currentUser.userId === 0) {
            throw new Error('Không tìm thấy thông tin người dùng. Vui lòng đăng nhập lại.');
        }

        //  PARSE POSITION NẾU LÀ JSON ARRAY
        let position = currentUser.position;
        try {
            // Nếu position là JSON array (VD: ["Nhân viên kho", "Thu ngân"])
            const positions = JSON.parse(position);
            if (Array.isArray(positions) && positions.length > 0) {
                position = positions[0]; // Lấy position đầu tiên
            }
        } catch (e) {
            // Nếu không phải JSON, giữ nguyên string
            console.log('Position is a simple string:', position);
        }

        //  TRẢ VỀ THÔNG TIN TỪ CLAIMS (KHÔNG CẦN AWAIT)
        return {
            userId: currentUser.userId,
            fullName: currentUser.fullName,
            phone: currentUser.phone,
            position: position,
            email: currentUser.email
        };
    }

