    function getIngredientStatusBadge(status) {
        const statusMap = {
            'expired': '<span class="audit-ingredient-status-badge audit-ingredient-status-expired">Hết hạn</span>',
            'expiring': '<span class="audit-ingredient-status-badge audit-ingredient-status-expiring">Sắp hết hạn</span>',
            'normal': '<span class="audit-ingredient-status-badge audit-ingredient-status-normal">Bình thường</span>'
        };
        return statusMap[status] || statusMap['normal'];
    }

    function formatNumber(value) {
        if (value === null || value === undefined) return '0,00';
        return parseFloat(value).toLocaleString('de-DE', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    async function confirmAudit(auditId) {
        const confirmBtn = document.getElementById('confirmBtn');
        const checkbox = document.getElementById('confirmCheckbox');

        if (!checkbox.checked) {
            showToast('warning', 'Chưa xác nhận', 'Vui lòng tick vào ô checkbox để xác nhận!');
            return;
        }

        const isConfirmed = await showConfirmModal({
            type: 'success',
            icon: '',
            title: 'Xác nhận đơn kiểm kê',
            message: 'Bạn có chắc chắn muốn XÁC NHẬN đơn kiểm kê này?',
            warning: null,
            buttonText: 'Xác nhận',
            buttonClass: 'confirm-modal-btn-confirm'
        });

        if (!isConfirmed) return;

        confirmBtn.disabled = true;
        confirmBtn.textContent = '⏳ Đang xử lý...';

        try {
            //  LẤY THÔNG TIN TỪ CLAIMS
            const user = await getCurrentUserFromSession();

            const requestData = {
                auditId: auditId,
                auditStatus: 'completed',
                confirmerId: user.userId,
                confirmerName: user.fullName,
                confirmerPhone: user.phone,
                confirmerPosition: user.position,
                confirmedAt: new Date().toISOString()
            };

            console.log('Sending confirm request:', requestData);

            const response = await fetch(`/AuditInventory/ConfirmAudit/${auditId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(requestData)
            });

            const result = await response.json();

            if (result.success) {
                await showConfirmModal({
                    type: 'success',
                    icon: '',
                    title: 'Thành công!',
                    message: 'Xác nhận đơn kiểm kê thành công!',
                    warning: null,
                    buttonText: ' Đóng',
                    buttonClass: 'confirm-modal-btn-confirm',
                        showCancelButton: false
                });
                closeAuditModal();
                location.reload();
            } else {
                await showConfirmModal({
                    type: 'danger',
                    icon: '❌',
                    title: 'Lỗi',
                    message: result.message || 'Không thể xác nhận đơn kiểm kê',
                    warning: null,
                    buttonText: ' Đóng',
                    buttonClass: 'confirm-modal-btn-reject'
                });
                confirmBtn.disabled = false;
                confirmBtn.innerHTML = ' Xác nhận';
            }
        } catch (error) {
            console.error('Error confirming audit:', error);
            await showConfirmModal({
                type: 'danger',
                icon: '❌',
                title: 'Lỗi',
                message: error.message || 'Có lỗi xảy ra khi xác nhận',
                warning: null,
                buttonText: ' Đóng',
                buttonClass: 'confirm-modal-btn-reject'
            });
            confirmBtn.disabled = false;
            confirmBtn.innerHTML = ' Xác nhận';
        }
    }


    async function rejectAudit(auditId) {
