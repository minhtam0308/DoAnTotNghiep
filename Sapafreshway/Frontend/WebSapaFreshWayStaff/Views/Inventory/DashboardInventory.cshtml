@model WebSapaFreshWayStaff.DTOs.Inventory.DashboardViewModel
@{
    Layout = "~/Views/Shared/_LayoutInventory.cshtml";
    ViewData["Title"] = "Dashboard Quản Lý Kho";
}


<style>
    /* Reset & Base */
    .wd-container * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .wd-page-wrapper {
        min-height: 100vh;
        background: linear-gradient(to bottom right, #f9fafb, #f3f4f6);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: #1f2937;
    }

    /* Layout & Spacing */
    .wd-padding-8 {
        padding: 32px;
    }

    .wd-padding-6 {
        padding: 24px;
    }

    .wd-padding-4 {
        padding: 16px;
    }

    .wd-space-y-6 > * + * {
        margin-top: 24px;
    }

    .wd-space-y-3 > * + * {
        margin-top: 12px;
    }

    .wd-space-y-1 > * + * {
        margin-top: 4px;
    }

    .wd-mt-1 {
        margin-top: 4px;
    }

    .wd-mt-0-5 {
        margin-top: 2px;
    }

    .wd-mt-2 {
        margin-top: 8px;
    }

    .wd-mb-1 {
        margin-bottom: 4px;
    }

    .wd-mb-2 {
        margin-bottom: 8px;
    }

    .wd-mb-4 {
        margin-bottom: 16px;
    }

    .wd-mb-8 {
        margin-bottom: 32px;
    }

    .wd-mr-2 {
        margin-right: 8px;
    }

    .wd-pb-4 {
        padding-bottom: 16px;
    }

    /* Grids & Flex */
    .wd-flex {
        display: flex;
    }

    .wd-flex-1 {
        flex: 1 1 0%;
    }

    .wd-items-center {
        align-items: center;
    }

    .wd-items-start {
        align-items: flex-start;
    }

    .wd-justify-between {
        justify-content: space-between;
    }

    .wd-justify-center {
        justify-content: center;
    }

    .wd-gap-2 {
        gap: 8px;
    }

    .wd-gap-3 {
        gap: 12px;
    }

    .wd-gap-6 {
        gap: 24px;
    }

    .wd-grid-3-col {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
    }

    .wd-grid-2-col {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
    }

    .wd-two-col-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
    }

    /* Typography */
    .wd-text-3xl {
        font-size: 30px;
    }

    .wd-text-2xl {
        font-size: 24px;
    }

    .wd-text-xl {
        font-size: 20px;
    }

    .wd-text-lg {
        font-size: 18px;
    }

    .wd-text-sm {
        font-size: 14px;
    }

    .wd-text-xs {
        font-size: 12px;
    }

    .wd-font-bold {
        font-weight: 700;
    }

    .wd-font-semibold {
        font-weight: 600;
    }

    .wd-font-medium {
        font-weight: 500;
    }

    /* Colors & Backgrounds */
    .wd-text-white {
        color: white;
    }

    .wd-text-gray-800 {
        color: #1f2937;
    }

    .wd-text-gray-700 {
        color: #374151;
    }

    .wd-text-gray-600 {
        color: #4b5563;
    }

    .wd-text-gray-500 {
        color: #6b7280;
    }

    .wd-text-gray-400 {
        color: #9ca3af;
    }

    .wd-text-blue-600 {
        color: #2563eb;
    }

    .wd-text-blue-700 {
        color: #1d4ed8;
    }

    .wd-text-green-600 {
        color: #10b981;
    }

    .wd-text-green-700 {
        color: #047857;
    }

    .wd-text-orange-500 {
        color: #f97316;
    }

    .wd-text-orange-600 {
        color: #ea580c;
    }

    .wd-text-red-500 {
        color: #ef4444;
    }

    .wd-text-red-600 {
        color: #dc2626;
    }

    .wd-text-purple-500 {
        color: #a855f7;
    }

    .wd-text-purple-600 {
        color: #9333ea;
    }

    .wd-text-purple-700 {
        color: #7e22ce;
    }

    .wd-bg-white {
        background-color: white;
    }

    .wd-bg-gray-100 {
        background-color: #f3f4f6;
    }

    .wd-bg-blue-100 {
        background-color: #dbeafe;
    }

    .wd-bg-green-50 {
        background-color: #f0fdf4;
    }

    .wd-bg-green-100 {
        background-color: #d1fae5;
    }

    .wd-bg-orange-50 {
        background-color: #fff7ed;
    }

    .wd-bg-red-50 {
        background-color: #fef2f2;
    }

    .wd-bg-purple-50 {
        background-color: #faf5ff;
    }

    .wd-bg-purple-100 {
        background-color: #e9d5ff;
    }

    .wd-bg-blue-500 {
        background-color: #3b82f6;
    }

    .wd-bg-blue-600 {
        background-color: #2563eb;
    }

    .wd-bg-green-500 {
        background-color: #10b981;
    }

    .wd-bg-green-600 {
        background-color: #059669;
    }

    .wd-bg-orange-600 {
        background-color: #ea580c;
    }

    .wd-bg-red-500 {
        background-color: #ef4444;
    }

    .wd-bg-purple-500 {
        background-color: #a855f7;
    }

    .wd-bg-purple-600 {
        background-color: #7c3aed;
    }

    .wd-bg-gray-600 {
        background-color: #4b5563;
    }

    .wd-bg-gradient-blue {
        background: linear-gradient(to bottom right, #3b82f6, #2563eb);
    }

    .wd-bg-gradient-green {
        background: linear-gradient(to bottom right, #10b981, #059669);
    }

    .wd-bg-gradient-purple {
        background: linear-gradient(to bottom right, #a855f7, #9333ea);
    }

    /* Borders & Shadows */
    .wd-border {
        border: 1px solid #e5e7eb;
    }

    .wd-border-b {
        border-bottom: 1px solid #e5e7eb;
    }

    .wd-border-gray-100 {
        border-color: #f3f4f6;
    }

    .wd-shadow-sm {
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }

    .wd-hover-shadow-md:hover {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.06);
    }

    .wd-rounded-xl {
        border-radius: 12px;
    }

    .wd-rounded-lg {
        border-radius: 8px;
    }

    .wd-rounded-full {
        border-radius: 9999px;
    }

    /* Components */
    .wd-header-bar {
        background-color: white;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
        border-bottom: 1px solid #e5e7eb;
        padding: 16px 32px;
    }

    .wd-btn-action, .wd-btn-primary {
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .wd-btn-action {
        padding: 8px;
        background: none;
        position: relative;
    }

        .wd-btn-action:hover {
            background-color: #f3f4f6;
        }

    .wd-btn-primary {
        padding: 8px 16px;
        background-color: #2563eb;
        color: white;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .wd-btn-primary:hover {
            background-color: #1d4ed8;
        }

    .wd-btn-link {
        background: none;
        border: none;
        cursor: pointer;
    }

        .wd-btn-link:hover {
            text-decoration: underline;
        }

    .wd-kpi-card {
        background-color: white;
        border: 1px solid #f3f4f6;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
        transition: box-shadow 0.2s;
    }

    .wd-kpi-card-icon-wrapper {
        padding: 12px;
        border-radius: 8px;
    }

    .wd-icon-bg-blue {
        background: linear-gradient(to bottom right, #3b82f6, #2563eb);
    }

    .wd-icon-bg-orange {
        background: linear-gradient(to bottom right, #f97316, #ea580c);
    }

    .wd-icon-bg-red {
        background: linear-gradient(to bottom right, #ef4444, #dc2626);
    }

    .wd-icon-bg-purple {
        background: linear-gradient(to bottom right, #a855f7, #9333ea);
    }

    .wd-task-panel-header {
        padding: 16px 24px;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .wd-task-grid {
        padding: 24px;
        display: grid;
        grid-template-columns: repeat(2, 1fr); 
        gap: 24px;
    }

    .wd-task-item {
        padding: 12px;
        border-radius: 8px;
        border: 1px solid transparent;
        cursor: pointer;
        transition: border-color 0.2s;
    }

        .wd-task-item.export {
            background: linear-gradient(to right, #eff6ff, rgba(239, 246, 255, 0.5));
            border-color: #dbeafe;
        }

            .wd-task-item.export:hover {
                border-color: #93c5fd;
            }

        .wd-task-item.import {
            background: linear-gradient(to right, #ecfdf5, rgba(236, 253, 245, 0.5));
            border-color: #d1fae5;
        }

            .wd-task-item.import:hover {
                border-color: #6ee7b7;
            }

        .wd-task-item.inventory {
            background: linear-gradient(to right, #faf5ff, rgba(250, 245, 255, 0.5));
            border-color: #e9d5ff;
        }

            .wd-task-item.inventory:hover {
                border-color: #d8b4fe;
            }

    .wd-tag-priority {
        font-size: 12px;
        padding: 2px 8px;
        border-radius: 4px;
        font-weight: 500;
    }

    .wd-tag-high {
        background-color: #ef4444;
        color: white;
    }

    .wd-tag-arriving {
        background-color: #10b981;
        color: white;
    }

    .wd-tag-pending {
        background-color: #e5e7eb;
        color: #374151;
    }

    .wd-alerts-list {
        max-height: 480px;
        overflow-y: auto;
        padding: 16px;
    }

    .wd-alert-item {
        padding: 16px;
        border-radius: 8px;
        border-left: 4px solid;
        margin-bottom: 12px;
        cursor: pointer;
        transition: box-shadow 0.2s;
    }

        .wd-alert-item:hover {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

    .wd-alert-urgent-expiry {
        background-color: #fef2f2;
        border-left-color: #ef4444;
    }

    .wd-alert-urgent-low {
        background-color: #fff7ed;
        border-left-color: #f97316;
    }

    .wd-alert-normal {
        background-color: #fffbeb;
        border-left-color: #facc15;
    }

    .wd-alert-time {
        color: #ef4444;
        font-weight: 700;
    }

    .wd-action-btn-quick {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 16px;
        border-radius: 8px;
        border: 1px solid;
        transition: all 0.2s;
        cursor: pointer;
        background: white;
    }

        .wd-action-btn-quick:hover > div {
            transform: scale(1.1);
        }

        .wd-action-btn-quick > div {
            transition: transform 0.2s;
        }

        .wd-action-btn-quick.blue {
            background: linear-gradient(to bottom right, #eff6ff, #dbeafe);
            border-color: #bfdbfe;
        }

        .wd-action-btn-quick.green {
            background: linear-gradient(to bottom right, #ecfdf5, #d1fae5);
            border-color: #a7f3d0;
        }

        .wd-action-btn-quick.purple {
            background: linear-gradient(to bottom right, #faf5ff, #e9d5ff);
            border-color: #d8b4fe;
        }

        .wd-action-btn-quick.orange {
            background: linear-gradient(to bottom right, #fff7ed, #fed7aa);
            border-color: #fdba74;
        }

        .wd-action-btn-quick.gray {
            background: linear-gradient(to bottom right, #f9fafb, #f3f4f6);
            border-color: #e5e7eb;
        }

    .wd-select {
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid #e5e7eb;
        font-size: 14px;
        outline: none;
    }

    .wd-last-mb-0:last-child {
        margin-bottom: 0;
    }

    .wd-last-pb-0:last-child {
        padding-bottom: 0;
    }

    .wd-last-border-b-0:last-child {
        border-bottom: none;
    }

    .wd-w-full {
        width: 100%;
    }

    .wd-h-2 {
        height: 8px;
    }

    .wd-w-2 {
        width: 8px;
    }

    .wd-task-item {
        padding: 12px;
        border-radius: 8px;
        border: 1px solid transparent;
        cursor: pointer;
        transition: border-color 0.2s, transform 0.2s; /* Thêm transform */
    }

        .wd-task-item:hover {
            transform: translateY(-2px); /* Nhấc lên khi hover */
        }   

    /* Thêm vào cuối phần style */
    .wd-task-section-scroll {
        max-height: 500px; /* Chiều cao tối đa cho ~5 items */
        overflow-y: auto;
        overflow-x: hidden;
    }

        /* Tùy chỉnh scrollbar */
        .wd-task-section-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .wd-task-section-scroll::-webkit-scrollbar-track {
            background: #f3f4f6;
            border-radius: 3px;
        }

        .wd-task-section-scroll::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 3px;
        }

            .wd-task-section-scroll::-webkit-scrollbar-thumb:hover {
                background: #9ca3af;
            }

</style>

@* --- HTML STRUCTURE --- *@
<div class="wd-page-wrapper wd-container">
    <div class="wd-header-bar">
        <div class="wd-flex wd-items-center wd-justify-between">
            <div>
                <h1 class="wd-text-2xl wd-font-bold wd-text-gray-800" style="font-size: 24px;
    font-weight: 600;
    margin-bottom: 5px;">
                    Dashboard Quản Lý Kho
                </h1>
                <p class="wd-text-sm wd-text-gray-500 wd-mt-1" id="wd-current-date">
                    Đang tải...
                </p>
            </div>
        </div>
    </div>

    <div class="wd-padding-8">
        <div class="wd-grid-3-col wd-gap-6 wd-mb-8">
            <!-- XÓA CARD TỔNG GIÁ TRỊ KHO -->
            <!-- Card 1: mặt hàng Sắp Hết -->
            <div class="wd-kpi-card wd-hover-shadow-md">
                <div class="wd-flex wd-items-start wd-justify-between wd-mb-4">
                    <div class="wd-kpi-card-icon-wrapper wd-icon-bg-orange">
                        <svg class="wd-text-white" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                    </div>
                    <span class="wd-text-xs wd-text-orange-600 wd-bg-orange-50 wd-px-2 wd-py-1 wd-rounded-full wd-font-medium">Cần chú ý</span>
                </div>
                <p class="wd-text-gray-500 wd-text-sm wd-mb-1">mặt hàng Sắp Hết</p>
                <h3 class="wd-text-3xl wd-font-bold wd-text-orange-600" id="kpi-low-stock">...</h3>
            </div>

            <!-- Card 2: Lô Sắp Hết Hạn -->
            <div class="wd-kpi-card wd-hover-shadow-md">
                <div class="wd-flex wd-items-start wd-justify-between wd-mb-4">
                    <div class="wd-kpi-card-icon-wrapper wd-icon-bg-red">
                        <svg class="wd-text-white" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    </div>
                    <span class="wd-text-xs wd-text-red-600 wd-bg-red-50 wd-px-2 wd-py-1 wd-rounded-full wd-font-medium">Khẩn cấp</span>
                </div>
                <p class="wd-text-gray-500 wd-text-sm wd-mb-1">Lô Sắp Hết Hạn</p>
                <h3 class="wd-text-3xl wd-font-bold wd-text-red-600" id="kpi-expiring-batches">...</h3>
            </div>

            <!-- Card 3: Đơn Chờ Xử Lý -->
            <div class="wd-kpi-card wd-hover-shadow-md">
                <div class="wd-flex wd-items-start wd-justify-between wd-mb-4">
                    <div class="wd-kpi-card-icon-wrapper wd-icon-bg-purple">
                        <svg class="wd-text-white" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                    <span class="wd-text-xs wd-text-purple-600 wd-bg-purple-50 wd-px-2 wd-py-1 wd-rounded-full wd-font-medium">Đang chờ</span>
                </div>
                <p class="wd-text-gray-500 wd-text-sm wd-mb-1">Đơn Chờ Xử Lý</p>
                <h3 class="wd-text-3xl wd-font-bold wd-text-purple-600" id="kpi-pending-orders">...</h3>
            </div>
        </div>

        @* Main Content - 2 Column Layout *@
        <div class="wd-two-col-layout">
            @* Left Column *@
            <div class="wd-space-y-6">
                @* Tasks Panel *@
                <div class="wd-bg-white wd-rounded-xl wd-shadow-sm wd-border wd-border-gray-100">
                    <div class="wd-task-panel-header">
                        <h2 class="wd-text-lg wd-font-bold wd-text-gray-800 wd-flex wd-items-center">
                            <svg class="wd-mr-2 wd-text-purple-500" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                            Công Việc Cần Xử Lý
                        </h2>
                    </div>
                    <div class="wd-task-grid" id="wd-pending-tasks"></div>
                </div>

                @* Bottom Left Grid *@
                <div class="wd-grid-2-col wd-gap-6">
                    

                    
                </div>
            </div>

            @* Right Column *@
            <div class="wd-space-y-6">
                @* Alerts *@
                <div class="wd-bg-white wd-rounded-xl wd-shadow-sm wd-border wd-border-gray-100">
                    <div class="wd-task-panel-header">
                        <h2 class="wd-text-lg wd-font-bold wd-text-gray-800 wd-flex wd-items-center">
                            <svg class="wd-mr-2 wd-text-orange-500" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                            Cảnh Báo Ưu Tiên
                        </h2>
                    </div>
                    <div class="wd-alerts-list" id="wd-alerts-list"></div>
                </div>

                @* Quick Access *@
                <div class="wd-bg-white wd-rounded-xl wd-shadow-sm wd-border wd-border-gray-100">
                    <div class="wd-task-panel-header">
                        <h2 class="wd-text-lg wd-font-bold wd-text-gray-800">Truy Cập Nhanh</h2>
                    </div>
                    <div class="wd-padding-4 wd-grid-2-col wd-gap-3">
                        <button class="wd-action-btn-quick green" onclick="window.location.href='/ImportInventory'">
                            <div class="wd-bg-green-600 wd-p-2 wd-rounded-lg wd-mb-2 wd-scale-110">
                                <svg class="wd-text-white" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14m-7-7h14"></path></svg>
                            </div>
                            <span class="wd-text-xs wd-font-semibold wd-text-gray-700">Tạo Đơn Nhập</span>
                        </button>
                        <button class="wd-action-btn-quick gray" onclick="window.location.href='/ManagerIngredent/DisplayIngredent'">
                            <div class="wd-bg-gray-600 wd-p-2 wd-rounded-lg wd-mb-2 wd-scale-110">
                                <svg class="wd-text-white" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2z"></path></svg>
                            </div>
                            <span class="wd-text-xs wd-font-semibold wd-text-gray-700">Quản lý mặt hàng</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {

        // ===== Utility Functions =====
        const $ = selector => document.querySelector(selector);

        // ====================================================================
        // ===== I. LẤY DỮ LIỆU TỪ SERVER =====
        // ====================================================================

        let ingredientList = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Ingredients));
        let purchaseOrders = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.PurchaseOrders));
        let auditInventories = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.AuditInventories));

        console.log('=== LOADED DATA ===');
        console.log('Ingredients:', ingredientList.length);
        console.log('Purchase Orders:', purchaseOrders.length);
        console.log('Audits:', auditInventories.length);

        // ====================================================================
        // ===== II. TÍNH TOÁN KPI =====
        // ====================================================================

        function calculateKPIs() {
            // 1. Số mặt hàng sắp hết
            const lowStockCount = ingredientList.filter(ing =>
                ing.ReorderLevel != null &&
                ing.TotalQuantity < ing.ReorderLevel
            ).length;

            // 2. Số lô sắp hết hạn - DÙNG ExpiringSoonBatchCount có sẵn
            const expiringSoonBatchCount = ingredientList.reduce((sum, ing) => {
                return sum + (ing.ExpiringSoonBatchCount || 0);
            }, 0);

            // 3. Đơn chờ xử lý
            const processingPurchase = purchaseOrders.filter(po =>
                po.Status && po.Status.trim() === 'Processing'
            ).length;

            const processingAudits = auditInventories.filter(audit =>
                audit.AuditStatus && audit.AuditStatus.trim() === 'processing'
            ).length;

            const totalPendingOrders = processingPurchase + processingAudits;

            console.log('KPIs:', {
                lowStockCount,
                expiringSoonBatchCount,
                processingPurchase,
                processingAudits,
                totalPendingOrders
            });

            return {
                lowStockCount,
                expiringSoonBatchCount,
                totalPendingOrders
            };
        }

        // ===== IV. LẤY DANH SÁCH ĐƠN PROCESSING =====


        function getProcessingOrders() {
            const processingPurchase = purchaseOrders
                .filter(po => po.Status && po.Status.trim() === 'Processing')
                .map(po => {
                    const orderDate = po.OrderDate ? new Date(po.OrderDate) : new Date();
                    return {
                        id: po.PurchaseOrderId,
                        type: 'import',
                        supplier: po.Supplier?.Name || 'N/A',
                        itemCount: po.PurchaseOrderDetails?.length || 0,
                        orderDate: orderDate.toLocaleDateString('vi-VN'),
                        time: orderDate.toLocaleString('vi-VN', {
                            hour: '2-digit',
                            minute: '2-digit',
                            day: '2-digit',
                            month: '2-digit',
                            year: 'numeric'
                        })

                    };
                });

            const processingAudit = auditInventories
                .filter(audit => audit.AuditStatus && audit.AuditStatus.trim() === 'processing')
                .map(audit => {
                    const createdDate = audit.CreatedAt ? new Date(audit.CreatedAt) : new Date();
                    return {
                        id: audit.AuditId,
                        type: 'inventory',
                        ingredientName: audit.IngredientName,
                        quantity: `${audit.AdjustmentQuantity} ${audit.Unit}`,
                        createdDate: createdDate.toLocaleDateString('vi-VN'),
                        time: createdDate.toLocaleString('vi-VN', {
                            hour: '2-digit',
                            minute: '2-digit',
                            day: '2-digit',
                            month: '2-digit',
                            year: 'numeric'
                        })
                    };
                });

            return {
                purchaseOrders: processingPurchase,
                auditOrders: processingAudit
            };
        }

        // ====================================================================
        // ===== V. LẤY DANH SÁCH CẢNH BÁO =====
        // ====================================================================

        function getLowStockAlerts() {
            const alerts = ingredientList
                .filter(ing =>
                    ing.ReorderLevel != null &&
                    ing.TotalQuantity < ing.ReorderLevel
                )
                .map(ing => ({
                    id: ing.IngredientId,
                    code: ing.IngredientCode,
                    name: ing.Name,
                    currentQuantity: ing.TotalQuantity,
                    reorderLevel: ing.ReorderLevel,
                    unit: ing.Unit?.Name || '',
                    urgent: ing.TotalQuantity < (ing.ReorderLevel / 2)
                }))
                .sort((a, b) => {
                    if (a.urgent && !b.urgent) return -1;
                    if (!a.urgent && b.urgent) return 1;
                    const aPercent = a.currentQuantity / a.reorderLevel;
                    const bPercent = b.currentQuantity / b.reorderLevel;
                    return aPercent - bPercent;
                });

            console.log('Low stock alerts:', alerts.length);
            return alerts;
        }

        // ====================================================================
        // ===== VI. RENDER FUNCTIONS =====
        // ====================================================================

        function renderKpiCards() {
            const kpis = calculateKPIs();

            $('#kpi-low-stock').innerHTML = kpis.lowStockCount + ' <span class="wd-text-lg wd-text-gray-400">món</span>';
            $('#kpi-expiring-batches').innerHTML = kpis.expiringSoonBatchCount + ' <span class="wd-text-lg wd-text-gray-400">lô</span>';
            $('#kpi-pending-orders').innerHTML = kpis.totalPendingOrders + ' <span class="wd-text-lg wd-text-gray-400">đơn</span>';
        }

        function renderPendingTasks() {
            const container = $('#wd-pending-tasks');
            const orders = getProcessingOrders();

            const importHtml = `
            <div>
                <div class="wd-flex wd-items-center wd-justify-between wd-mb-4">
                    <h3 class="wd-font-semibold wd-text-gray-700 wd-flex wd-items-center wd-text-sm">
                        <div class="wd-w-2 wd-h-2 wd-bg-green-500 wd-rounded-full wd-mr-2"></div> Đơn Nhập
                    </h3>
                    <span class="wd-bg-green-100 wd-text-green-700 wd-text-xs wd-px-2 wd-py-1 wd-rounded-full wd-font-semibold">${orders.purchaseOrders.length}</span>
                </div>
                <div class="wd-task-section-scroll">
                    <div class="wd-space-y-3">
                        ${orders.purchaseOrders.length === 0
                    ? '<p class="wd-text-xs wd-text-gray-400 wd-text-center wd-py-4">Không có đơn đang xử lý</p>'
                    : orders.purchaseOrders.map(order => `
                    <div class="wd-task-item import" onclick="window.location.href='/DetailImport/Detail/${order.id}'">
                        <div class="wd-flex wd-justify-between wd-items-start wd-mb-2">
                            <span class="wd-font-bold wd-text-sm wd-text-gray-800">${order.id}</span>
                            <span class="wd-tag-priority wd-tag-pending">Đang xử lý</span>
                        </div>
                        <p class="wd-text-xs wd-text-gray-700 wd-font-medium wd-mb-1">${order.supplier}</p>
                        <p class="wd-text-xs wd-text-gray-500">${order.itemCount} món • ${order.time}</p>
                    </div>
                `).join('')
                }
                    </div>
                </div>
            </div>
        `;

            const inventoryHtml = `
            <div>
                <div class="wd-flex wd-items-center wd-justify-between wd-mb-4">
                    <h3 class="wd-font-semibold wd-text-gray-700 wd-flex wd-items-center wd-text-sm">
                        <div class="wd-w-2 wd-h-2 wd-bg-purple-500 wd-rounded-full wd-mr-2"></div> Kiểm Kê
                    </h3>
                    <span class="wd-bg-purple-100 wd-text-purple-700 wd-text-xs wd-px-2 wd-py-1 wd-rounded-full wd-font-semibold">${orders.auditOrders.length}</span>
                </div>
                <div class="wd-task-section-scroll">
                    <div class="wd-space-y-3">
                        ${orders.auditOrders.length === 0
                    ? '<p class="wd-text-xs wd-text-gray-400 wd-text-center wd-py-4">Không có đơn đang xử lý</p>'
                    : orders.auditOrders.map(order => `
                    <div class="wd-task-item inventory">
                        <div class="wd-flex wd-justify-between wd-items-start wd-mb-2">
                            <span class="wd-font-bold wd-text-sm wd-text-gray-800">${order.id}</span>
                            <span class="wd-tag-priority wd-tag-pending">Đang xử lý</span>
                        </div>
                        <p class="wd-text-xs wd-text-gray-700 wd-font-medium wd-mb-1">${order.ingredientName}</p>
                        <p class="wd-text-xs wd-text-gray-500">${order.quantity} • ${order.time}</p>
                    </div>
                `).join('')
                }
                    </div>
                </div>
            </div>
        `;

            container.innerHTML = importHtml + inventoryHtml;
        }

        function renderAlerts() {
            const container = $('#wd-alerts-list');
            const alerts = getLowStockAlerts();

            if (alerts.length === 0) {
                container.innerHTML = '<p class="wd-text-center wd-text-gray-400 wd-py-8">Không có cảnh báo</p>';
                return;
            }

            const html = alerts.map(alert => `
                    <div class="wd-alert-item ${alert.urgent ? 'wd-alert-urgent-low' : 'wd-alert-normal'}">
                        <div class="wd-flex wd-justify-between wd-items-start wd-mb-2">
                            <h4 class="wd-font-bold wd-text-gray-800 wd-text-sm">${alert.name}</h4>
                            ${alert.urgent ? '<span class="wd-tag-priority wd-tag-high">Gấp</span>' : ''}
                        </div>
                        <div class="wd-space-y-1">
                            <p class="wd-text-sm wd-text-gray-700">
                                Còn: <span class="wd-font-bold">${alert.currentQuantity.toFixed(2)} ${alert.unit}</span>
                            </p>
                            <p class="wd-text-xs wd-text-gray-600">Tối thiểu: ${alert.reorderLevel.toFixed(2)} ${alert.unit}</p>
                            <p class="wd-text-xs wd-text-red-600">⚠ Cần nhập thêm: ${(alert.reorderLevel - alert.currentQuantity).toFixed(2)} ${alert.unit}</p>
                        </div>
                    </div>
                `).join('');

            container.innerHTML = html;
        }


        // ====================================================================
        // ===== VII. INITIALIZATION =====
        // ====================================================================

        function initializeDashboard() {
            const currentDate = new Date().toLocaleDateString('vi-VN', {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });
            $('#wd-current-date').textContent = currentDate;

            renderKpiCards();
            renderPendingTasks();
            renderAlerts();
        }

        initializeDashboard();
    });
</script>