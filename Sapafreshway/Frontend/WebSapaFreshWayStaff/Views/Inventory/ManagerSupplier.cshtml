            /** Quay lại danh sách nhà cung cấp */
            window.goToSupplierList = function () {
                setState({ activeTab: 'list', selectedSupplier: null });
            }

            // Sự kiện Tìm kiếm (Search)
            $('#sm-supplier-search-input').addEventListener('input', (e) => {
                setState({ searchTerm: e.target.value });
            });

            // Sự kiện Modal (Thêm nhà cung cấp)
            $('#sm-add-supplier-btn').addEventListener('click', () => {
                // Reset form
                $('#add-code').value = '';
                $('#add-name').value = '';
                $('#add-contact').value = '';
                $('#add-phone').value = '';
                $('#add-email').value = '';
                $('#add-address').value = '';

                setState({ showAddModal: true });
            });

            $('#sm-modal-cancel-btn').addEventListener('click', () => {
                setState({ showAddModal: false });
            });

            $('#sm-modal-save-btn').addEventListener('click', async () => {
                const data = {
                    code: $('#add-code').value.trim(),
                    name: $('#add-name').value.trim(),
                    contact: $('#add-contact').value.trim(),
                    phone: $('#add-phone').value.trim(),
                    email: $('#add-email').value.trim(),
                    address: $('#add-address').value.trim()
                };

                // Validate
                const validation = validateSupplierForm(data, false);
                if (!validation.isValid) {
                    validation.errors.forEach((error, index) => {
                        setTimeout(() => {
                            showToast('error', 'Lỗi xác thực', error);
                        }, index * 300); // Hiển thị lần lượt
                    });
                    return;
                }

                try {
                    // Hiển thị loading (optional)
                    const saveBtn = $('#sm-modal-save-btn');
                    const originalText = saveBtn.textContent;
                    saveBtn.textContent = 'Đang lưu...';
                    saveBtn.disabled = true;

                    const response = await fetch(ENDPOINTS.CREATE_SUPPLIER, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            CodeSupplier: data.code,
                            Name: data.name,
                            ContactInfo: data.contact,
                            Phone: data.phone,
                            Email: data.email,
                            Address: data.address
                        })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        showToast('success', 'Thành công', 'Thêm nhà cung cấp thành công!');
                        setState({ showAddModal: false });

                        // Reset form
                        $('#add-code').value = '';
                        $('#add-name').value = '';
                        $('#add-contact').value = '';
                        $('#add-phone').value = '';
                        $('#add-email').value = '';
                        $('#add-address').value = '';

                        // Reload data
                        fetchAndInitializeData();
                    } else {
                        showToast('error', 'Lỗi', result.message || 'Không thể thêm nhà cung cấp');
                    }

                    // Reset button
                    saveBtn.textContent = originalText;
                    saveBtn.disabled = false;

                } catch (error) {
                    console.error('Error creating supplier:', error);
                    showToast('error', 'Lỗi kết nối', 'Không thể kết nối đến máy chủ');

                    // Reset button
                    const saveBtn = $('#sm-modal-save-btn');
                    saveBtn.textContent = 'Lưu';
                    saveBtn.disabled = false;
                }
            });

            // Đóng modal khi click ra ngoài overlay
            $('#sm-add-modal').addEventListener('click', (e) => {
                if (e.target.id === 'sm-add-modal') {
                    setState({ showAddModal: false });
                }
            });

            // ===== INITIALIZATION (Khởi tạo) =====
            fetchAndInitializeData();


            /** Render chi tiết đơn hàng - LAZY LOADING */
            window.renderOrderDetails = async function (order) {
                try {
                    // Fetch dữ liệu từ API
                    const details = await fetchData(`/ManagerSupplier/OrderDetails/${order.id}`);

                    if (!details || !details.purchaseOrderDetails || details.purchaseOrderDetails.length === 0) {
                        return '<p style="text-align: center; color: #9ca3af; padding: 20px;">Không có dữ liệu chi tiết</p>';
                    }

                    const items = details.purchaseOrderDetails;

                    // ✅ LẤY DỮ LIỆU TRỰC TIẾP TỪ item, KHÔNG QUA item.ingredient
                    const itemsHtml = items.map(item => `
                    <tr>
                        <td>
                            <div style="font-weight: 500;">${item.ingredientName || 'N/A'}</div>
                            <div style="font-size: 12px; color: #6b7280; margin-top: 2px;">Mã: ${item.ingredientCode || 'N/A'}</div>
                        </td>
                        <td>${item.quantity} ${item.unit || ''}</td>
                        <td>${formatCurrency(item.unitPrice)} đ</td>
                        <td style="font-weight: 500;">${formatCurrency(item.subtotal)} đ</td>
                    </tr>
                `).join('');

                    const total = items.reduce((sum, item) => sum + (item.subtotal || 0), 0);

                    return `
                    <table class="sm-details-table">
                        <thead>
                            <tr>
                                <th>Tên sản phẩm</th>
                                <th>Số lượng</th>
                                <th>Đơn giá</th>
                                <th style="text-align: right;">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${itemsHtml}
                        </tbody>
                    </table>
                    <div class="sm-details-summary">
                        <div class="sm-summary-item">
                            <span class="sm-summary-label">Tổng cộng:</span>
                            <span class="sm-summary-value sm-summary-total">${formatCurrency(total)} đ</span>
                        </div>
                    </div>
                `;
                } catch (error) {
                    console.error('Error rendering order details:', error);
                    return '<p style="text-align: center; color: #dc2626; padding: 20px;">Lỗi khi tải chi tiết đơn hàng</p>';
                }
            }

            /** Toggle hiển thị chi tiết đơn hàng */
            window.toggleOrderDetails = async function (orderId) {
                const detailsRow = document.getElementById(`details-${orderId}`);
                const icon = document.getElementById(`icon-${orderId}`);
                const contentDiv = detailsRow?.querySelector('.sm-order-details-content');

                if (!detailsRow || !icon) return;

                if (detailsRow.classList.contains('expanded')) {
                    // Collapse
                    detailsRow.classList.remove('expanded');
                    icon.classList.remove('rotated');
                } else {
                    // Đóng tất cả row khác
                    document.querySelectorAll('.sm-order-details-row.expanded').forEach(row => {
                        row.classList.remove('expanded');
                    });
                    document.querySelectorAll('.sm-expand-icon.rotated').forEach(ic => {
                        ic.classList.remove('rotated');
                    });

                    // Mở row hiện tại
                    detailsRow.classList.add('expanded');
                    icon.classList.add('rotated');

                    // Load details nếu chưa load
                    if (contentDiv && !contentDiv.dataset.loaded) {
                        contentDiv.innerHTML = '<p style="text-align:center; padding:20px; color: #6b7280;">⏳ Đang tải...</p>';

                        const order = state.orderHistory.find(o => o.id === orderId);
                        if (order) {
                            const detailsHtml = await window.renderOrderDetails(order);
                            contentDiv.innerHTML = `
                                        <div class="sm-details-header">Chi tiết đơn hàng #${orderId}</div>
                                        ${detailsHtml}
                                    `;
                            contentDiv.dataset.loaded = 'true';
                        }
                    }
                }
            }

            // ===== HELPER FUNCTIONS FOR HIGHLIGHTING =====

            window.viewSupplierDetail = function (supplierId) {
                const supplier = window.SUPPLIERS_DATA.find(s => s.id === supplierId);
                if (supplier) {
                    setState({
                        activeTab: 'detail',
                        selectedSupplier: supplier,
                        detailSubTab: 'orders',
                        orderHistory: null,
                        ingredients: null
                    });
                }
            }

            window.highlightSupplierByCode = function (code) {
                // Scroll to supplier card
                const card = document.querySelector(`[data-supplier-id]`);
                const allCards = document.querySelectorAll('.sm-supplier-card');

                allCards.forEach(c => c.classList.remove('highlighted'));

                const targetSupplier = window.SUPPLIERS_DATA.find(s => s.code === code);
                if (targetSupplier) {
                    const targetCard = document.querySelector(`[data-supplier-id="${targetSupplier.id}"]`);
                    if (targetCard) {
                        targetCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        targetCard.classList.add('highlighted');

                        // Remove highlight sau 3s
                        setTimeout(() => {
                            targetCard.classList.remove('highlighted');
                        }, 3000);
                    }
                }
            }

            window.highlightSupplierByName = function (name) {
                const allCards = document.querySelectorAll('.sm-supplier-card');
                allCards.forEach(c => c.classList.remove('highlighted'));

                const targetSupplier = window.SUPPLIERS_DATA.find(s => s.name === name);
                if (targetSupplier) {
                    const targetCard = document.querySelector(`[data-supplier-id="${targetSupplier.id}"]`);
                    if (targetCard) {
                        targetCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        targetCard.classList.add('highlighted');

                        setTimeout(() => {
                            targetCard.classList.remove('highlighted');
                        }, 3000);
                    }
                }
            }

            // ===== EDIT SUPPLIER FUNCTIONS =====

            window.editSupplier = function (supplierId) {
                const supplier = window.SUPPLIERS_DATA.find(s => s.id === supplierId);

                if (!supplier) {
                    showToast('error', 'Lỗi', 'Không tìm thấy nhà cung cấp');
                    return;
                }

                // Fill form
                $('#edit-code').value = supplier.code;
                $('#edit-name').value = supplier.name;
                $('#edit-contact').value = supplier.contact || '';
                $('#edit-phone').value = supplier.phone || '';
                $('#edit-email').value = supplier.email || '';
                $('#edit-address').value = supplier.address || '';

                setState({
                    showEditModal: true,
                    editingSupplierId: supplierId
                });
            }

            // Event listeners cho modal edit
            const editCancelBtn = $('#sm-edit-modal-cancel-btn');
            if (editCancelBtn) {
                editCancelBtn.addEventListener('click', () => {
                    setState({ showEditModal: false, editingSupplierId: null });
                });
            }

            const editSaveBtn = $('#sm-edit-modal-save-btn');
            if (editSaveBtn) {
                editSaveBtn.addEventListener('click', async () => {
                    const data = {
                        name: $('#edit-name').value.trim(),
                        contact: $('#edit-contact').value.trim(),
                        phone: $('#edit-phone').value.trim(),
                        email: $('#edit-email').value.trim(),
                        address: $('#edit-address').value.trim()
                    };

                    // Validate
                    const validation = validateSupplierForm(data, true);
                    if (!validation.isValid) {
                        validation.errors.forEach((error, index) => {
                            setTimeout(() => {
                                showToast('error', 'Lỗi xác thực', error);
                            }, index * 300);
                        });
                        return;
                    }

                    try {
                        // Hiển thị loading
                        const saveBtn = $('#sm-edit-modal-save-btn');
                        const originalText = saveBtn.textContent;
                        saveBtn.textContent = 'Đang cập nhật...';
                        saveBtn.disabled = true;

                        const response = await fetch(ENDPOINTS.UPDATE_SUPPLIER(state.editingSupplierId), {
                            method: 'PUT',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                Name: data.name,
                                ContactInfo: data.contact,
                                Phone: data.phone,
                                Email: data.email,
                                Address: data.address
                            })
                        });

                        const result = await response.json();

                        if (response.ok) {
                            showToast('success', 'Thành công', 'Cập nhật nhà cung cấp thành công!');
                            setState({ showEditModal: false, editingSupplierId: null });
                            fetchAndInitializeData();
                        } else {
                            showToast('error', 'Lỗi', result.message || 'Không thể cập nhật nhà cung cấp');
                        }

                        // Reset button
                        saveBtn.textContent = originalText;
                        saveBtn.disabled = false;

                    } catch (error) {
                        console.error('Error updating supplier:', error);
                        showToast('error', 'Lỗi kết nối', 'Không thể kết nối đến máy chủ');

                        // Reset button
                        const saveBtn = $('#sm-edit-modal-save-btn');
                        saveBtn.textContent = 'Cập nhật';
                        saveBtn.disabled = false;
                    }


                });
            }

            // ✅ VALIDATE REAL-TIME CHO PHONE
            const addPhoneInput = $('#add-phone');
            if (addPhoneInput) {
                addPhoneInput.addEventListener('input', (e) => {
                    const phone = e.target.value;
                    if (phone && !validatePhone(phone)) {
                        e.target.style.borderColor = '#dc2626';
                    } else {
                        e.target.style.borderColor = '#d1d5db';
                    }
                });
            }

            const editPhoneInput = $('#edit-phone');
            if (editPhoneInput) {
                editPhoneInput.addEventListener('input', (e) => {
                    const phone = e.target.value;
                    if (phone && !validatePhone(phone)) {
                        e.target.style.borderColor = '#dc2626';
                    } else {
                        e.target.style.borderColor = '#d1d5db';
                    }
                });
            }

            // ✅ VALIDATE REAL-TIME CHO EMAIL
            const addEmailInput = $('#add-email');
            if (addEmailInput) {
                addEmailInput.addEventListener('input', (e) => {
                    const email = e.target.value;
                    if (email && !validateEmail(email)) {
                        e.target.style.borderColor = '#dc2626';
                    } else {
                        e.target.style.borderColor = '#d1d5db';
                    }
                });
            }

            const editEmailInput = $('#edit-email');
            if (editEmailInput) {
                editEmailInput.addEventListener('input', (e) => {
                    const email = e.target.value;
                    if (email && !validateEmail(email)) {
                        e.target.style.borderColor = '#dc2626';
                    } else {
                        e.target.style.borderColor = '#d1d5db';
                    }
                });
            }

        });


    </script>
</body>
</html>