@{
    Layout = "_LayoutInventory";
    ViewData["Title"] = "Quản Lý Nhà Cung Cấp";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Nhà cung cấp</title>
    <style>

/* ===== BASE STYLES & RESET ===== */
.sm-container * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

.sm-page-wrapper {
    /* min-h-screen bg-gray-50 p-6 */
    min-height: 100vh;
    background-color: #f9fafb;
    padding: 24px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    color: #1f2937; /* text-gray-800 */
}

/* ===== TYPOGRAPHY & HEADER ===== */
.sm-space-y-6 > * + * {
    margin-top: 24px; /* space-y-6 */
}

.sm-header-area {
    /* mb-6 */
    margin-bottom: 24px;
}

.sm-title {
    /* text-3xl font-bold text-gray-900 */
    font-size: 30px;
    font-weight: 700;
    color: #111827;
}

.sm-subtitle {
    /* text-gray-600 mt-1 */
    color: #4b5563;
    margin-top: 4px;
}

/* ===== STATS CARDS (QUICK STATS) ===== */
.sm-stats-grid {
    /* grid grid-cols-4 gap-4 */
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
}

.sm-stat-card {
    /* bg-white border rounded-lg p-5 */
    background-color: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 20px;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.sm-card-header {
    /* flex items-center justify-between mb-3 */
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
}

.sm-card-label {
    /* text-sm text-gray-600 font-medium */
    font-size: 14px;
    color: #4b5563;
    font-weight: 500;
}

.sm-card-icon {
    /* w-5 h-5 text-blue-600 */
    width: 20px;
    height: 20px;
}

.sm-icon-blue { color: #2563eb; }
.sm-icon-green { color: #10b981; }
.sm-icon-orange { color: #f97316; }
.sm-icon-purple { color: #9333ea; }
.sm-icon-red { color: #dc2626; }
.sm-icon-gray { color: #4b5563; }

.sm-stat-value {
    /* text-3xl font-bold */
    font-size: 30px;
    font-weight: 700;
    color: #111827;
}

.sm-stat-value.sm-green { color: #10b981; }
.sm-stat-value.sm-orange { color: #f97316; }
.sm-stat-value.sm-purple { color: #9333ea; }

.sm-stat-subtext {
    /* text-xs text-gray-500 mt-2 */
    font-size: 12px;
    color: #6b7280;
    margin-top: 8px;
}

.sm-stat-subtext.sm-green { color: #10b981; }

.sm-status-dot {
    /* w-3 h-3 bg-green-500 rounded-full */
    width: 12px;
    height: 12px;
    background-color: #10b981;
    border-radius: 50%;
}

/* ===== TWO COLUMN LAYOUT (Recent & Top) ===== */
.sm-two-col-grid {
    /* grid grid-cols-2 gap-6 */
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
}

.sm-panel {
    /* bg-white border rounded-lg */
    background-color: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
}

.sm-panel-header {
    /* p-4 border-b */
    padding: 16px;
    border-bottom: 1px solid #e5e7eb;
}

.sm-panel-header.sm-flex-between {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.sm-panel-title {
    /* font-semibold flex items-center gap-2 */
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
}

.sm-panel-title svg {
    /* w-5 h-5 text-gray-600 */
    width: 20px;
    height: 20px;
    color: #4b5563;
}

.sm-select {
    /* text-sm border rounded px-2 py-1 */
    font-size: 14px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 4px 8px;
    background-color: white;
    cursor: pointer;
}

.sm-select:focus {
    outline: 2px solid transparent;
    outline-offset: 2px;
    box-shadow: 0 0 0 2px #3b82f6; /* focus:ring-2 focus:ring-blue-500 */
}

/* List/Transaction Items */
.sm-divide-y > * + * {
    border-top: 1px solid #e5e7eb;
}

.sm-list-item {
    /* p-4 hover:bg-gray-50 */
    padding: 16px;
    transition: background-color 0.2s;
    cursor: pointer;
}

.sm-list-item:hover {
    background-color: #f9fafb;
}

.sm-flex-start-between {
    /* flex justify-between items-start mb-1 */
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
}

.sm-item-name {
    /* font-medium text-sm */
    font-size: 14px;
    font-weight: 500;
}

.sm-item-value {
    /* text-sm font-semibold text-green-600 */
    font-size: 14px;
    font-weight: 600;
    color: #10b981;
}

.sm-item-subtext {
    /* text-xs text-gray-500 */
    font-size: 12px;
    color: #6b7280;
}

.sm-panel-footer {
    /* p-3 border-t text-center */
    padding: 12px;
    border-top: 1px solid #e5e7eb;
    text-align: center;
}

.sm-footer-btn {
    /* text-blue-600 hover:text-blue-700 text-sm font-medium */
    color: #2563eb;
    font-size: 14px;
    font-weight: 500;
    background: none;
    border: none;
    cursor: pointer;
}

.sm-footer-btn:hover {
    color: #1d4ed8;
}

/* Top Suppliers Ranking */
.sm-rank-content {
    /* flex items-center gap-3 */
    display: flex;
    align-items: center;
    gap: 12px;
}

.sm-rank-badge {
    /* w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm */
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
}

.sm-rank-badge.rank-1 { /* bg-yellow-100 text-yellow-700 */
    background-color: #fef9c3;
    color: #b45309;
}

.sm-rank-badge.rank-2 { /* bg-gray-100 text-gray-700 */
    background-color: #f3f4f6;
    color: #374151;
}

.sm-rank-badge.rank-3 { /* bg-orange-100 text-orange-700 */
    background-color: #ffedd5;
    color: #c2410c;
}

.sm-rank-info {
    /* flex-1 */
    flex-grow: 1;
}

/* ===== SUPPLIER LIST HEADER & ACTIONS ===== */
.sm-list-controls {
    /* flex justify-between items-center */
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
}

.sm-list-title-h3 {
    /* text-lg font-semibold */
    font-size: 18px;
    font-weight: 600;
}

.sm-action-group {
    /* flex gap-3 */
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
}

/* Search Input */
.sm-search-wrapper {
    /* relative */
    position: relative;
}

.sm-search-icon {
    /* absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-5 h-5 */
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #9ca3af;
    width: 20px;
    height: 20px;
    pointer-events: none;
}

.sm-search-input {
    /* pl-10 pr-4 py-2 border rounded-lg w-64 */
    padding: 8px 16px 8px 40px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 14px;
    width: 256px;
    background-color: white;
    transition: all 0.2s;
}

.sm-search-input:focus {
    /* focus:ring-2 focus:ring-blue-500 focus:border-transparent */
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 2px #3b82f6;
}

/* Filter Select */
.sm-filter-select {
    /* px-4 py-2 border rounded-lg */
    padding: 8px 16px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 14px;
    background-color: white;
    cursor: pointer;
    transition: all 0.2s;
}

.sm-filter-select:focus {
    /* focus:ring-2 focus:ring-blue-500 */
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 2px #3b82f6;
}

/* Add Button */
.sm-add-btn {
    /* flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 */
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background-color: #2563eb;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;
}

.sm-add-btn:hover {
    background-color: #1d4ed8;
}

.sm-add-btn svg {
    /* w-5 h-5 */
    width: 20px;
    height: 20px;
}

/* ===== SUPPLIER CARDS (LIST) ===== */
.sm-supplier-cards-grid {
    /* grid gap-4 (Changed from grid-gap to gap for compatibility) */
    display: grid;
    gap: 16px;
}

.sm-supplier-card {
    /* bg-white border rounded-lg p-6 hover:shadow-md transition-shadow */
    background-color: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 24px;
    transition: box-shadow 0.3s;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
}

.sm-supplier-card:hover {
    /* hover:shadow-md */
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.sm-card-content-wrapper {
    /* flex justify-between items-start */
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}

.sm-card-main-info {
    /* flex-1 */
    flex-grow: 1;
    min-width: 0;
}

.sm-card-title-group {
    /* flex items-center gap-3 mb-2 */
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
}

.sm-card-title-h3 {
    /* text-lg font-semibold */
    font-size: 18px;
    font-weight: 600;
}

.sm-card-code {
    /* text-sm text-gray-500 */
    font-size: 14px;
    color: #6b7280;
}

.sm-status-tag {
    /* px-3 py-1 rounded-full text-xs font-medium */
    padding: 4px 12px;
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
}

.sm-tag-active {
    /* bg-green-100 text-green-700 */
    background-color: #d1fae5;
    color: #047857;
}

.sm-tag-inactive {
    /* bg-gray-100 text-gray-700 */
    background-color: #f3f4f6;
    color: #374151;
}

.sm-contact-grid {
    /* grid grid-cols-2 gap-4 mb-4 text-sm text-gray-600 */
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 16px;
    font-size: 14px;
    color: #4b5563;
}

.sm-contact-grid p span {
    font-weight: 500; /* strong */
}

.sm-stats-footer {
    /* flex gap-6 text-sm */
    display: flex;
    gap: 24px;
    font-size: 14px;
}

.sm-stat-item {
    /* flex items-center gap-2 */
    display: flex;
    align-items: center;
    gap: 8px;
}

.sm-stat-item svg {
    /* w-4 h-4 text-blue-500/text-green-500 */
    width: 16px;
    height: 16px;
}

.sm-stat-item.sm-blue svg { color: #3b82f6; }
.sm-stat-item.sm-green svg { color: #10b981; }

.sm-action-buttons {
    /* flex gap-2 */
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}

.sm-action-btn {
    /* p-2 text-blue-600 hover:bg-blue-50 rounded-lg */
    padding: 8px;
    border: none;
    background: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.2s;
    line-height: 1; /* fix alignment for icons */
}

.sm-action-btn svg {
    /* w-5 h-5 */
    width: 20px;
    height: 20px;
}

.sm-action-btn:hover {
    background-color: #eff6ff; /* blue-50 */
}

.sm-btn-view { color: #2563eb; }

.sm-btn-edit { color: #4b5563; }
.sm-btn-edit:hover { background-color: #f3f4f6; }

.sm-btn-power.active { /* Tạm ngưng (active supplier) */
    color: #f97316;
}

.sm-btn-power.inactive { /* Kích hoạt (inactive supplier) */
    color: #10b981;
}

.sm-btn-power.active:hover { background-color: #fff7ed; } /* orange-50 */
.sm-btn-power.inactive:hover { background-color: #ecfdf5; } /* green-50 */

.sm-btn-delete {
    /* text-red-600 hover:bg-red-50 */
    color: #dc2626;
}

.sm-btn-delete:hover {
    background-color: #fef2f2; /* red-50 */
}

/* ===== DETAIL VIEW STYLES (SupplierDetail) ===== */
.sm-back-btn {
    /* text-blue-600 hover:text-blue-700 mb-2 */
    color: #2563eb;
    margin-bottom: 8px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    display: block;
    transition: color 0.2s;
}

.sm-back-btn:hover {
    color: #1d4ed8;
}

.sm-detail-title {
    /* text-2xl font-bold */
    font-size: 24px;
    font-weight: 700;
}

.sm-detail-code {
    /* text-gray-500 */
    color: #6b7280;
}

.sm-detail-header-actions {
    /* flex gap-2 */
    display: flex;
    gap: 8px;
}

.sm-detail-action-btn {
    /* px-4 py-2 border rounded-lg hover:bg-gray-50 */
    padding: 8px 16px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    background-color: white;
    cursor: pointer;
    font-size: 14px;
    transition: background-color 0.2s;
}

.sm-detail-action-btn:hover {
    background-color: #f9fafb;
}

.sm-detail-action-btn.sm-primary {
    /* bg-blue-600 text-white rounded-lg hover:bg-blue-700 */
    background-color: #2563eb;
    color: white;
    border-color: #2563eb;
}

.sm-detail-action-btn.sm-primary:hover {
    background-color: #1d4ed8;
}

/* Detail Stats Cards */
.sm-detail-stat-card {
    /* bg-blue-50 p-4 rounded-lg */
    padding: 16px;
    border-radius: 8px;
    box-shadow: none; /* No shadow */
}

.sm-detail-card-blue { background-color: #eff6ff; }
.sm-detail-card-green { background-color: #ecfdf5; }
.sm-detail-card-orange { background-color: #fff7ed; }
.sm-detail-card-purple { background-color: #faf5ff; }

.sm-detail-stat-value {
    /* text-2xl font-bold text-blue-600 */
    font-size: 24px;
    font-weight: 700;
}

.sm-detail-value-blue { color: #2563eb; }
.sm-detail-value-green { color: #10b981; }
.sm-detail-value-orange { color: #f97316; }
.sm-detail-value-purple { color: #9333ea; }

/* Tabs */
.sm-tabs-bar {
    /* border-b */
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 16px;
}

.sm-tabs-group {
    /* flex gap-6 */
    display: flex;
    gap: 24px;
}

.sm-tab-btn {
    /* pb-3 px-2 font-medium */
    padding: 0 8px 12px 8px;
    font-weight: 500;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    transition: color 0.2s;
    color: #6b7280; /* text-gray-500 */
}

.sm-tab-btn.sm-active-tab {
    /* border-b-2 border-blue-600 text-blue-600 */
    border-bottom: 2px solid #2563eb;
    color: #2563eb;
}

/* Tables (Order History, Products) */
.sm-table {
    /* w-full */
    width: 100%;
    border-collapse: collapse;
}

.sm-table-thead {
    /* bg-gray-50 */
    background-color: #f9fafb;
}

.sm-table-th {
    /* px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase */
    padding: 12px 24px;
    text-align: left;
    font-size: 12px;
    font-weight: 500;
    color: #6b7280;
    text-transform: uppercase;
}

.sm-table-th.sm-text-right { text-align: right; }

.sm-table-tbody > .sm-table-tr {
    border-top: 1px solid #e5e7eb; /* divide-y simulation */
}

.sm-table-tbody > .sm-table-tr:hover {
    background-color: #f9fafb; /* hover:bg-gray-50 */
}

.sm-table-td {
    /* px-6 py-4 text-sm */
    padding: 16px 24px;
    font-size: 14px;
    color: #374151; /* text-gray-700 */
}

.sm-table-td.sm-font-medium { font-weight: 500; }
.sm-table-td.sm-blue-link { color: #2563eb; font-weight: 500; }

.sm-table-status-tag {
    /* px-2 py-1 text-xs rounded-full bg-green-100 text-green-700 */
    padding: 4px 8px;
    font-size: 12px;
    border-radius: 9999px;
    background-color: #d1fae5;
    color: #047857;
    white-space: nowrap;
}

.sm-table-action-btn {
    /* text-blue-600 hover:text-blue-700 text-sm */
    color: #2563eb;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
}

.sm-table-action-btn:hover {
    color: #1d4ed8;
}

/* Products Panel Header */
.sm-products-panel-header {
    /* p-4 border-b flex justify-between items-center */
    padding: 16px;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* Stats Tab Content */
.sm-chart-panel {
    /* bg-white border rounded-lg p-6 */
    background-color: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 24px;
}

.sm-chart-title {
    /* font-semibold mb-4 flex items-center gap-2 */
    font-weight: 600;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.sm-chart-title svg {
    width: 20px;
    height: 20px;
}

/* Bar Chart Simulation */
.sm-bar-chart-container {
    /* h-64 flex items-end justify-around gap-2 */
    height: 256px;
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    gap: 8px;
    padding-top: 10px; /* Space for the top of the bars */
}

.sm-bar {
    /* flex-1 bg-blue-500 rounded-t */
    flex-grow: 1;
    background-color: #3b82f6;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    min-width: 4px; /* Ensure thin bars are visible */
}

.sm-chart-labels {
    /* flex justify-between text-xs text-gray-500 mt-2 */
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: #6b7280;
    margin-top: 8px;
}

/* Trend Chart Simulation */
.sm-trend-item {
    /* space-y-4 */
    margin-bottom: 16px;
}

.sm-trend-item:last-child {
    margin-bottom: 0;
}

.sm-trend-header {
    /* flex justify-between text-sm mb-1 */
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    margin-bottom: 4px;
}

.sm-trend-name {
    color: #1f2937;
}

.sm-trend-change.sm-green { color: #10b981; }
.sm-trend-change.sm-red { color: #dc2626; }
.sm-trend-change.sm-gray { color: #4b5563; }

.sm-progress-bar-bg {
    /* w-full bg-gray-200 rounded-full h-2 */
    width: 100%;
    background-color: #e5e7eb;
    border-radius: 9999px;
    height: 8px;
}

.sm-progress-bar-fill {
    /* h-2 rounded-full */
    height: 8px;
    border-radius: 9999px;
}

.sm-progress-fill-green { background-color: #10b981; }
.sm-progress-fill-red { background-color: #dc2626; }
.sm-progress-fill-gray { background-color: #6b7280; }

/* Aggregate Report */
.sm-report-grid {
    /* grid grid-cols-3 gap-4 */
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
}

.sm-report-card {
    /* text-center p-4 bg-gray-50 rounded-lg */
    text-align: center;
    padding: 16px;
    background-color: #f9fafb;
    border-radius: 8px;
}

.sm-report-label {
    /* text-sm text-gray-600 mb-1 */
    font-size: 14px;
    color: #4b5563;
    margin-bottom: 4px;
}

.sm-report-value {
    /* text-2xl font-bold */
    font-size: 24px;
    font-weight: 700;
    color: #111827;
}

.sm-report-sub {
    /* text-xs text-green-600/text-gray-600 */
    font-size: 12px;
    margin-top: 4px;
}

.sm-report-sub.sm-green { color: #10b981; }
.sm-report-sub.sm-gray { color: #4b5563; }


/* ===== MODAL STYLES ===== */
.sm-modal-overlay {
    /* fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 */
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 50;
}

.sm-modal-content {
