    <div id="sm-toast-container" class="sm-toast-container"></div>

    <script>
        function showToast(type, title, message, duration = 4000) {
            const container = document.getElementById('sm-toast-container');
            if (!container) return;

            // Icon SVG cho từng loại
            const icons = {
                success: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>`,
                error: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                </svg>`,
                warning: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>`
            };

            const toast = document.createElement('div');
            toast.className = `sm-toast ${type}`;
            toast.innerHTML = `
                <div class="sm-toast-icon">${icons[type]}</div>
                <div class="sm-toast-content">
                    <div class="sm-toast-title">${title}</div>
                    ${message ? `<div class="sm-toast-message">${message}</div>` : ''}
                </div>
                <button class="sm-toast-close">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            `;

            container.appendChild(toast);

            // Close button handler
            const closeBtn = toast.querySelector('.sm-toast-close');
            closeBtn.addEventListener('click', () => removeToast(toast));

            // Auto remove after duration
            setTimeout(() => removeToast(toast), duration);
        }

        function removeToast(toast) {
            toast.classList.add('hiding');
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.parentNode.removeChild(toast);
                }
            }, 300);
        }



        document.addEventListener('DOMContentLoaded', () => {

            // ====================================================================
            // ===== I. CONFIGURATION & UTILITY FUNCTIONS (Hàm tiện ích) =====
            // ====================================================================

            const $ = selector => document.querySelector(selector);
            const $$ = selector => document.querySelectorAll(selector);

            // --- CẤU HÌNH API ENDPOINTS ---
            const ENDPOINTS = {
                SUMMARY_LIST: '/ManagerSupplier/Summary',
                ORDERS_HISTORY: (id) => `/ManagerSupplier/OrdersHistory/${id}`,
                PRODUCTS_SUPPLIED: (id) => `/ManagerSupplier/ProductsSupplied/${id}`,
                TOP_SUPPLIERS: '/ManagerSupplier/TopSuppliers',
                RECENT_TRANSACTIONS: '/ManagerSupplier/RecentTransactions',
                ALL_RECENT_TRANSACTIONS: '/ManagerSupplier/AllRecentTransactions',
                MONTHLY_STATS: '/ManagerSupplier/MonthlyStats',
                CREATE_SUPPLIER: '/ManagerSupplier/Create',  // ✅ THÊM
                UPDATE_SUPPLIER: (id) => `/ManagerSupplier/Update/${id}`,  // ✅ THÊM
                DELETE_SUPPLIER: (id) => `/ManagerSupplier/Delete/${id}`
            };

            // --- Fetch Utility ---
            async function fetchData(url, options = {}) {
                const showEmptyToast = options.showEmptyToast !== false; // Mặc định là true
                const silent = options.silent || false; // Không hiển thị toast nào

                try {
                    const response = await fetch(url);

                    // ✅ XỬ LÝ 404 - KHÔNG HIỂN THỊ LỖI
                    if (response.status === 404) {
                        console.warn(`Data not found (404): ${url}`);
                        if (showEmptyToast && !silent) {
                            showToast('warning', 'Dữ liệu trống', 'Không có dữ liệu để hiển thị');
                        }
                        return null;
                    }

                    // ✅ XỬ LÝ CÁC LỖI KHÁC (500, 400, v.v.)
                    if (!response.ok) {
                        console.error(`HTTP Error ${response.status}: ${url}`);

                        // Chỉ hiển thị lỗi nghiêm trọng (500+)
                        if (response.status >= 500 && !silent) {
                            showToast('error', 'Lỗi server', 'Có lỗi xảy ra khi tải dữ liệu. Vui lòng thử lại sau.');
                        }
                        return null;
                    }

                    const data = await response.json();

                    // ✅ KIỂM TRA DỮ LIỆU RỖNG
                    if (!data || (Array.isArray(data) && data.length === 0)) {
                        console.info(`Empty data returned from: ${url}`);
                        if (showEmptyToast && !silent) {
                            showToast('warning', 'Dữ liệu trống', 'Không có dữ liệu để hiển thị');
                        }
                        return Array.isArray(data) ? [] : null;
                    }

                    return data;

                } catch (error) {
                    console.error("Fetch error:", url, error);

                    // Chỉ hiển thị lỗi network/connection
                    if (!silent) {
                        showToast('error', 'Lỗi kết nối', 'Không thể kết nối đến server. Vui lòng kiểm tra kết nối mạng.');
                    }
                    return null;
                }
            }

            // --- Formatting Utils ---
            function formatCurrency(num) { return num.toLocaleString('vi-VN'); }
            function formatMillion(num) { return (num / 1000000).toFixed(1) + 'M'; }



function validatePhone(phone) {
    const re = /^0\d{9}$/;  // 10 số, bắt đầu bằng 0
    return re.test(phone);
}

function validateSupplierForm(data, isEdit = false) {
    const errors = [];
    
    if (!isEdit && !data.code?.trim()) {
        errors.push('Mã nhà cung cấp không được để trống');
    }
    if (!data.name?.trim()) {
        errors.push('Tên nhà cung cấp không được để trống');
    }
    if (!data.contact?.trim()) {
        errors.push('Người liên hệ không được để trống');
    }
    if (!data.phone?.trim()) {
        errors.push('Số điện thoại không được để trống');
    } else if (!validatePhone(data.phone)) {
        errors.push('Số điện thoại phải có 10 số và bắt đầu bằng 0');
    }
    if (!data.email?.trim()) {
        errors.push('Email không được để trống');
    } else if (!validateEmail(data.email)) {  // ✅ THÊM
        errors.push('Email không đúng định dạng');
    }
    if (!data.address?.trim()) {
        errors.push('Địa chỉ không được để trống');
    }
    
    return {
        isValid: errors.length === 0,
        errors: errors
    };
}


function validateEmail(email) {
    const re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
    return re.test(email);
}

function validatePhone(phone) {
    const re = /^0\d{9}$/;
    return re.test(phone);
}

            // ====================================================================
            // ===== II. STATE MANAGEMENT & RENDER FLOW =====
            // ====================================================================

            // Dữ liệu gốc và trạng thái
            let SUPPLIERS_DATA = [];
            let state = {
                activeTab: 'list',
                detailSubTab: 'orders',
                selectedSupplier: null,
                searchTerm: '',
                showAddModal: false,
                showEditModal: false,  // ✅ THÊM
                editingSupplierId: null,
                showTransactionsModal: false,  // ✅ THÊM
                allTransactions: [],  // ✅ THÊM - Lưu 50 giao dịch
                filteredTransactions: [],  // ✅ THÊM - Dữ liệu sau khi filter
                transactionsSearch: '',  // ✅ THÊM
                transactionsSort: 'date-desc',  // ✅ THÊM
                topPeriod: 'month',
                orderHistory: [],
                ingredients: [],
                topSuppliers: [],
                recentTransactions: [],
                monthlyStats: null
            };


            function setState(newState) {
                state = { ...state, ...newState };

                // Xử lý modal transactions
                const transactionsModal = $('#sm-transactions-modal');
                if (transactionsModal) {
                    transactionsModal.style.display = state.showTransactionsModal ? 'flex' : 'none';
                }

                // ✅ Xử lý modal edit
                const editModal = $('#sm-edit-modal');
                if (editModal) {
                    editModal.style.display = state.showEditModal ? 'flex' : 'none';
                }

                render();
            }


            // Hàm render chính (Giữ nguyên)
            function render() {
                const listTab = $('#sm-tab-list');
                const detailTab = $('#sm-tab-detail');
                const modal = $('#sm-add-modal');

                listTab.style.display = state.activeTab === 'list' ? 'block' : 'none';
                detailTab.style.display = state.activeTab === 'detail' ? 'block' : 'none';
                modal.style.display = state.showAddModal ? 'flex' : 'none';

                if (state.activeTab === 'list') {
                    renderSupplierListContent();
                } else if (state.activeTab === 'detail' && state.selectedSupplier) {
                    renderSupplierDetailContent();
                    // Logic render SubContent sẽ nằm trong renderSupplierDetailContent
                }
            }


            const closeModalBtn = $('#sm-close-transactions-modal');
            if (closeModalBtn) {
                closeModalBtn.addEventListener('click', closeTransactionsModal);
            }

            // Đóng modal bằng nút "Đóng"
            const closeBtn = $('#sm-transactions-modal-close');
            if (closeBtn) {
                closeBtn.addEventListener('click', closeTransactionsModal);
            }

            // Đóng modal khi click overlay
            const modalOverlay = $('#sm-transactions-modal');
            if (modalOverlay) {
                modalOverlay.addEventListener('click', (e) => {
                    if (e.target.id === 'sm-transactions-modal') {
                        closeTransactionsModal();
                    }
                });
            }

            // Tìm kiếm trong modal
            const searchInput = $('#sm-transactions-search');
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    state.transactionsSearch = e.target.value;
                    filterAndSortTransactions();
                });
            }

            // Sắp xếp trong modal
            const sortSelect = $('#sm-transactions-sort');
            if (sortSelect) {
                sortSelect.addEventListener('change', (e) => {
                    state.transactionsSort = e.target.value;
                    filterAndSortTransactions();
                });
            }


            // ====================================================================
            // ===== III. DATA FETCHING & UI UPDATES (Logic Tích hợp API) =====
            // ====================================================================

            async function fetchAndInitializeData() {
                // ✅ LẤY DANH SÁCH NHÀ CUNG CẤP - KHÔNG HIỂN THỊ TOAST
                const summaryData = await fetchData(ENDPOINTS.SUMMARY_LIST, { silent: true });
                window.SUPPLIERS_DATA = summaryData || [];

                // ✅ LẤY TOP SUPPLIERS - KHÔNG HIỂN THỊ TOAST
                const topSuppliersData = await fetchData(ENDPOINTS.TOP_SUPPLIERS, { silent: true });
                state.topSuppliers = topSuppliersData || [];

                // ✅ LẤY RECENT TRANSACTIONS - KHÔNG HIỂN THỊ TOAST
                const recentTransactionsData = await fetchData(ENDPOINTS.RECENT_TRANSACTIONS, { silent: true });
                state.recentTransactions = recentTransactionsData || [];

                // ✅ LẤY THỐNG KÊ THÁNG - KHÔNG HIỂN THỊ TOAST
                const monthlyStatsData = await fetchData(ENDPOINTS.MONTHLY_STATS, { silent: true });
                state.monthlyStats = monthlyStatsData;

                // ✅ CHỈ HIỂN THỊ 1 TOAST DUY NHẤT NẾU TẤT CẢ ĐỀU NULL
                if (!summaryData && !topSuppliersData && !recentTransactionsData && !monthlyStatsData) {
                    showToast('warning', 'Không có dữ liệu', 'Hệ thống chưa có dữ liệu nhà cung cấp');
                }

                render();
            }

            // --- B. Fetch Dữ liệu Chi tiết khi chuyển View ---
            async function fetchDetailData(supplierId, subTab) {
                renderSubContent(); // Hiển thị loading

                let data = null;
                if (subTab === 'orders') {
                    // ✅ KHÔNG HIỂN THỊ TOAST KHI TẢI
                    data = await fetchData(ENDPOINTS.ORDERS_HISTORY(supplierId), { silent: true });
                    state.orderHistory = data || [];
                    renderSubContent();
                } else if (subTab === 'products') {
                    // ✅ KHÔNG HIỂN THỊ TOAST KHI TẢI
                    data = await fetchData(ENDPOINTS.PRODUCTS_SUPPLIED(supplierId), { silent: true });
                    state.ingredients = data || [];
                    renderSubContent();
                }
            }


            async function fetchAllTransactions() {
                // ✅ KHÔNG HIỂN THỊ TOAST KHI TẢI
                const data = await fetchData(ENDPOINTS.ALL_RECENT_TRANSACTIONS, { silent: true });
                state.allTransactions = data || [];
                state.filteredTransactions = data || [];
                renderTransactionsModal();
            }

            // ✅ HÀM LỌC VÀ SẮP XẾP GIAO DỊCH
            function filterAndSortTransactions() {
                let filtered = [...state.allTransactions];

                // Lọc theo từ khóa tìm kiếm
                const searchTerm = state.transactionsSearch.toLowerCase();
                if (searchTerm) {
                    filtered = filtered.filter(txn =>
                        txn.supplierName.toLowerCase().includes(searchTerm) ||
                        txn.supplierCode.toLowerCase().includes(searchTerm)
                    );
                }

                // Sắp xếp
                switch (state.transactionsSort) {
                    case 'date-desc':
                        filtered.sort((a, b) => new Date(b.timeConfirm) - new Date(a.timeConfirm));
                        break;
                    case 'date-asc':
                        filtered.sort((a, b) => new Date(a.timeConfirm) - new Date(b.timeConfirm));
                        break;
                    case 'value-desc':
                        filtered.sort((a, b) => b.totalValue - a.totalValue);
                        break;
                    case 'value-asc':
                        filtered.sort((a, b) => a.totalValue - b.totalValue);
                        break;
                }

                state.filteredTransactions = filtered;
                renderTransactionsModal();
            }

            // ✅ HÀM RENDER MODAL GIAO DỊCH
            function renderTransactionsModal() {
                const tbody = $('#sm-transactions-table-body');
                if (!tbody) return;

                const transactions = state.filteredTransactions;

                if (transactions.length === 0) {
                    tbody.innerHTML = `
                    <tr>
                        <td colspan="4" class="sm-table-td" style="text-align: center; color: #9ca3af; padding: 40px;">
                            Không tìm thấy giao dịch phù hợp
                        </td>
                    </tr>
                `;
                    return;
                }

                const html = transactions.map(txn => {
                    const formattedValue = formatMillion(txn.totalValue);
                    const formattedDate = new Date(txn.timeConfirm).toLocaleString('vi-VN', {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit'
                    });

                    return `
                    <tr class="sm-table-tr">
                        <td class="sm-table-td sm-font-medium">${txn.supplierName}</td>
                        <td class="sm-table-td">
                            <span class="sm-transactions-supplier-code">${txn.supplierCode}</span>
                        </td>
                        <td class="sm-table-td">
                            <span class="sm-transactions-value">${formattedValue} VNĐ</span>
                        </td>
                        <td class="sm-table-td">
                            <span class="sm-transactions-date">${formattedDate}</span>
                        </td>
                    </tr>
                `;
                }).join('');

                tbody.innerHTML = html;
            }

            // ✅ MỞ MODAL KHI CLICK "Xem tất cả"
            function openTransactionsModal() {
                state.showTransactionsModal = true;
                state.transactionsSearch = '';
                state.transactionsSort = 'date-desc';

                // Reset input values
                const searchInput = $('#sm-transactions-search');
                const sortSelect = $('#sm-transactions-sort');
                if (searchInput) searchInput.value = '';
                if (sortSelect) sortSelect.value = 'date-desc';

                setState({ showTransactionsModal: true });
                fetchAllTransactions();
            }

            // ✅ ĐÓNG MODAL
            function closeTransactionsModal() {
                setState({ showTransactionsModal: false });
            }



            /** Render nội dung cho Tab Danh sách (Sử dụng dữ liệu thực) */
            function renderSupplierListContent() {
                const suppliers = window.SUPPLIERS_DATA || [];
                const total = suppliers.length;

                // CẬP NHẬT UI - Stats Cards
                const totalElement = $('#stat-total-suppliers');
                const totalSubtextElement = $('#stat-total-subtext');
                const transactionsElement = $('#stat-transactions');
                const transactionsSubtextElement = $('#stat-transactions-subtext');

                if (totalElement) totalElement.textContent = total;
                if (totalSubtextElement) {
                    totalSubtextElement.textContent = total > 0 ? 'Đang hoạt động' : 'Chưa có nhà cung cấp';
                }

                // ✅ HIỂN THỊ DỮ LIỆU THỐNG KÊ THÁNG
                if (state.monthlyStats) {
                    if (transactionsElement) {
                        transactionsElement.textContent = state.monthlyStats.ordersThisMonth;
                    }
                    if (transactionsSubtextElement) {
                        transactionsSubtextElement.textContent = `Tháng ${state.monthlyStats.month}/${state.monthlyStats.year}`;
                    }
                } else {
                    if (transactionsElement) transactionsElement.textContent = '0';
                    if (transactionsSubtextElement) transactionsSubtextElement.textContent = 'Chưa có giao dịch';
                }

                // Phần render danh sách suppliers
                const filteredSuppliers = filterSuppliers();
                const container = $('#sm-supplier-cards-container');
