    .sm-max-width-area {
        padding: 0 16px;
    }
}

@@media (max-width: 1024px) {
    /* Desktop -> Tablet/Large Mobile */
    .sm-stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    .sm-two-col-grid {
        grid-template-columns: 1fr;
    }
    .sm-contact-grid {
        grid-template-columns: 1fr;
