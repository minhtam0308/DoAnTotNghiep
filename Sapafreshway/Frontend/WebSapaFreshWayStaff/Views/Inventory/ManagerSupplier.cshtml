                        </div>
                    </div>
                `).join('');
                }

                container.innerHTML = html;

                requestAnimationFrame(() => {
                    renderTopSuppliers();
                    renderRecentTransactions();
                });
            }


            /** Hàm hiển thị dialog xác nhận */
            function showConfirmToast(title, message) {
                return new Promise((resolve) => {
                    // Tạo overlay
                    const overlay = document.createElement('div');
                    overlay.className = 'sm-modal-overlay';
                    overlay.style.display = 'flex';
                    overlay.style.zIndex = '10000';

                    // Tạo confirm dialog
                    overlay.innerHTML = `
                    <div class="sm-modal-content" style="max-width: 400px;">
                        <h3 class="sm-modal-title">${title}</h3>
                        <p style="color: #6b7280; margin: 16px 0;">${message}</p>
                        <div class="sm-modal-footer">
                            <button id="confirm-cancel" class="sm-modal-btn sm-cancel">
                                Hủy
                            </button>
                            <button id="confirm-ok" class="sm-modal-btn sm-save" style="background-color: #dc2626;">
                                Xác nhận
                            </button>
                        </div>
                    </div>
                `;

                    document.body.appendChild(overlay);

                    // Xử lý sự kiện
                    document.getElementById('confirm-cancel').onclick = () => {
                        document.body.removeChild(overlay);
                        resolve(false);
                    };

                    document.getElementById('confirm-ok').onclick = () => {
                        document.body.removeChild(overlay);
                        resolve(true);
                    };

                    // Click overlay để đóng
                    overlay.onclick = (e) => {
                        if (e.target === overlay) {
                            document.body.removeChild(overlay);
                            resolve(false);
                        }
                    };
                });
            }

            /** Xóa nhà cung cấp (chuyển isActive = false) */
            window.deleteSupplier = async function (id) {
                const confirmDelete = await showConfirmToast('Xác nhận xóa', 'Bạn có chắc muốn xóa nhà cung cấp này?');
                if (!confirmDelete) return;

                try {
                    const response = await fetch(ENDPOINTS.DELETE_SUPPLIER(id), {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (response.ok) {
                        showToast('success', 'Thành công', 'Đã xóa nhà cung cấp thành công!');
                        fetchAndInitializeData();
                    } else {
                        const result = await response.json();
                        showToast('error', 'Lỗi', result.message || 'Không thể xóa nhà cung cấp');
                    }
                } catch (error) {
                    console.error('Error deleting supplier:', error);
                    showToast('error', 'Lỗi kết nối', 'Không thể kết nối đến máy chủ');
                }
            }

            /** Lọc danh sách nhà cung cấp dựa trên state */
            function filterSuppliers() {
                return window.SUPPLIERS_DATA.filter(s => {
                    const matchSearch = s.name.toLowerCase().includes(state.searchTerm.toLowerCase()) ||
                        s.code.toLowerCase().includes(state.searchTerm.toLowerCase());
                    return matchSearch;
                });
            }


