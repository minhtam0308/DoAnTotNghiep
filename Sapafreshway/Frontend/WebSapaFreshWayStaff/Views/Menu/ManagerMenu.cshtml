                            </div>
                            <div class="ingredient-detail">
                                <span class="ingredient-detail-label">Đơn vị</span>
                                <span class="ingredient-detail-value">${recipe.ingredient.unit.unitName}</span>
                            </div>
                        </div>
                    </div>
                `).join('');
        } else {
            ingredientsList.innerHTML = '<div style="text-align: center; padding: 2rem; color: #6b7280;"><p>Món này chưa có công thức nguyên liệu</p></div>';
        }

        const historyList = document.getElementById('modalHistoryList');
        historyList.innerHTML = `
                <div class="history-item today">
                    <span class="history-label">Hôm nay</span>
                    <span class="history-value">${item.servedToday} phần</span>
                </div>
                <div class="history-item">
                    <span class="history-label">Hôm qua</span>
                    <span class="history-value">${item.servedYesterday} phần</span>
                </div>
                <div class="history-item">
                    <span class="history-label">Trung bình 7 ngày</span>
                    <span class="history-value">${item.average7Days.toFixed(1)} phần</span>
                </div>
                <div class="history-item">
                    <span class="history-label">Trung bình 1 tháng</span>
                    <span class="history-value">${item.average30Days.toFixed(1)} phần</span>
                </div>
                <div class="history-item">
                    <span class="history-label">Trung bình 3 tháng</span>
                    <span class="history-value">${item.average90Days.toFixed(1)} phần</span>
                </div>
            `;

        const performanceList = document.getElementById('modalPerformanceList');
        performanceList.innerHTML = `
                <div class="performance-item ${item.compareWithYesterday > 20 ? 'hot' : item.compareWithYesterday < -20 ? 'low' : 'normal'}">
                    <div class="performance-item-left">
                        ${getPerformanceIcon(item.compareWithYesterday > 20 ? 'hot' : item.compareWithYesterday < -20 ? 'low' : 'normal')}
                        <span class="performance-item-label">vs Hôm qua</span>
                    </div>
                    <span class="performance-percentage">${item.compareYesterdayFormatted}</span>
                </div>
                <div class="performance-item ${item.compareWith7Days > 20 ? 'hot' : item.compareWith7Days < -20 ? 'low' : 'normal'}">
                    <div class="performance-item-left">
                        ${getPerformanceIcon(item.compareWith7Days > 20 ? 'hot' : item.compareWith7Days < -20 ? 'low' : 'normal')}
                        <span class="performance-item-label">vs 7 ngày</span>
                    </div>
                    <span class="performance-percentage">${item.compare7DaysFormatted}</span>
                </div>
                <div class="performance-item ${item.compareWith30Days > 20 ? 'hot' : item.compareWith30Days < -20 ? 'low' : 'normal'}">
                    <div class="performance-item-left">
                        ${getPerformanceIcon(item.compareWith30Days > 20 ? 'hot' : item.compareWith30Days < -20 ? 'low' : 'normal')}
                        <span class="performance-item-label">vs 30 ngày</span>
                    </div>
                    <span class="performance-percentage">${(item.compareWith30Days > 0 ? '+' : '') + item.compareWith30Days.toFixed(2)}%</span>
                </div>
            `;

        const currentPerf = getPerformance(item, state.selectedPeriod);
        const strategyBox = document.getElementById('modalStrategyBox');
        if (currentPerf.status === 'hot') {
            strategyBox.innerHTML = '<div class="strategy-box hot"><p>✓ Món đang bán rất tốt! Đảm bảo đủ nguyên liệu và có thể tăng giá nhẹ để tối ưu lợi nhuận.</p></div>';
        } else if (currentPerf.status === 'low') {
            strategyBox.innerHTML = '<div class="strategy-box low"><p>⚠ Món bán chậm hơn bình thường. Xem xét giảm giá, cải tiến món hoặc tăng cường marketing.</p></div>';
        } else {
            strategyBox.innerHTML = '<div class="strategy-box normal"><p>ⓘ Món đang bán ổn định. Duy trì chất lượng và theo dõi xu hướng.</p></div>';
        }

        document.getElementById('menuModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeModal(event) {
        if (event && event.target.classList.contains('menu-modal-content')) {
            return;
        }
        document.getElementById('menuModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
        state.selectedItem = null;
    }

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            closeModal();
        }
    });

    // ===== INITIALIZATION =====
    function init() {
        renderCategoryStats();
        renderCategoryFilters();
        renderMenuItems();
        updatePerformanceStats();
        renderTopOrdered();
        renderLeastOrdered();
        document.getElementById('topPeriodSelector').value = state.topPeriod;
        document.getElementById('leastPeriodSelector').value = state.topPeriod;
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    console.log('Menu Dashboard initialized successfully!');
</script>