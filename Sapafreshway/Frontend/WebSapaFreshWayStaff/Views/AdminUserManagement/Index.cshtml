@model WebSapaFreshWayStaff.Models.UserManagement.UserListViewModel

@{
    ViewData["Title"] = "Quản lý người dùng hệ thống ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var search = Model?.SearchRequest ?? new WebSapaFreshWayStaff.DTOs.UserManagement.UserSearchRequest();
}

<!-- Page Header -->
<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h3 class="page-title">Quản lý người dùng</h3>
            <ul class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Tổng quan</a></li>
                <li class="breadcrumb-item active">Quản lý người dùng hệ thống</li>
            </ul>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Thêm người dùng
            </a>
        </div>
    </div>
</div>

<!-- Stats Summary -->
<div class="row g-3 mb-3">
    @{
        var counts = ViewBag.UserCounts;
        int Safe(object? v) => v is int i ? i : 0;
        var total = Safe(counts?.Total);
        var ownerCount = Safe(counts?.Owner);
        var adminCount = Safe(counts?.Admin);
        var managerCount = Safe(counts?.Manager);
        var staffCount = Safe(counts?.Staff);
        var customerCount = Safe(counts?.Customer);
    }
    <div class="col-md-2">
        <a class="text-reset text-decoration-none" href="@Url.Action("Index", new { roleId = (int?)null, status = search.Status ?? 0, pageSize = search.PageSize, sortBy = search.SortBy, sortOrder = search.SortOrder })">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body py-3">
                    <div class="text-muted small">Tổng</div>
                    <div class="h5 mb-0 fw-bold">@total</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a class="text-reset text-decoration-none" href="@Url.Action("Index", new { roleId = 1, status = search.Status ?? 0, pageSize = search.PageSize, sortBy = search.SortBy, sortOrder = search.SortOrder })">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body py-3">
                    <div class="text-muted small">Owner</div>
                    <div class="h5 mb-0 fw-bold">@ownerCount</div>
                </div>
            </div>
        </a>
    </div>
  
    <div class="col-md-2">
        <a class="text-reset text-decoration-none" href="@Url.Action("Index", new { roleId = 3, status = search.Status ?? 0, pageSize = search.PageSize, sortBy = search.SortBy, sortOrder = search.SortOrder })">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body py-3">
                    <div class="text-muted small">Manager</div>
                    <div class="h5 mb-0 fw-bold">@managerCount</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a class="text-reset text-decoration-none" href="@Url.Action("Index", new { roleId = 4, status = search.Status ?? 0, pageSize = search.PageSize, sortBy = search.SortBy, sortOrder = search.SortOrder })">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body py-3">
                    <div class="text-muted small">Staff</div>
                    <div class="h5 mb-0 fw-bold">@staffCount</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a class="text-reset text-decoration-none" href="@Url.Action("Index", new { roleId = 5, status = search.Status ?? 0, pageSize = search.PageSize, sortBy = search.SortBy, sortOrder = search.SortOrder })">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body py-3">
                    <div class="text-muted small">Customer</div>
                    <div class="h5 mb-0 fw-bold">@customerCount</div>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Filter Section -->
<div class="card mb-3 border-0 shadow-sm">
    <div class="card-body">
        <form method="get" id="filterForm" asp-action="Index" class="p-2">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="fw-semibold">Tìm kiếm</label>
                        <input type="text" name="searchTerm" class="form-control form-control-sm text-dark" placeholder="Tên, email, số điện thoại..." value="@search.SearchTerm">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="fw-semibold">Vai trò</label>
                        <select name="roleId" class="form-select form-select-sm text-dark">
                            <option value="">Tất cả vai trò</option>
                            @if (Model.AvailableRoles != null)
                            {
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    <option value="@role.RoleId" selected="@(search.RoleId != null && search.RoleId.ToString() == role.RoleId.ToString())">@role.RoleName</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="fw-semibold">Trạng thái</label>
                        <select name="status" class="form-select form-select-sm text-dark">
                            <option value="">Tất cả</option>
                            <option value="0" selected="@(search.Status != null && search.Status.ToString() == "0")">Hoạt động</option>
                            <option value="1" selected="@(search.Status != null && search.Status.ToString() == "1")">Ngừng hoạt động</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="fw-semibold">Số dòng</label>
                        <select name="pageSize" class="form-select form-select-sm text-dark">
                            <option value="10" selected="@(search.PageSize == 10)">10 / trang</option>
                            <option value="25" selected="@(search.PageSize == 25)">25 / trang</option>
                            <option value="50" selected="@(search.PageSize == 50)">50 / trang</option>
                            <option value="100" selected="@(search.PageSize == 100)">100 / trang</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label class="fw-semibold">Sắp xếp theo</label>
                        <select name="sortBy" class="form-select form-select-sm text-dark">
                            <option value="FullName" selected="@(search.SortBy == "FullName")">Tên</option>
                            <option value="Email" selected="@(search.SortBy == "Email")">Email</option>
                            <option value="RoleId" selected="@(search.SortBy == "RoleId")">Vai trò</option>
                            <option value="CreatedAt" selected="@(search.SortBy == "CreatedAt")">Ngày tạo</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-1">
                    <div class="form-group d-flex align-items-end">
                        <button type="submit" class="btn btn-primary btn-sm w-100 fw-semibold shadow-sm">
                            <i class="fas fa-search"></i> Lọc
                        </button>
                    </div>
                </div>
            </div>
            <input type="hidden" name="sortOrder" value="@(search.SortOrder ?? "asc")" id="sortOrder" />
        </form>
    </div>
</div>

<!-- Users Table -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
<table class="table table-striped table-bordered align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên</th>
                        <th>Ảnh</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th class="text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.UserList != null && Model.UserList.Users != null && Model.UserList.Users.Any())
                    {
                        foreach (var user in Model.UserList.Users)
                        {
                            <tr>
                                <td>@user.UserId</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = user.UserId })">@user.FullName</a>
                                </td>
                                <td>
                                    <h2 class="table-avatar">
                                        <a href="@Url.Action("Details", new { id = user.UserId })" class="avatar avatar-sm mr-2">
                                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                            {
                                                <img class="avatar-img rounded-circle" src="@user.AvatarUrl" alt="User Image">
                                            }
                                            else
                                            {
                                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3">
                                                    @{
                                                        var lastWord = user.FullName?.Split(' ').LastOrDefault();
                                                        var initial = !string.IsNullOrEmpty(lastWord) && lastWord.Length > 0
                                                        ? lastWord.Substring(0, 1).ToUpper()
                                                        : !string.IsNullOrEmpty(user.FullName) && user.FullName.Length > 0
                                                        ? user.FullName.Substring(0, 1).ToUpper()
                                                        : "?";
                                                    }
                                                    <span>@initial</span>
                                                </div>
                                            }
                                        </a>
                                       
                                    </h2>
                                </td>
                                <td>@user.Email</td>
                                <td>@(user.Phone ?? "Không có")</td>
                                <td>
                                    <span class="badge badge-pill @(user.RoleId == 1 ? "badge-danger" : user.RoleId == 2 ? "badge-warning" : user.RoleId == 3 ? "badge-info" : "badge-secondary")">
                                        @(user.RoleName ?? "Unknown")
                                    </span>
                                </td>
                                <td>
                                    @if (user.Status == 0)
                                    {
                                        <span class="badge badge-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Ngừng hoạt động</span>
                                    }
                                </td>
                                <td>@(user.CreatedAt?.ToString("dd/MM/yyyy") ?? "Không có")</td>
                                <td class="text-right">
                                    <div class="actions">
                                        <a href="@Url.Action("Details", new { id = user.UserId })" class="btn btn-sm bg-info-light">
                                            <i class="far fa-eye"></i> Xem
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = user.UserId })" class="btn btn-sm bg-warning-light">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>
                                        @if (user.Status == 0)
                                        {
                                            <button type="button" class="btn btn-sm bg-danger-light" onclick="openDeactivateModal(@user.UserId, '@user.FullName')">
                                                <i class="fas fa-ban"></i> Ngừng hoạt động
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm bg-success-light" onclick="openActivateModal(@user.UserId, '@user.FullName')">
                                                <i class="fas fa-check"></i> Kích hoạt
                                            </button>
                                        }
                                        <button type="button" class="btn btn-sm bg-danger-light text-danger" onclick="openDeleteModal(@user.UserId, '@user.FullName')">
                                            <i class="fas fa-trash text-danger"></i> Xóa
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center">
                                <div class="py-4">
                                    <i class="fas fa-users fa-3x text-muted mb-3"></i>
                                    <h5>Không có người dùng</h5>
                                    <p class="text-muted">Hãy đổi điều kiện tìm kiếm hoặc tạo mới.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model?.UserList != null && Model.UserList.Users != null && Model.UserList.Users.Any())
        {
            <!-- Pagination -->
            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="dataTables_info">
                        Hiển thị @((Model.UserList.Page - 1) * Model.UserList.PageSize + 1) - @Math.Min(Model.UserList.Page * Model.UserList.PageSize, Model.UserList.TotalCount) trên @Model.UserList.TotalCount bản ghi
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="dataTables_paginate paging_simple_numbers float-right">
                        <ul class="pagination">
                            @if (Model.UserList.HasPreviousPage)
                            {
                                <li class="paginate_button page-item previous">
                                    <a href="@Url.Action("Index", new { page = Model.UserList.Page - 1, searchTerm = search.SearchTerm, roleId = search.RoleId, status = search.Status, pageSize = search.PageSize, sortBy = search.SortBy, sortOrder = search.SortOrder })" class="page-link">Trước</a>
                                </li>
                            }
                            else
                            {
                                <li class="paginate_button page-item previous disabled">
                                    <a href="#" class="page-link">Trước</a>
                                </li>
                            }

                            @for (int i = Math.Max(1, Model.UserList.Page - 2); i <= Math.Min(Model.UserList.TotalPages, Model.UserList.Page + 2); i++)
                            {
                                if (i == Model.UserList.Page)
                                {
                                    <li class="paginate_button page-item active">
                                        <a href="#" class="page-link">@i</a>
                                    </li>
                                }
                                else
                                {
                                    <li class="paginate_button page-item">
                                    <a href="@Url.Action("Index", new { page = i, searchTerm = search.SearchTerm, roleId = search.RoleId, status = search.Status, pageSize = search.PageSize, sortBy = search.SortBy, sortOrder = search.SortOrder })" class="page-link">@i</a>
                                    </li>
                                }
                            }

                            @if (Model.UserList.HasNextPage)
                            {
                                <li class="paginate_button page-item next">
                                    <a href="@Url.Action("Index", new { page = Model.UserList.Page + 1, searchTerm = search.SearchTerm, roleId = search.RoleId, status = search.Status, pageSize = search.PageSize, sortBy = search.SortBy, sortOrder = search.SortOrder })" class="page-link">Tiếp</a>
                                </li>
                            }
                            else
                            {
                                <li class="paginate_button page-item next disabled">
                                    <a href="#" class="page-link">Tiếp</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Deactivate Modal -->
<div class="modal fade" id="deactivateModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ngừng hoạt động người dùng</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc muốn ngừng hoạt động người dùng này?</p>
                <p><strong>Tên:</strong> <span id="deactivateUserName"></span></p>
                <div class="form-group">
                    <label for="deactivateReason">Lý do (không bắt buộc)</label>
                    <textarea id="deactivateReason" class="form-control" rows="3" placeholder="Nhập lý do ngừng hoạt động..."></textarea>
                </div>
                <input type="hidden" id="deactivateUserId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" onclick="submitDeactivate()">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">Xóa người dùng</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="text-danger"><strong>Cảnh báo: Thao tác này không thể hoàn tác!</strong></p>
                <p>Bạn có chắc chắn muốn xóa vĩnh viễn người dùng này?</p>
                <p><strong>Tên:</strong> <span id="deleteUserName"></span></p>
                <div class="form-group">
                    <label for="deleteReason">Lý do (không bắt buộc)</label>
                    <textarea id="deleteReason" class="form-control" rows="3" placeholder="Nhập lý do xóa..."></textarea>
                </div>
                <input type="hidden" id="deleteUserId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" onclick="submitDelete()">Xóa vĩnh viễn</button>
            </div>
        </div>
    </div>
</div>

<!-- Activate Modal -->
<div class="modal fade" id="activateModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-check-circle me-2"></i>Kích hoạt người dùng</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn kích hoạt người dùng này?</p>
                <p><strong>Tên:</strong> <span id="activateUserName"></span></p>
                <input type="hidden" id="activateUserId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-success" onclick="submitActivate()">
                    <i class="fas fa-check me-1"></i>Kích hoạt
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Generic Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" role="dialog" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalLabel">Xác nhận</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="confirm-message mb-0">Bạn chắc chắn muốn thực hiện hành động này?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-cancel" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary btn-confirm">Xác nhận</button>
            </div>
        </div>
    </div>
</div>
@{
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
    var warningMessage = TempData["WarningMessage"] as string;
}

@section Scripts {
    <script src="~/js/admin-user-management.js" asp-append-version="true"></script>
    <script>
        // Initialize on page load
            
        $(document).ready(function() {
            initializeUserManagement();
        });

        // Show success/error messages from TempData
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <text>
                    showSuccessToast('@successMessage');
            </text>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <text>
                    showErrorToast('@errorMessage');

            </text>
        }
        @if (!string.IsNullOrEmpty(warningMessage))
        {
            <text>
                   showWarningToast('@warningMessage');
            </text>
        }

        // Activate Modal Functions
        function openActivateModal(userId, userName) {
            document.getElementById('activateUserId').value = userId;
            document.getElementById('activateUserName').textContent = userName;
            $('#activateModal').modal('show');
        }

        function submitActivate() {
            const userId = document.getElementById('activateUserId').value;
            ÂctiveUser(userId, 0);
            $('#activateModal').modal('hide');
        }
    </script>
}

