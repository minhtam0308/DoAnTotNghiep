@model WebSapaFreshWayStaff.Models.UserManagement.UserCreateViewModel

@{
    ViewData["Title"] = "Tạo người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- Page Header -->
<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h3 class="page-title">Tạo người dùng mới</h3>
            <ul class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Tổng quan</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Quản lý người dùng</a></li>
                <li class="breadcrumb-item active">Tạo mới</li>
            </ul>
        </div>
    </div>
</div>

<!-- Create Form -->
<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title mb-0">Thông tin người dùng</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" id="createForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FullName" class="control-label"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email" class="control-label"></label>
                                <input asp-for="Email" class="form-control" type="email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Phone" class="control-label"></label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="RoleId" class="control-label"></label>
                                <select asp-for="RoleId" class="form-control">
                                <option value="">-- Chọn vai trò --</option>
                                    @if (Model.AvailableRoles != null)
                                    {
                                        @foreach (var role in Model.AvailableRoles)
                                        {
                                            <option value="@role.RoleId">@role.RoleName</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="RoleId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Status" class="control-label"></label>
                                <select asp-for="Status" class="form-control">
                                    <option value="0">Hoạt động</option>
                                    <option value="1">Ngừng hoạt động</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="TemporaryPassword" class="control-label"></label>
                                <input asp-for="TemporaryPassword" class="form-control" type="password" />
                                <span asp-validation-for="TemporaryPassword" class="text-danger"></span>
                                <small class="form-text text-muted">Để trống để hệ thống tự tạo</small>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="SendEmailNotification" class="form-check-input" type="checkbox" />
                            <label asp-for="SendEmailNotification" class="form-check-label">
                                Gửi email thông báo cho người dùng
                            </label>
                        </div>
                    </div>

                    <div class="form-group text-right">
                        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                        <button type="button" class="btn btn-primary" onclick="openCreateConfirmModal()">Tạo</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function openCreateConfirmModal() {
            $('#createConfirmModal').modal('show');
        }

        function submitCreateForm() {
            document.getElementById('createForm').submit();
        }
    </script>
}

<!-- Create Confirm Modal -->
<div class="modal fade" id="createConfirmModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-question-circle me-2"></i>Xác nhận tạo người dùng</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc muốn tạo người dùng này?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="submitCreateForm()">
                    <i class="fas fa-plus me-1"></i>Tạo người dùng
                </button>
            </div>
        </div>
    </div>
</div>

