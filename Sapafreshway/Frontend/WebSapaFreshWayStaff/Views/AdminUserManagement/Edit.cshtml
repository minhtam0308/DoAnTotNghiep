@model WebSapaFreshWayStaff.Models.UserManagement.UserEditViewModel

@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- Page Header -->
<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h3 class="page-title">Chỉnh sửa người dùng</h3>
            <ul class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Tổng quan</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Quản lý người dùng</a></li>
                <li class="breadcrumb-item active">Chỉnh sửa</li>
            </ul>
        </div>
    </div>
</div>

<!-- Edit Form -->
<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title mb-0">Thông tin người dùng</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
                    <input type="hidden" asp-for="UserId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FullName" class="control-label"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email" class="control-label"></label>
                                <input asp-for="Email" class="form-control" type="email" readonly />
                                <small class="form-text text-muted">Email không thể thay đổi</small>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Phone" class="control-label"></label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="RoleId" class="control-label"></label>
                                @{
                                    var roleName = !string.IsNullOrEmpty(Model.RoleName) 
                                        ? Model.RoleName 
                                        : Model.AvailableRoles?.FirstOrDefault(r => r.RoleId == Model.RoleId)?.RoleName ?? "Unknown";
                                }
                                <input type="hidden" asp-for="RoleId" />
                                <input type="text" class="form-control" value="@roleName" readonly disabled style="background-color: #e9ecef; cursor: not-allowed;" />
                                <small class="form-text text-muted">
                                    <i class="fas fa-info-circle"></i> Vai trò không thể thay đổi khi chỉnh sửa người dùng
                                </small>
                                <span asp-validation-for="RoleId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Status" class="control-label"></label>
                                <select asp-for="Status" class="form-control">
                                    <option value="0">Hoạt động</option>
                                    <option value="1">Ngừng hoạt động</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="control-label">Ảnh đại diện</label>
                                
                                @* Hiển thị ảnh hiện tại nếu có *@
                                @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                                {
                                    <div class="mb-2">
                                        <img src="@Model.AvatarUrl" alt="Avatar hiện tại" class="img-thumbnail" style="max-width: 150px; max-height: 150px; display: block;" id="currentAvatar" />
                                        <small class="text-muted d-block mt-1">Ảnh hiện tại</small>
                                    </div>
                                }
                                
                                @* File upload *@
                                <div class="mb-2">
                                    <label for="AvatarFile" class="form-label">Chọn ảnh mới (JPG, PNG, GIF - tối đa 5MB)</label>
                                    <input type="file" asp-for="AvatarFile" class="form-control" accept="image/jpeg,image/png,image/gif,image/jpg" id="AvatarFile" onchange="previewImage(this)" />
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle"></i> Ảnh sẽ được upload lên Cloudinary. Nếu không chọn ảnh mới, ảnh hiện tại sẽ được giữ nguyên.
                                    </small>
                                    <span asp-validation-for="AvatarFile" class="text-danger"></span>
                                </div>
                                
                                @* Preview ảnh mới được chọn *@
                                <div id="imagePreview" class="mt-2" style="display: none;">
                                    <img id="previewImg" src="#" alt="Preview" class="img-thumbnail" style="max-width: 150px; max-height: 150px; display: block;" />
                                    <small class="text-muted d-block mt-1">Ảnh mới sẽ được upload</small>
                                </div>
                                
                                @* Hidden field để giữ AvatarUrl nếu không upload file mới *@
                                <input type="hidden" asp-for="AvatarUrl" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group text-right">
                        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                        <button type="button" class="btn btn-primary" onclick="openEditConfirmModal()">Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImage(input) {
            const preview = document.getElementById('imagePreview');
            const previewImg = document.getElementById('previewImg');
            const currentAvatar = document.getElementById('currentAvatar');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    preview.style.display = 'block';
                    if (currentAvatar) {
                        currentAvatar.style.opacity = '0.5';
                    }
                };
                
                reader.readAsDataURL(input.files[0]);
                
                // Validate file size (5MB)
                const fileSize = input.files[0].size / 1024 / 1024; // Size in MB
                if (fileSize > 5) {
                    showErrorModal('Kích thước file không được vượt quá 5MB');
                    input.value = '';
                    preview.style.display = 'none';
                    if (currentAvatar) {
                        currentAvatar.style.opacity = '1';
                    }
                    return;
                }
                
                // Validate file type
                const fileType = input.files[0].type;
                const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/jpg'];
                if (!allowedTypes.includes(fileType)) {
                    showErrorModal('Chỉ chấp nhận file ảnh (JPG, PNG, GIF)');
                    input.value = '';
                    preview.style.display = 'none';
                    if (currentAvatar) {
                        currentAvatar.style.opacity = '1';
                    }
                    return;
                }
            } else {
                preview.style.display = 'none';
                if (currentAvatar) {
                    currentAvatar.style.opacity = '1';
                }
            }
        }

        function openEditConfirmModal() {
            $('#editConfirmModal').modal('show');
        }

        function submitEditForm() {
            document.getElementById('editForm').submit();
        }

        function showErrorModal(message) {
            document.getElementById('errorMessage').textContent = message;
            $('#errorModal').modal('show');
        }
    </script>
}

<!-- Edit Confirm Modal -->
<div class="modal fade" id="editConfirmModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-question-circle me-2"></i>Xác nhận cập nhật</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc muốn lưu thay đổi cho người dùng này?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="submitEditForm()">
                    <i class="fas fa-save me-1"></i>Lưu thay đổi
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Error Modal -->
<div class="modal fade" id="errorModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Lỗi</h5>
                <button type="button" class="close text-white" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p id="errorMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

