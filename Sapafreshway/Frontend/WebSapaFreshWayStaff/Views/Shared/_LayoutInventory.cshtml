<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - WareHouse</title>

    @RenderSection("Styles", required: false)
    <style>
        /* Reset cho toàn bộ trang */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background-color: #e8eaed;
            height: 100vh;
            overflow: hidden;
        }

        /* Scope tất cả CSS của layout vào container chính */
        .layout-container {
            display: flex;
            height: 100vh;
            position: relative;
        }

        /* Sidebar - prefix với .layout-sidebar */
        .layout-sidebar {
            width: 250px;
            background: linear-gradient(180deg, #2c3e50 0%, #1a252f 100%);
            display: flex;
            flex-direction: column;
            padding: 0;
            box-shadow: 2px 0 15px rgba(0, 0, 0, 0.2);
            flex-shrink: 0;
            transition: width 0.3s ease, transform 0.3s ease;
            position: relative;
            z-index: 1000;
        }

        /* Sidebar collapsed state */
        .layout-sidebar.collapsed {
            width: 70px;
        }

        /* Toggle Button */
        .sidebar-toggle-btn {
            position: absolute;
            right: -15px;
            top: 20px;
            width: 30px;
            height: 30px;
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            border: none;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(34, 197, 94, 0.4);
            transition: all 0.3s ease;
            z-index: 1001;
        }

        .sidebar-toggle-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.6);
        }

        .sidebar-toggle-btn svg {
            width: 18px;
            height: 18px;
            color: white;
            transition: transform 0.3s ease;
        }

        .layout-sidebar.collapsed .sidebar-toggle-btn svg {
            transform: rotate(180deg);
        }

        /* Logo Section */
        .layout-sidebar .sidebar-logo {
            padding: 25px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.2);
        }

        .layout-sidebar .sidebar-logo {
            /* Căn giữa nội dung logo */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .layout-sidebar .sidebar-brand-logo {
            max-width: 100%; /* Không tràn ra ngoài */
            height: auto; /* Giữ tỷ lệ ảnh */
            max-height: 50px; /* Giới hạn chiều cao tối đa, bạn có thể chỉnh số này to nhỏ tùy ý */
            object-fit: contain;
            margin-bottom: 5px;
            transition: all 0.3s ease;
        }

        /* Xử lý khi Sidebar thu nhỏ (Collapsed) */
        .layout-sidebar.collapsed .sidebar-brand-logo {
            max-height: 30px; /* Thu nhỏ logo khi sidebar đóng lại */
            opacity: 1; /* Giữ hiển thị logo (hoặc chỉnh thành 0 nếu muốn ẩn hẳn) */
        }

        .layout-sidebar .sidebar-logo p {
            color: rgba(255, 255, 255, 0.7);
            font-size: 12px;
            font-weight: 500;
            white-space: nowrap;
            transition: opacity 0.3s ease;
        }

        .layout-sidebar.collapsed .sidebar-logo h1,
        .layout-sidebar.collapsed .sidebar-logo p {
            opacity: 0;
            pointer-events: none;
        }

        .layout-sidebar.collapsed .sidebar-logo {
            padding: 25px 10px;
            text-align: center;
        }

        /* Menu */
        .layout-sidebar .sidebar-menu {
            flex: 1;
            overflow-y: auto;
            padding: 20px 0;
        }

        .layout-sidebar .sidebar-menu-item {
            display: flex;
            align-items: center;
            padding: 14px 20px;
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            margin: 0 15px 8px;
            border-radius: 10px;
            position: relative;
        }

        .layout-sidebar .sidebar-menu-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
        }

        /* Active state */
        .layout-sidebar .sidebar-menu-item.active {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
        }

        .layout-sidebar .sidebar-menu-item.active svg {
            color: white;
        }

        .layout-sidebar .sidebar-menu-item svg {
            width: 22px;
            height: 22px;
            margin-right: 12px;
            flex-shrink: 0;
            color: rgba(255, 255, 255, 0.7);
            transition: color 0.3s ease;
        }

        .layout-sidebar .sidebar-menu-item span {
            white-space: nowrap;
            transition: opacity 0.3s ease;
        }

        .layout-sidebar.collapsed .sidebar-menu-item span {
            opacity: 0;
            width: 0;
            overflow: hidden;
        }

        .layout-sidebar.collapsed .sidebar-menu-item {
            padding: 14px;
            justify-content: center;
            margin: 0 10px 8px;
        }

        .layout-sidebar.collapsed .sidebar-menu-item svg {
            margin-right: 0;
        }

        /* Submenu styles */
        .sidebar-menu-group {
            margin: 10px 10px 10px 0px;
        }

        .sidebar-menu-parent {
            position: relative;
            display: flex;
            align-items: center;
            width: 100%;
        }

        .sidebar-menu-parent .submenu-arrow {
            width: 16px;
            height: 16px;
            margin-left: auto;
            transition: transform 0.3s ease, opacity 0.3s ease;
            flex-shrink: 0;
            color: rgba(255, 255, 255, 0.6);
        }

        .layout-sidebar.collapsed .submenu-arrow {
            opacity: 0;
            width: 0;
        }

        .sidebar-submenu {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
            background-color: rgba(0, 0, 0, 0.2);
            border-radius: 8px;
            margin-top: 5px;
        }

        .sidebar-menu-group.active .sidebar-submenu {
            max-height: 200px;
        }

        .sidebar-menu-group.active .submenu-arrow {
            transform: rotate(180deg);
        }

        .sidebar-submenu-item {
            display: block;
            padding: 12px 20px 12px 52px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.3s ease;
            border-radius: 6px;
            margin: 5px 10px;
        }

        .sidebar-submenu-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .sidebar-submenu-item.active {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: white;
        }

        .layout-sidebar.collapsed .sidebar-submenu {
            display: none;
        }

        /* User Section */
        .layout-sidebar .sidebar-user-section {
            padding: 15px 20px;
            margin: 10px 15px;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.2) 100%);
            border-radius: 12px;
            transition: all 0.3s ease;
            border: 1px solid rgba(59, 130, 246, 0.3);
        }

        .layout-sidebar .sidebar-user-link {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: inherit;
        }

        .layout-sidebar.collapsed .sidebar-user-section {
            padding: 15px 10px;
            justify-content: center;
        }

        .layout-sidebar .sidebar-user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
            flex-shrink: 0;
            box-shadow: 0 2px 8px rgba(59, 130, 246, 0.4);
        }

        .layout-sidebar .sidebar-user-info {
            flex: 1;
            min-width: 0;
            transition: opacity 0.3s ease;
        }

        .layout-sidebar.collapsed .sidebar-user-info {
            opacity: 0;
            width: 0;
            overflow: hidden;
        }

        .layout-sidebar .sidebar-user-name {
            font-size: 13px;
            font-weight: 600;
            color: white;
            margin-bottom: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .layout-sidebar .sidebar-user-email {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.6);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Logout Button */
        .layout-sidebar .sidebar-logout-wrapper {
            padding: 0 15px 20px;
        }

        .layout-sidebar .sidebar-logout-btn {
            width: 100%;
            padding: 12px 20px;
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }

        .layout-sidebar .sidebar-logout-btn:hover {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(239, 68, 68, 0.4);
        }

        .layout-sidebar .sidebar-logout-btn:active {
            transform: translateY(0);
        }

        .layout-sidebar .sidebar-logout-btn svg {
            width: 18px;
            height: 18px;
            transition: opacity 0.3s ease;
        }

        .layout-sidebar .sidebar-logout-btn .logout-text {
            transition: opacity 0.3s ease, width 0.3s ease;
        }

        .layout-sidebar.collapsed .sidebar-logout-btn .logout-text {
            opacity: 0;
            width: 0;
            overflow: hidden;
        }

        .layout-sidebar.collapsed .sidebar-logout-wrapper {
            padding: 0 10px 20px;
        }

        /* Main Content */
        .layout-main-content {
            margin: 10px;
            flex: 1;
            overflow-y: auto;
            background-color: #e8eaed;
            min-width: 0;
            transition: margin-left 0.3s ease;
        }

        /* Scrollbar styling */
        .layout-sidebar .sidebar-menu::-webkit-scrollbar,
        .layout-main-content::-webkit-scrollbar {
            width: 6px;
        }

        .layout-sidebar .sidebar-menu::-webkit-scrollbar-track,
        .layout-main-content::-webkit-scrollbar-track {
            background: transparent;
        }

        .layout-sidebar .sidebar-menu::-webkit-scrollbar-thumb,
        .layout-main-content::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 3px;
        }

        .layout-sidebar .sidebar-menu::-webkit-scrollbar-thumb:hover,
        .layout-main-content::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.3);
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .layout-sidebar {
                width: 200px;
            }

            .layout-main-content {
                padding: 15px;
            }
        }

        @@media (max-width: 576px) {
            .layout-sidebar {
                position: fixed;
                left: 0;
                top: 0;
                height: 100vh;
                transform: translateX(-100%);
                z-index: 1000;
            }

            .layout-sidebar.mobile-open {
                transform: translateX(0);
            }

            .sidebar-toggle-btn {
                right: -45px;
            }

            .layout-main-content {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <div class="layout-container">
        <!-- Sidebar -->
        <aside class="layout-sidebar" id="sidebar">
            <!-- Toggle Button -->
            <button class="sidebar-toggle-btn" onclick="toggleSidebar()" aria-label="Toggle Sidebar">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M15 19l-7-7 7-7" />
                </svg>
            </button>

            <div class="sidebar-logo">
                <img src="~/assets/images/MainLogo.png" alt="Sapa Forest Logo" class="sidebar-brand-logo">
                <p>Quản lý kho Sapa FoRest</p>
            </div>

            <nav class="sidebar-menu">
                <a href="@Url.Action("Index", "DashboardInventory")"
                   class="sidebar-menu-item"
                   data-controller="DashboardInventory">
                    <svg fill="currentColor" viewBox="0 0 24 24">
                        <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                    </svg>
                    <span>Dashboard</span>
                </a>

                <a href="@Url.Action("Index", "MainImportInventory")"
                   class="sidebar-menu-item"
                   data-controller="MainImportInventory">
                    <svg fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14H7v-2h5v2zm5-4H7v-2h10v2zm0-4H7V7h10v2z" />
                    </svg>
                    <span>Nhập hàng</span>
                </a>

                <a href="@Url.Action("Index", "ExportInventory")"
                   class="sidebar-menu-item"
                   data-controller="ExportInventory">
                    <svg fill="currentColor" viewBox="0 0 24 24">
                        <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z" />
                    </svg>
                    <span>Xuất hàng</span>
                </a>

                <div class="sidebar-menu-group">
                    <div class="sidebar-menu-item sidebar-menu-parent"
                         onclick="toggleSubmenu(this)"
                         data-controller="ManagerIngredent">
                        <svg fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20 2H4c-1 0-2 .9-2 2v3.01c0 .72.43 1.34 1 1.69V20c0 1.1 1.1 2 2 2h14c.9 0 2-.9 2-2V8.7c.57-.35 1-.97 1-1.69V4c0-1.1-1-2-2-2zm-5 12H9v-2h6v2zm5-7H4V4h16v3z" />
                        </svg>
                        <span>Mặt hàng</span>
                        <svg class="submenu-arrow" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M7 10l5 5 5-5z" />
                        </svg>
                    </div>
                    <div class="sidebar-submenu">
                        <a href="@Url.Action("DisplayIngredent", "ManagerIngredent")"
                           class="sidebar-submenu-item"
                           data-controller="ManagerIngredent">
                            <span>Quản lý mặt hàng</span>
                        </a>
                        <a href="@Url.Action("Index", "AuditInventory")"
                           class="sidebar-submenu-item"
                           data-controller="AuditInventory">
                            <span>Quản lý kiểm kê</span>
                        </a>
                    </div>
                </div>

                <a href="@Url.Action("Index", "ManagerSupplier")"
                   class="sidebar-menu-item"
                   data-controller="ManagerSupplier">
                    <svg fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                    <span>Nhà cung cấp</span>
                </a>

                <a href="@Url.Action("Index", "UnitInventory")"
                   class="sidebar-menu-item"
                   data-controller="CaiDat">
                    <svg fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" />
                    </svg>
                    <span>Kho và đơn vị tính</span>
                </a>
            </nav>

            <div class="sidebar-user-section">
                <a href="@Url.Action("Index", "UserProfile")" class="sidebar-user-link">
                    <div class="sidebar-user-avatar">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value?.Substring(0, 1).ToUpper()
                        }
                        else
                        {
                            @:A
                        }
                    </div>
                    <div class="sidebar-user-info">
                        <div class="sidebar-user-name">
                            @if (User.Identity.IsAuthenticated)
                            {
                                @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                            }
                            else
                            {
                                @:Admin User
                            }
                        </div>
                        <div class="sidebar-user-email">
                            @if (User.Identity.IsAuthenticated)
                            {
                                @User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                            }
                            else
                            {
                                @:admin@warehouse.vn
                            }
                        </div>
                    </div>
                </a>
            </div>

            <div class="sidebar-logout-wrapper">
                <form id="logoutForm" action="/Auth/Logout" method="post">
                    <button type="submit" class="sidebar-logout-btn">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/>
                        </svg>
                        <span class="logout-text">Đăng xuất</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="layout-main-content">
            @RenderBody()
        </main>
    </div>

    <script>
        // Toggle Sidebar
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('collapsed');
            
            // Save state to localStorage
            const isCollapsed = sidebar.classList.contains('collapsed');
            localStorage.setItem('sidebarCollapsed', isCollapsed);
        }

        // Toggle submenu
        function toggleSubmenu(element) {
            const group = element.closest('.sidebar-menu-group');
            const allGroups = document.querySelectorAll('.sidebar-menu-group');

            // Close all other submenus
            allGroups.forEach(g => {
                if (g !== group) {
                    g.classList.remove('active');
                }
            });

            // Toggle current submenu
            group.classList.toggle('active');
        }

        // Highlight active menu item based on current controller
        document.addEventListener('DOMContentLoaded', function () {
            // Restore sidebar state
            const sidebarCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (sidebarCollapsed) {
                document.getElementById('sidebar').classList.add('collapsed');
            }

            const currentController = '@ViewContext.RouteData.Values["Controller"]';
            const menuItems = document.querySelectorAll('.sidebar-menu-item');
            const submenuItems = document.querySelectorAll('.sidebar-submenu-item');

            console.log('Current Controller:', currentController);

            // Check main menu items
            menuItems.forEach(item => {
                const itemController = item.getAttribute('data-controller');
                if (itemController && itemController.toLowerCase() === currentController.toLowerCase()) {
                    item.classList.add('active');

                    // If it's a parent menu, expand it
                    const group = item.closest('.sidebar-menu-group');
                    if (group) {
                        group.classList.add('active');
                    }
                } else {
                    item.classList.remove('active');
                }
            });

            // Check submenu items
            submenuItems.forEach(item => {
                const itemController = item.getAttribute('data-controller');
                if (itemController && itemController.toLowerCase() === currentController.toLowerCase()) {
                    item.classList.add('active');

                    // Expand parent menu
                    const group = item.closest('.sidebar-menu-group');
                    if (group) {
                        group.classList.add('active');
                    }
                } else {
                    item.classList.remove('active');
                }
            });
        });
    </script>


    @RenderSection("Scripts", required: false)
</body>
</html>