@using System.Security.Claims
@{
    // Lấy thông tin từ claims để tránh gọi API (tránh redirect sang host API)
    string GetClaim(string type) => User.FindFirst(type)?.Value ?? string.Empty;

    var avatarUrl = !string.IsNullOrWhiteSpace(GetClaim("AvatarUrl"))
        ? GetClaim("AvatarUrl")
        : Url.Content("~/assets/images/faces/face8.jpg");

    var displayName = !string.IsNullOrWhiteSpace(User.Identity?.Name)
        ? User.Identity.Name
        : GetClaim(ClaimTypes.Name) ?? "User";

    var displayEmail = GetClaim(ClaimTypes.Email);
}
