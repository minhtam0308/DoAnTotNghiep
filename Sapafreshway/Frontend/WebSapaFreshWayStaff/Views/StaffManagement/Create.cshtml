@model WebSapaFreshWayStaff.Models.StaffViewModels.StaffCreateViewModel

@{
    ViewData["Title"] = "Thêm nhân viên mới";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- Page Header -->
<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h3 class="page-title">Thêm nhân viên mới</h3>
            <ul class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="HomeManager" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Quản lý Nhân viên</a></li>
                <li class="breadcrumb-item active">Thêm nhân viên mới</li>
            </ul>
        </div>
    </div>
</div>

<!-- Create Form -->
<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="card-title mb-0"><i class="fas fa-user-plus"></i> Thông tin nhân viên</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" id="createStaffForm" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <h5 class="border-bottom pb-2 mb-3"><i class="fas fa-id-card"></i> Thông tin cá nhân</h5>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FullName" class="control-label required"></label>
                                <input asp-for="FullName" class="form-control" autocomplete="off" placeholder="Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email" class="control-label required"></label>
                                <input asp-for="Email" class="form-control" type="email" autocomplete="email" placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Phone" class="control-label"></label>
                                <input asp-for="Phone" class="form-control" type="tel" autocomplete="tel" placeholder="0123456789" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="HireDate" class="control-label required"></label>
                                <input asp-for="HireDate" class="form-control" type="date" />
                                <span asp-validation-for="HireDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4"><i class="fas fa-briefcase"></i> Chức vụ & Lương</h5>

                    <div class="form-group">
                        <label asp-for="PositionId" class="control-label required">
                            <i class="fas fa-briefcase"></i> Chức vụ
                        </label>
                        <select asp-for="PositionId" class="form-control form-control-lg" id="positionSelect">
                            <option value="">-- Chọn chức vụ --</option>
                            @if (Model.AvailablePositions != null && Model.AvailablePositions.Any())
                            {
                                @foreach (var position in Model.AvailablePositions)
                                {
                                    <option value="@position.PositionId" 
                                            data-salary="@position.BaseSalary">
                                        @position.PositionName - @position.BaseSalary.ToString("N0") VND
                                    </option>
                                }
                            }
                        </select>
                        <span asp-validation-for="PositionId" class="text-danger"></span>
                        <small class="form-text text-muted">
                            <i class="fas fa-info-circle"></i> Chọn chức vụ cho nhân viên. Lương cơ bản sẽ được tự động điền theo chức vụ.
                        </small>
                    </div>

                    <div class="form-group">
                        <label class="control-label">
                            <i class="fas fa-calculator"></i> Lương cơ bản 
                            <span class="badge badge-info">Tự động điền</span>
                        </label>
                        <div class="input-group">
                            <input type="text" id="displaySalary" class="form-control form-control-lg" readonly value="0 VND" 
                                   style="background-color: #e3f2fd; font-weight: bold; font-size: 1.2rem; color: #1976d2;">
                            <div class="input-group-append">
                                <span class="input-group-text bg-primary text-white">
                                    <i class="fas fa-coins"></i>
                                </span>
                            </div>
                        </div>
                        <input type="hidden" asp-for="BaseSalary" id="hiddenBaseSalary" value="0" />
                        <small class="form-text text-info">
                            <i class="fas fa-lightbulb"></i> Lương được tự động điền từ chức vụ được chọn
                        </small>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> <strong>Vai trò:</strong> Staff (Nhân viên) - Tự động gán cho tất cả nhân viên mới
                    </div>

                    <h5 class="border-bottom pb-2 mb-3 mt-4"><i class="fas fa-key"></i> Bảo mật</h5>

                    <div class="form-group">
                        <label asp-for="Password" class="control-label"></label>
                        <input asp-for="Password" class="form-control" type="password" autocomplete="new-password" placeholder="Để trống để tự động tạo" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        <small class="form-text text-muted">
                            <i class="fas fa-lock"></i> Để trống để hệ thống tự động tạo mật khẩu ngẫu nhiên và gửi email cho nhân viên
                        </small>
                    </div>

                    <div class="form-group">
                        <label class="control-label">
                            <i class="fas fa-image"></i> Ảnh đại diện
                        </label>
                        <div class="border rounded p-3" style="background-color: #f8f9fa;">
                            <!-- Image Preview -->
                            <div class="text-center mb-3" id="avatarPreviewContainer" style="display: none;">
                                <img id="avatarPreview" src="" alt="Avatar Preview" class="img-thumbnail" style="max-width: 200px; max-height: 200px; object-fit: cover;">
                                <button type="button" class="btn btn-sm btn-danger d-block mx-auto mt-2" id="removeAvatarBtn">
                                    <i class="fas fa-trash"></i> Xóa ảnh
                                </button>
                            </div>
                            
                            <!-- File Input -->
                            <input type="file" 
                                   class="form-control" 
                                   id="avatarFileInput" 
                                   name="AvatarFile"
                                   accept="image/jpeg,image/png,image/jpg,image/gif">
                            
                            <span asp-validation-for="AvatarUrl" class="text-danger"></span>
                        </div>
                        <small class="form-text text-muted">
                            <i class="fas fa-info-circle"></i> Chọn ảnh để upload. Hỗ trợ JPG, PNG, GIF (tối đa 5MB)
                        </small>
                    </div>

                    <div class="form-group text-right mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg" id="btnSubmit">
                            <i class="fas fa-save"></i> Tạo nhân viên
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // ========== AVATAR UPLOAD ==========
            $('#avatarFileInput').on('change', function(e) {
                const file = e.target.files[0];
                
                if (file) {
                    // Validate file size (5MB)
                    if (file.size > 5 * 1024 * 1024) {
                        toastr.error('Kích thước ảnh không được vượt quá 5MB');
                        $(this).val('');
                        return;
                    }
                    
                    // Validate file type
                    const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
                    if (!validTypes.includes(file.type)) {
                        toastr.error('Vui lòng chọn file ảnh JPG, PNG hoặc GIF');
                        $(this).val('');
                        return;
                    }
                    
                    // Show preview
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#avatarPreview').attr('src', e.target.result);
                        $('#avatarPreviewContainer').show();
                    };
                    reader.readAsDataURL(file);
                    
                    toastr.success('Đã chọn ảnh thành công');
                }
            });
            
            // Remove avatar
            $('#removeAvatarBtn').on('click', function() {
                $('#avatarFileInput').val('');
                $('#avatarPreview').attr('src', '');
                $('#avatarPreviewContainer').hide();
                toastr.info('Đã xóa ảnh đại diện');
            });
            
            // ========== SALARY CALCULATION ==========
            function updateSalary() {
                const selectedOption = $('#positionSelect option:selected');
                const salary = parseFloat(selectedOption.data('salary')) || 0;
                
                if (salary > 0) {
                    $('#displaySalary').val(salary.toLocaleString('vi-VN') + ' VND');
                    $('#hiddenBaseSalary').val(salary);
                    $('#displaySalary').css('color', '#1976d2');
                    $('#positionSelect').removeClass('is-invalid');
                } else {
                    $('#displaySalary').val('0 VND');
                    $('#hiddenBaseSalary').val(0);
                    $('#displaySalary').css('color', '#999');
                }
            }
            
            // Listen to position select changes
            $('#positionSelect').on('change', function() {
                updateSalary();
            });
            
            // ========== FORM VALIDATION ==========
            $('#createStaffForm').on('submit', function(e) {
                const positionId = parseInt($('#positionSelect').val());
                
                if (!positionId || positionId <= 0) {
                    e.preventDefault();
                    toastr.error('Vui lòng chọn chức vụ!');
                    $('#positionSelect').addClass('is-invalid');
                    return false;
                }
                
                const baseSalary = parseFloat($('#hiddenBaseSalary').val());
                if (baseSalary <= 0) {
                    e.preventDefault();
                    toastr.error('Lương cơ bản phải lớn hơn 0!');
                    return false;
                }
                
                // Disable submit button to prevent double submission
                $('#btnSubmit').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Đang xử lý...');
            });
        });
    </script>
    
    <style>
        .required::after {
            content: " *";
            color: red;
        }
        #positionSelect {
            font-size: 1.1rem;
        }
        #positionSelect option {
            padding: 10px;
        }
        #avatarPreview {
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        #uploadAvatarBtn {
            font-size: 1rem;
            padding: 12px;
        }
        #uploadAvatarBtn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0,123,255,0.3);
            transition: all 0.3s ease;
        }
    </style>
}
